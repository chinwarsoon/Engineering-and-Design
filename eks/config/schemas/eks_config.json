{
    "$schema": "https://eks.engineering/schemas/eks_setup_schema.json",
    "$id": "https://eks.engineering/configs/eks_config_default.json",
    "version": "1.4.0",
    "title": "EKS Default Project Configuration — v1.4.0 (T1.67: project_setup added)",
    "project_rules_registry": {
        "$ref": "https://eks.engineering/configs/eks_project_rules_config.json"
    },
    "discipline_registry": {
        "$ref": "https://eks.engineering/schemas/eks_discipline_schema.json"
    },
    "project_registry": {
        "$ref": "https://eks.engineering/schemas/eks_project_code_schema.json"
    },
    "department_registry": {
        "$ref": "https://eks.engineering/schemas/eks_department_schema.json"
    },
    "facility_registry": {
        "$ref": "https://eks.engineering/schemas/eks_facility_schema.json"
    },
    "global_paths": {
        "data_dir": "data",
        "output_dir": "output",
        "archive_dir": "archive",
        "config_dir": "config"
    },
    "registry": {
        "type": "duckdb",
        "connection_string": "output/eks_registry.db",
        "timeout": 30
    },
    "parsers": {
        ".pdf": "eks.engine.parsers.pdf_parser.PDFParser",
        ".docx": "eks.engine.parsers.docx_parser.DOCXParser",
        ".xlsx": "eks.engine.parsers.xlsx_parser.XLSXParser",
        ".dgn": "eks.engine.parsers.dgn_parser.DGNParserStub",
        ".dwg": "eks.engine.parsers.dwg_parser.DWGParserStub"
    },
    "embedding": {
        "active_provider": "openai",
        "model_name": "text-embedding-3-small",
        "dimensions": 1536
    },
    "vector_store": {
        "url": "http://localhost:6333",
        "collection_name": "eks_chunks",
        "distance_metric": "Cosine"
    },
    "logging": {
        "default_level": 1,
        "debug_file_path": "output/debug_log.json"
    },
    "project_setup": {
        "required_folders": [
            "archive", "config", "data", "output", "engine",
            "log", "docs", "workplan", "test", "ui"
        ],
        "required_engine_subfolders": [
            "core", "parsers", "chunking", "embedding",
            "vector_store", "graph", "extractors", "retrieval",
            "cache", "logging"
        ],
        "required_files": [
            "eks.yml",
            "eks/config/schemas/eks_base_schema.json",
            "eks/config/schemas/eks_setup_schema.json"
        ],
        "environment": {
            "python_version": "3.13",
            "conda_env": "eks",
            "dependencies": [
                "duckdb", "jsonschema", "pymupdf", "python-docx",
                "openpyxl", "psutil", "rdflib", "fastapi", "uvicorn",
                "qdrant-client", "neo4j", "openai", "tiktoken",
                "pytest", "referencing"
            ]
        },
        "validation_options": {
            "auto_create_folders": true,
            "strict_file_validation": false,
            "verbose": false
        }
    }
}
