function moveColumn(index, direction, event) {
    event.stopPropagation(); // Prevents menu from closing
    const newIndex = index + direction;
    
    if (newIndex >= 0 && newIndex < headers.length) {
        // 1. Swap headers in the global array
        const temp = headers[index];
        headers[index] = headers[newIndex];
        headers[newIndex] = temp;
        
        // 2. Re-render the ENTIRE checklist content, including the top buttons
        document.getElementById('columnChecklist').innerHTML = `
            <div style="display: flex; gap: 10px; padding-bottom: 10px; margin-bottom: 10px; border-bottom: 1px solid var(--border);">
                <button class="btn-outline" style="flex: 1; padding: 4px; font-size: 11px;" onclick="bulkToggleCols(true, event)">Select All</button>
                <button class="btn-outline" style="flex: 1; padding: 4px; font-size: 11px;" onclick="bulkToggleCols(false, event)">Clear All</button>
            </div>
            <div id="checkListItems">
                ${headers.map((h, i) => `
                    <div class="col-reorder-item" style="display: flex; align-items: center; gap: 5px; margin-bottom: 5px;">
                        <button class="btn-outline" style="padding: 2px 5px; font-size: 10px;" onclick="moveColumn(${i}, -1, event)">▲</button>
                        <button class="btn-outline" style="padding: 2px 5px; font-size: 10px;" onclick="moveColumn(${i}, 1, event)">▼</button>
                        <label style="flex-grow: 1; margin: 0; text-transform: none; opacity: 1; cursor: pointer;">
                            <input type="checkbox" class="col-visibility-check" data-col="${h}" ${hiddenColumns.has(h) ? '' : 'checked'} onchange="toggleCol('${h}')"> ${h}
                        </label>
                    </div>
                `).join('')}
            </div>
        `;

        // 3. Refresh the table to show the new sequence
        runFilter();
    }
}




    // --- Column Resizing Engine ---

    function initResizers() {

        const ths = document.querySelectorAll('th');

        ths.forEach(th => {

            // Remove existing resizer if any to avoid duplicates

            const oldResizer = th.querySelector('.resizer');

            if (oldResizer) oldResizer.remove();



            const resizer = document.createElement('div');

            resizer.classList.add('resizer');

            th.appendChild(resizer);



            // Prevent clicks on the resizer from also triggering sorting on the header
            resizer.addEventListener('click', (e) => e.stopPropagation());

            resizer.addEventListener('mousedown', function(e) {

                e.preventDefault();

                e.stopPropagation();

                

                const startX = e.pageX;

                const startWidth = th.offsetWidth;

                th.classList.add('resizing');



                const onMouseMove = (e) => {

                    const width = startWidth + (e.pageX - startX);

                    if (width > 50) { // Minimum width constraint

                        th.style.width = width + 'px';

                        th.style.minWidth = width + 'px'; // Essential for table-layout: auto

                    }

                };



                const onMouseUp = () => {

                    th.classList.remove('resizing');

                    document.removeEventListener('mousemove', onMouseMove);

                    document.removeEventListener('mouseup', onMouseUp);

                    // Persist the resized width so it survives table rerenders
                    if (th.dataset && th.dataset.col) {
                        columnWidths[th.dataset.col] = th.offsetWidth;
                    }
                };



                document.addEventListener('mousemove', onMouseMove);

                document.addEventListener('mouseup', onMouseUp);

            });

        });

    }



    function autoFitColumns() {
        const table = document.getElementById('mainTable');
        if (!table) return;

        // Let the browser size columns based on the rendered content once
        table.style.tableLayout = 'auto';

        requestAnimationFrame(() => {
            const ths = table.querySelectorAll('th');
            ths.forEach(th => {
                const col = th.dataset.col;
                if (!col) return;
                const w = Math.ceil(th.getBoundingClientRect().width);
                columnWidths[col] = w;
                th.style.width = `${w}px`;
                th.style.minWidth = `${w}px`;
            });
            // Lock layout to make manual resizing behave predictably
            table.style.tableLayout = 'fixed';
        });
    }


    // Core Data Logic

    function isExcelDate(val) {
        return typeof val === 'number' && val > 29221 && val < 60000;
    }

    function excelSerialToJsDate(val) {
        if (val instanceof Date) return val;
        if (isExcelDate(val)) return new Date((val - 25569) * 86400 * 1000);
        const parsed = new Date(val);
        return !isNaN(parsed) ? parsed : null;
    }

    function sanitizeHeader(h) {
        return typeof h === 'string' ? h.replace(/[\r\n\t]+/g, ' ').trim() : h;
    }



    document.getElementById('upload').addEventListener('change', (e) => {

        const reader = new FileReader();

        reader.onload = (evt) => {

            workbook = XLSX.read(evt.target.result, {type: 'array', cellDates: true});

            const s = document.getElementById('sheetSelector');

            s.innerHTML = workbook.SheetNames.map(n => `<option value="${n}">${n}</option>`).join('');

            s.classList.remove('hidden');

            loadSheet(workbook.SheetNames[0]);

        };

        reader.readAsArrayBuffer(e.target.files[0]);

    });



function loadSheet(name) {
    logDebug("Loading sheet: " + name);
    console.log("Loading sheet:", name);

    // 1. Data Extraction
    const sheet = workbook.Sheets[name];

    // We use {cellDates: true} in the reader, so sheet_to_json handles the rest
    // Convert to JSON with defval as null to easily identify truly empty cells
    // const sheetData = XLSX.utils.sheet_to_json(sheet, {defval: ""});
    let sheetData = XLSX.utils.sheet_to_json(sheet, { defval: null });


    // 2. Validation Check
    if (sheetData.length === 0) {
        alert("This sheet appears to be empty.");
        return;
    }

// 3. Header and Data Sanitization
//    rawData = sheetData.map(row => {
//        const cleanRow = {};
//        Object.keys(row).forEach(k => {
//            const cleanKey = sanitizeHeader(k);
//            cleanRow[cleanKey] = row[k];
//        });
//        return cleanRow;
//    });
//
// --- STEP A: Clean Headers and Remove Blank Columns ---
// Identify columns that have at least one non-null/non-empty value
//    let allPossibleHeaders = Object.keys(sheetData[0]);
//    headers = allPossibleHeaders.filter(h => {
//        return sheetData.some(row => row[h] !== null && row[h] !== "");
//    }).map(h => sanitizeHeader(h));

rawData = sheetData.map(row => {
    const cleanRow = {};
    let hasData = false; // Start by assuming the box is empty

    Object.keys(row).forEach(k => {
        const cleanKey = sanitizeHeader(k);
        const value = row[k];

        // Check if the value is actually something useful (not null, undefined, or empty string)
        if (value !== null && value !== undefined && String(value).trim() !== "") {
            hasData = true; // We found something! This row is not blank.
            cleanRow[cleanKey] = value;
        } else {

            //cleanRow[cleanKey] = cleanKey.toLowerCase().includes("date") ? null : "NA"; // If the header name contains "date", use null. Otherwise use "NA".
            //cleanRow[cleanKey] = "NA"; // Fill blanks with "NA" as requested
            cleanRow[cleanKey] = null; // Fill blanks with Null as requested
        }
    });

    // If the row has data, return the clean box. If not, return null.
    return hasData ? cleanRow : null;
}).filter(row => row !== null); // This final step throws away all the "null" (blank) rows.


// Assign header
    headers = Object.keys(rawData[0]);
    console.log("Detected Headers:", headers);

    // Reset any saved widths when the dataset changes
    columnWidths = {};
    autoFitDone = false;

    logDebug(`Cleaned Data: ${rawData.length} rows, ${headers.length} columns.`);





// 4. UI: Populate Step 2 (Column Selection)
    const headerListEl = document.getElementById('headerList');
    if (headerListEl) {
        headerListEl.innerHTML = headers.map(h => `
            <label class="toggle-chip">
                <input type="checkbox" value="${h.replace(/"/g, '&quot;')}" class="col-check" onchange="syncChip(this)"> 
                <span class="status-icon"></span> ${h}
            </label>
        `).join('');
    }

    // 5. UI: Transitions
    // Reveal Step 2
    document.getElementById('step2').classList.remove('hidden');

// Ensure the container for the chips is visible
    const step2Container = document.getElementById('headerListContainer');
    if (step2Container) {
        step2Container.style.display = "block";
        step2Container.classList.remove('hidden');
    }

// Auto-collapse Step 1 (the file upload box) to focus the user on Step 2
    const step1Container = document.getElementById('loadFilesContainer');
    const step1Btn = document.getElementById('toggleStep1Btn');
    if (step1Container) {
        step1Container.style.display = "none";
        if (step1Btn) step1Btn.innerHTML = "▼ Show File Upload";
    }


}


function syncChip(input) {
    const label = input.parentElement;
    
    // Use classList ONLY. 
    // Do NOT add characters like '●' here.
    if (input.checked) {
        label.classList.add('active');
    } else {
        label.classList.remove('active');
    }
}


function populateDropdowns() {
    selectedFilterCols.forEach(col => {
        const listEl = document.getElementById(`list-${col}`); 
        if (!listEl) return;

        // Get unique values and explicitly handle the null/empty ones
        const uniqueRaw = [...new Set(rawData.map(r => r[col]))];
        
        const uniqueFormatted = uniqueRaw.map(v => {
            // Check for nulls, undefined, or empty strings from the sanitization step
            if (v === null || v === undefined || String(v).trim() === "") return "(Blanks)";
            return String(formatExcelDate(v));
        });

        // De-duplicate (to merge null and "") and sort
        const finalUnique = [...new Set(uniqueFormatted)].sort();

        listEl.innerHTML = finalUnique.map(v => {
            const escaped = v.replace(/'/g, "\\'");
            return `
                <div class="option-item">
                    <label>
                        <input type="checkbox" data-val="${escaped}" onchange="handleSelect('${col}','${escaped}', this.checked)"> 
                        ${v}
                    </label>
                </div>`;
        }).join('');
    });
}


