{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://eks.engineering/schemas/eks_base_schema.json",
    "version": "1.8.0",
    "title": "EKS Base Schema - Definitions",
    "description": "Pipeline configuration definitions. Document metadata definitions moved to eks_doc_base_schema.json (T1.34). discipline_code consolidated into discipline_entry_def.properties.code (removed as standalone def per U079). document_relationship_trigger_map stripped to shape-only (v1.4.0) — actual entries moved to config files (U086). revision_id moved to doc schema set (v1.5.0) — U087. v1.6.0: added required_folder_setup_def, required_file_setup_def, environment_setup_def, validation_options_def (T1.67). v1.7.0: replaced flat-array project_setup defs with DCC-aligned object definitions: folder_entry_def, root_file_entry_def, schema_file_entry_def, discovery_rule_def, environment_entry_def, dependency_config_def, validation_rule_entry_def, project_metadata_def (T1.85). v1.8.0: added system_parameters_def for T1.97/I088 SSOT runtime behavior settings. v1.9.0: added workflow_file_entry_def and tool_file_entry_def for T1.98.6/I090 (DCC project_config parity).",
    "type": "object",
    "definitions": {
        "discipline_entry_def": {
            "type": "object",
            "properties": {
                "code": { "type": "string" },
                "description": { "type": "string" }
            },
            "required": ["code", "description"],
            "additionalProperties": false
        },
        "project_rules_def": {
            "type": "object",
            "properties": {
                "allowed_disciplines": {
                    "type": "array",
                    "items": { "type": "string" },
                    "description": "List of discipline codes permitted for this project"
                },
                "fragment_required_fields": {
                    "type": "object",
                    "description": "Per-fragment required field overrides for this project. Key = fragment name (item_core, manufacturer, etc.), value = array of required property paths. Shape-only definitions in asset base schema carry no required constraints — this is the SSOT for mandatory fields.",
                    "additionalProperties": {
                        "type": "array",
                        "items": { "type": "string" },
                        "minItems": 1
                    }
                }
            },
            "required": ["allowed_disciplines"],
            "additionalProperties": false
        },
        "global_paths_def": {
            "type": "object",
            "properties": {
                "data_dir": { "type": "string" },
                "output_dir": { "type": "string" },
                "archive_dir": { "type": "string" },
                "config_dir": { "type": "string" },
                "log_dir": { "type": "string", "description": "Log directory relative to eks_root (T1.83 follow-up)" },
                "eks_root": { "type": "string", "description": "EKS package root relative to project root (T1.83)" }
            },
            "required": ["data_dir", "output_dir", "archive_dir", "config_dir", "log_dir"],
            "additionalProperties": false
        },
        "registry_def": {
            "type": "object",
            "properties": {
                "type": { "type": "string", "enum": ["duckdb", "postgresql"] },
                "connection_string": { "type": "string" }
            },
            "required": ["type", "connection_string"],
            "additionalProperties": false
        },
        "system_parameters_def": {
            "type": "object",
            "description": "Runtime behavior settings for loaders, validators, servers, and registry retry behavior (T1.97/I088).",
            "properties": {
                "fail_fast": { "type": "boolean", "default": true },
                "log_level": { "$ref": "#/definitions/verbosity_level", "default": 1 },
                "debug_mode": { "type": "boolean", "default": false },
                "skip_readiness": { "type": "boolean", "default": false },
                "retry_count": { "type": "integer", "minimum": 0, "default": 3 },
                "retry_delay": { "type": "number", "minimum": 0, "default": 0.5 },
                "api_timeout": { "type": "integer", "minimum": 1, "default": 120 },
                "ollama_timeout": { "type": "integer", "minimum": 1, "default": 30 },
                "db_timeout": { "type": "integer", "minimum": 1, "default": 30 }
            },
            "required": ["fail_fast", "log_level", "debug_mode", "skip_readiness", "retry_count", "retry_delay", "api_timeout", "ollama_timeout", "db_timeout"],
            "additionalProperties": false
        },
        "parsers_def": {
            "type": "object",
            "additionalProperties": { "type": "string" }
        },
        "embedding_def": {
            "type": "object",
            "properties": {
                "active_provider": { "type": "string", "enum": ["openai", "ollama"] },
                "model_name": { "type": "string" },
                "dimensions": { "type": "integer" }
            },
            "required": ["active_provider", "model_name", "dimensions"],
            "additionalProperties": false
        },
        "vector_store_def": {
            "type": "object",
            "properties": {
                "url": { "type": "string" },
                "collection_name": { "type": "string" },
                "distance_metric": { "type": "string", "enum": ["Cosine", "Euclidean", "Dot"] }
            },
            "required": ["url", "collection_name", "distance_metric"],
            "additionalProperties": false
        },
        "logging_def": {
            "type": "object",
            "properties": {
                "default_level": { "$ref": "#/definitions/verbosity_level", "default": 1 },
                "debug_file_path": { "type": "string" }
            },
            "required": ["default_level"],
            "additionalProperties": false
        },
        "verbosity_level": {
            "type": "integer",
            "enum": [0, 1, 2, 3],
            "description": "Shared verbosity/logging level (0=quiet/errors only, 1=normal, 2=debug, 3=trace)"
        },
        "document_relationship_trigger_map": {
            "type": "object",
            "description": "Shape definition: maps document metadata field names to ontology relationship types. Actual entries defined per-schema-set in config files (eks_asset_config.json, eks_doc_config.json).",
            "additionalProperties": { "type": "string" }
        },
        "project_entry_def": {
            "type": "object",
            "properties": {
                "code": { "type": "string", "description": "Project code identifier" },
                "description": { "type": "string", "description": "Project name or description" }
            },
            "required": ["code", "description"],
            "additionalProperties": false
        },
        "department_entry_def": {
            "type": "object",
            "properties": {
                "code": { "type": "string", "description": "Department code identifier" },
                "description": { "type": "string", "description": "Department name" }
            },
            "required": ["code", "description"],
            "additionalProperties": false
        },
        "facility_entry_def": {
            "type": "object",
            "properties": {
                "prefix": { "type": "string", "description": "Facility prefix code" },
                "description": { "type": "string", "description": "Facility description" }
            },
            "required": ["prefix", "description"],
            "additionalProperties": false
        },
        "folder_entry_def": {
            "type": "object",
            "description": "Folder/directory entry with metadata (DCC-aligned)",
            "properties": {
                "name": { "type": "string", "description": "Relative path of the folder from project root" },
                "required": { "type": "boolean", "description": "Whether this folder is mandatory" },
                "purpose": { "type": "string", "description": "Description of the folder's purpose" },
                "auto_created": { "type": "boolean", "description": "Whether this folder is auto-created on first run", "default": false }
            },
            "required": ["name", "required", "purpose"],
            "additionalProperties": false
        },
        "root_file_entry_def": {
            "type": "object",
            "description": "File at project root level (DCC-aligned)",
            "properties": {
                "name": { "type": "string", "description": "Filename at root level" },
                "required": { "type": "boolean", "description": "Whether this file is mandatory" },
                "purpose": { "type": "string", "description": "Description of the file's purpose" },
                "extension": { "type": "string", "enum": ["yml", "yaml", "md", "txt", "py", "json", "other"], "description": "File type extension" }
            },
            "required": ["name", "required", "purpose"],
            "additionalProperties": false
        },
        "schema_file_entry_def": {
            "type": "object",
            "description": "Schema file entry with metadata (DCC-aligned)",
            "properties": {
                "filename": { "type": "string", "description": "Schema filename relative to config/schemas" },
                "required": { "type": "boolean", "description": "Whether this schema file is mandatory" },
                "description": { "type": "string", "description": "Purpose of this schema file" }
            },
            "required": ["filename", "required", "description"],
            "additionalProperties": false
        },
        "workflow_file_entry_def": {
            "type": "object",
            "description": "Workflow/pipeline file entry with metadata (DCC-aligned — project_config.json#/workflow_files, T1.98.6/I090)",
            "properties": {
                "filename": { "type": "string", "description": "Workflow filename relative to project root" },
                "required": { "type": "boolean", "description": "Whether this workflow file is mandatory" },
                "description": { "type": "string", "description": "Purpose of this workflow file" },
                "type": { "type": "string", "description": "File classification (e.g. python_module, python_script)", "default": "python_module" }
            },
            "required": ["filename", "required", "description"],
            "additionalProperties": false
        },
        "tool_file_entry_def": {
            "type": "object",
            "description": "Tool/utility file entry with metadata (DCC-aligned — project_config.json#/tool_files, T1.98.6/I090)",
            "properties": {
                "filename": { "type": "string", "description": "Tool filename relative to project root" },
                "required": { "type": "boolean", "description": "Whether this tool file is mandatory" },
                "description": { "type": "string", "description": "Purpose of this tool file" },
                "type": { "type": "string", "description": "File classification (e.g. python_module, python_script)", "default": "python_script" }
            },
            "required": ["filename", "required", "description"],
            "additionalProperties": false
        },
        "discovery_rule_def": {
            "type": "object",
            "description": "Pattern-based discovery rule (DCC-aligned)",
            "properties": {
                "pattern": { "type": "string", "description": "File pattern to match" },
                "directory": { "type": "string", "description": "Directory to search in" },
                "recursive": { "type": "boolean", "description": "Whether to search recursively", "default": false },
                "auto_register": { "type": "boolean", "description": "Whether to auto-register discovered files", "default": false },
                "category": { "type": "string", "description": "Category of discovered files" },
                "exclude_patterns": { "type": "array", "description": "Patterns to exclude", "items": { "type": "string" } }
            },
            "required": ["pattern", "directory", "category"],
            "additionalProperties": false
        },
        "environment_entry_def": {
            "type": "object",
            "description": "Environment specification entry (DCC-aligned)",
            "properties": {
                "name": { "type": "string", "description": "Environment name (e.g. conda, venv)" },
                "required": { "type": "boolean", "description": "Whether this environment is mandatory" },
                "file": { "type": "string", "description": "Environment specification file (e.g. eks.yml)" },
                "location": { "type": "string", "enum": ["root", "config", "tools"], "description": "Where the environment file is located" },
                "setup_commands": { "type": "array", "description": "Commands to set up the environment", "items": { "type": "string" } },
                "key_dependencies": { "type": "array", "description": "Primary dependencies for this project", "items": { "type": "string" } },
                "python_version": { "type": "string", "description": "Expected Python version (e.g. 3.13)" },
                "conda_env": { "type": "string", "description": "Conda environment name" }
            },
            "required": ["name", "required"],
            "additionalProperties": false
        },
        "dependency_config_def": {
            "type": "object",
            "description": "Complete dependencies configuration (DCC-aligned)",
            "properties": {
                "required": { "type": "array", "description": "Required Python packages", "items": { "type": "string" } },
                "optional": { "type": "array", "description": "Optional Python packages", "items": { "type": "string" } },
                "engines": {
                    "type": "array",
                    "description": "Engine modules with their exports",
                    "items": {
                        "type": "object",
                        "properties": {
                            "module": { "type": "string", "description": "Python module name" },
                            "members": { "type": "array", "description": "Required classes/functions from this module", "items": { "type": "string" } },
                            "optional": { "type": "boolean", "description": "Whether this engine dependency is optional", "default": false }
                        },
                        "required": ["module"]
                    }
                }
            },
            "required": ["required"],
            "additionalProperties": false
        },
        "validation_rule_entry_def": {
            "type": "object",
            "description": "Validation rule configuration (DCC-aligned)",
            "properties": {
                "rule": { "type": "string", "description": "Validation rule identifier" },
                "enabled": { "type": "boolean", "description": "Whether this rule is active", "default": true },
                "description": { "type": "string", "description": "Purpose of this validation rule" },
                "severity": { "type": "string", "enum": ["error", "warning", "info"], "default": "error", "description": "Validation failure severity level" },
                "parameters": { "type": "object", "description": "Rule-specific configuration parameters" }
            },
            "required": ["rule", "description"],
            "additionalProperties": false
        },
        "project_metadata_def": {
            "type": "object",
            "description": "Project metadata and identification (DCC-aligned)",
            "properties": {
                "project_id": { "type": "string", "description": "Unique project identifier" },
                "project_name": { "type": "string", "description": "Human-readable project name" },
                "version": { "type": "string", "description": "Project version" },
                "created_date": { "type": "string", "format": "date", "description": "Project creation date" },
                "last_modified": { "type": "string", "format": "date", "description": "Last modification date" }
            },
            "required": ["project_id", "project_name", "version"],
            "additionalProperties": false
        }
    }
}
