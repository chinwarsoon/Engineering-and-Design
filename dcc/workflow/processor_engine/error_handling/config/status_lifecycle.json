{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dcc-pipeline.internal/schemas/error-status-lifecycle",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {"type": "string"},
    "states": {
      "type": "object",
      "additionalProperties": {"type": "object"}
    },
    "transitions": {
      "type": "array",
      "items": {"type": "object"}
    }
  },
  "required": ["version", "states", "transitions"],
  "version": "1.0",
  "states": {
    "NEW": {"description": "Error just identified"},
    "IN_PROGRESS": {"description": "Being remediated"},
    "RESOLVED": {"description": "Fix applied"},
    "CLOSED": {"description": "Verified and closed"}
  },
  "transitions": [
    {"from": "NEW", "to": "IN_PROGRESS"},
    {"from": "IN_PROGRESS", "to": "RESOLVED"},
    {"from": "RESOLVED", "to": "CLOSED"}
  ]
}
