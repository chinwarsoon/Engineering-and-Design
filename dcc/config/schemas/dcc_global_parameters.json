{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dcc-pipeline.internal/schemas/dcc_global_parameters",
  "title": "DCC Global Processing Parameter Values",
  "description": "Actual runtime values for data processing parameters. Values-only file - definitions are in dcc_register_base#/definitions/dcc_parameter_entry. Referenced by dcc_register_config.json via $ref.",
  "version": "1.0.0",
  "type": "object",
  "additionalProperties": false,
  "allOf": [
    {
      "$ref": "https://dcc-pipeline.internal/schemas/dcc_register_base"
    }
  ],
  "dcc_parameters": {
    "duration_is_working_day": true,
    "start_col": "P",
    "end_col": "AP",
    "header_row_index": 4,
    "first_review_duration": 20,
    "second_review_duration": 14,
    "resubmission_duration": 14,
    "upload_sheet_name": "Prolog Submittals ",
    "win_upload_file": "data/Submittal and RFI Tracker Lists.xlsx",
    "win_download_path": "output",
    "linux_upload_file": "data/Submittal and RFI Tracker Lists.xlsx",
    "linux_download_path": "output",
    "colab_upload_file": "/content/sample_data/Submittal and RFI Tracker Lists.xlsx",
    "colab_download_path": "/content/output",
    "upload_file_name": "data/Submittal and RFI Tracker Lists.xlsx",
    "download_file_path": "output",
    "output_filename_pattern": "processed_dcc_universal",
    "summary_filename": "processing_summary.txt",
    "error_dashboard_filename": "error_dashboard_data.json",
    "error_diagnostic_log_filename": "error_diagnostic_log.csv",
    "debug_log_filename": "debug_log.json",
    "ai_insight_summary_filename": "ai_insight_summary.json",
    "ai_insight_report_filename": "ai_insight_report.md",
    "ai_insight_trace_filename": "ai_insight_trace.json",
    "schema_validation_status_filename": "schema_validation_status.json",
    "ai_runs_db_filename": "dcc_runs.duckdb",
    "ai_model": "llama3.2:3b",
    "model_memory_headroom_gb": 2.0,
    "model_pool": [
      {
        "name": "llama3.2:3b",
        "size_gb": 2.0,
        "family": "llama3.2",
        "capability": "chat",
        "ram_multiplier": 1.5,
        "enabled": true,
        "notes": "Schema default. Best fit/quality balance for 9.5 GB available RAM."
      },
      {
        "name": "qwen2.5-coder:3b",
        "size_gb": 1.9,
        "family": "qwen2.5",
        "capability": "code",
        "ram_multiplier": 1.5,
        "enabled": true,
        "notes": "Backup candidate for code-heavy prompts."
      },
      {
        "name": "deepseek-coder:1.3b",
        "size_gb": 0.776,
        "family": "deepseek-coder",
        "capability": "code",
        "ram_multiplier": 1.5,
        "enabled": true,
        "notes": "Low-RAM fallback. Tested OK on 1.2 GB available."
      },
      {
        "name": "gemma3:4b",
        "size_gb": 3.3,
        "family": "gemma3",
        "capability": "chat",
        "ram_multiplier": 1.5,
        "enabled": true,
        "notes": "Marginal headroom; use when 5+ GB free."
      },
      {
        "name": "gemma4:e4b",
        "size_gb": 9.6,
        "family": "gemma4",
        "capability": "chat",
        "ram_multiplier": 1.5,
        "enabled": false,
        "notes": "Confirmed hang on 11 GiB host (60s timeout, exceeds 14 GB requirement). Hard-blocked via enabled=false."
      },
      {
        "name": "llama3.1:8b",
        "size_gb": 4.9,
        "family": "llama3.1",
        "capability": "chat",
        "ram_multiplier": 1.5,
        "enabled": true,
        "notes": "Original hardcoded default. Slow (19.8s) but works; available if free RAM > 9.4 GB."
      },
      {
        "name": "hermes3:8b",
        "size_gb": 4.7,
        "family": "hermes3",
        "capability": "chat",
        "ram_multiplier": 1.5,
        "enabled": true,
        "notes": "Hermes 3 8B model available locally."
      },
      {
        "name": "hermes3:latest",
        "size_gb": 4.7,
        "family": "hermes3",
        "capability": "chat",
        "ram_multiplier": 1.5,
        "enabled": true,
        "notes": "Hermes 3 latest available locally."
      },
      {
        "name": "qwen:latest",
        "size_gb": 2.3,
        "family": "qwen",
        "capability": "chat",
        "ram_multiplier": 1.5,
        "enabled": true,
        "notes": "Qwen latest model available locally."
      },
      {
        "name": "qwen2.5-coder:14b",
        "size_gb": 9.0,
        "family": "qwen2.5",
        "capability": "code",
        "ram_multiplier": 1.5,
        "enabled": true,
        "notes": "Large coder model available locally."
      },
      {
        "name": "gemma4:e2b",
        "size_gb": 7.2,
        "family": "gemma4",
        "capability": "chat",
        "ram_multiplier": 1.5,
        "enabled": true,
        "notes": "Gemma 4 e2b variant available locally."
      },
      {
        "name": "qwen2.5-coder:1.5b-base",
        "size_gb": 0.986,
        "family": "qwen2.5",
        "capability": "code",
        "ram_multiplier": 1.5,
        "enabled": true,
        "notes": "Small coder base model available locally."
      }
    ],
    "embed_model_pool": [
      {
        "name": "nomic-embed-text",
        "size_gb": 0.27,
        "family": "nomic",
        "capability": "embed",
        "ram_multiplier": 1.5,
        "enabled": true,
        "notes": "Fixed embedding model. Not RAM-selected; used by name."
      },
      {
        "name": "nomic-embed-text:latest",
        "size_gb": 0.274,
        "family": "nomic",
        "capability": "embed",
        "ram_multiplier": 1.5,
        "enabled": true,
        "notes": "Latest version of nomic-embed-text available locally."
      }
    ],
    "pending_status": {
      "schema": "approval_code_schema",
      "code": "PEN",
      "field": "status",
      "description": "Resolved from approval_code_schema approval entry with code 'PEN'. Ensures single source of truth for pending status."
    },
    "dynamic_column_creation": {
      "enabled": true,
      "missing_column_action": "create_with_default",
      "default_value": "NA",
      "description": "Executed by _initialize_missing_columns. If a schema column is not found in the input data, it is created using the global or column-specific default value."
    },
    "fill_jump_limit": 20,
    "fill_max_percentage": 80.0,
    "submission_count_warning_threshold": 100,
    "health_pass_threshold": 90.0,
    "health_fail_threshold": 60.0,
    "health_grade_thresholds": {
      "A+": 99.0,
      "A": 95.0,
      "A-": 90.0,
      "B+": 85.0,
      "B": 80.0,
      "C": 70.0,
      "D": 60.0,
      "F": 0.0
    }
  }
}