{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dcc-pipeline.internal/schemas/global_parameters",
  "title": "DCC Global Parameters",
  "description": "Global pipeline parameters with type metadata and default values for DCC processing pipeline. Type-driven validation enabled.",
  "version": "2.0.0",
  "type": "object",
  "additionalProperties": false,
  "allOf": [
    {"$ref": "https://dcc-pipeline.internal/schemas/project_setup_base#/definitions/global_parameters_entry"}
  ],
  "global_parameters": [
    {
      "key": "fail_fast",
      "type": "boolean",
      "description": "Stop pipeline on first error",
      "default_value": false,
      "required": false
    },
    {
      "key": "debug_dev_mode",
      "type": "boolean",
      "description": "Enable debug mode for development",
      "default_value": false,
      "required": false
    },
    {
      "key": "is_colab",
      "type": "boolean",
      "description": "Running in Google Colab environment",
      "default_value": false,
      "required": false
    },
    {
      "key": "overwrite_existing_downloads",
      "type": "boolean",
      "description": "Whether to overwrite existing output files",
      "default_value": true,
      "required": false
    },
    {
      "key": "duration_is_working_day",
      "type": "boolean",
      "description": "Calculate durations in working days",
      "default_value": true,
      "required": false
    },
    {
      "key": "pc_name",
      "type": "scalar",
      "description": "PC identifier for environment tracking",
      "default_value": "CESL-22120",
      "required": false
    },
    {
      "key": "start_col",
      "type": "scalar",
      "description": "Excel start column for processing",
      "default_value": "P",
      "required": false,
      "pattern": "^[A-Z]{1,3}$"
    },
    {
      "key": "end_col",
      "type": "scalar",
      "description": "Excel end column for processing",
      "default_value": "AP",
      "required": false,
      "pattern": "^[A-Z]{1,3}$"
    },
    {
      "key": "header_row_index",
      "type": "integer",
      "description": "Excel header row index (0-based)",
      "default_value": 4,
      "required": false,
      "min_value": 0,
      "max_value": 1000
    },
    {
      "key": "first_review_duration",
      "type": "integer",
      "description": "First review duration in days",
      "default_value": 20,
      "required": false,
      "min_value": 1
    },
    {
      "key": "second_review_duration",
      "type": "integer",
      "description": "Second review duration in days",
      "default_value": 14,
      "required": false,
      "min_value": 1
    },
    {
      "key": "resubmission_duration",
      "type": "integer",
      "description": "Resubmission duration in days",
      "default_value": 14,
      "required": false,
      "min_value": 1
    },
    {
      "key": "progress_stage",
      "type": "scalar",
      "description": "Current pipeline progress stage",
      "default_value": "not_start",
      "required": false
    },
    {
      "key": "upload_sheet_name",
      "type": "scalar",
      "description": "Excel sheet name for data extraction",
      "default_value": "Prolog Submittals",
      "required": false
    },
    {
      "key": "win_upload_file",
      "type": "file",
      "description": "Windows-specific input file path",
      "default_value": "K:\\J Submission\\Submittal and RFI Tracker Lists.xlsx",
      "required": false,
      "check_exists": true,
      "file_extensions": [".xlsx", ".xls"]
    },
    {
      "key": "win_download_path",
      "type": "directory",
      "description": "Windows-specific output directory path",
      "default_value": "K:\\J Submission\\AI Tools and Report\\data_output",
      "required": false,
      "check_exists": false,
      "create_if_missing": true
    },
    {
      "key": "win_upload_file_fallback",
      "type": "file",
      "description": "Windows fallback input file path",
      "default_value": "data/Submittal and RFI Tracker Lists.xlsx",
      "required": false,
      "check_exists": true,
      "file_extensions": [".xlsx", ".xls"]
    },
    {
      "key": "win_download_path_fallback",
      "type": "directory",
      "description": "Windows fallback output directory path",
      "default_value": "output",
      "required": false,
      "check_exists": false,
      "create_if_missing": true
    },
    {
      "key": "linux_upload_file",
      "type": "file",
      "description": "Linux-specific input file path",
      "default_value": "data/Submittal and RFI Tracker Lists.xlsx",
      "required": false,
      "check_exists": true,
      "file_extensions": [".xlsx", ".xls"]
    },
    {
      "key": "linux_download_path",
      "type": "directory",
      "description": "Linux-specific output directory path",
      "default_value": "output",
      "required": false,
      "check_exists": false,
      "create_if_missing": true
    },
    {
      "key": "colab_upload_file",
      "type": "file",
      "description": "Colab-specific input file path",
      "default_value": "/content/sample_data/Submittal and RFI Tracker Lists.xlsx",
      "required": false,
      "check_exists": true,
      "file_extensions": [".xlsx", ".xls"]
    },
    {
      "key": "colab_download_path",
      "type": "directory",
      "description": "Colab-specific output directory path",
      "default_value": "/content/output",
      "required": false,
      "check_exists": false,
      "create_if_missing": true
    },
    {
      "key": "upload_colab_file_name",
      "type": "file",
      "description": "Colab input file name (alternative key)",
      "default_value": "/content/sample_data/Submittal and RFI Tracker Lists.xlsx",
      "required": false,
      "check_exists": true,
      "file_extensions": [".xlsx", ".xls"]
    },
    {
      "key": "upload_file_name",
      "type": "file",
      "description": "Generic input file path (default)",
      "default_value": "data/Submittal and RFI Tracker Listss.xlsx",
      "required": true,
      "check_exists": true,
      "file_extensions": [".xlsx", ".xls"],
      "cli_arg_name": "--excel-file",
      "cli_arg_short": "-e",
      "aliases": ["excel_file", "input_file"]
    },
    {
      "key": "download_file_path",
      "type": "directory",
      "description": "Generic output directory path (default)",
      "default_value": "output",
      "required": true,
      "check_exists": false,
      "create_if_missing": true,
      "cli_arg_name": "--output-path",
      "aliases": ["output_dir", "output_path"]
    },
    {
      "key": "output_file",
      "type": "file",
      "description": "Final output file name (not full path, just filename)",
      "default_value": "output.xlsx",
      "required": false,
      "check_exists": false,
      "file_extensions": [".xlsx", ".csv", ".json"],
      "cli_arg_name": "--output-file",
      "aliases": ["output_filename", "result_file"]
    },
    {
      "key": "output_filename_pattern",
      "type": "scalar",
      "description": "Default output filename pattern (stem) when output_file not specified",
      "default_value": "processed_dcc_universal",
      "required": false,
      "pattern": "^[a-zA-Z0-9_-]+$",
      "aliases": ["default_output_stem", "output_pattern"]
    },
    {
      "key": "summary_filename",
      "type": "scalar",
      "description": "Processing summary file name",
      "default_value": "processing_summary.txt",
      "required": false,
      "pattern": "^[a-zA-Z0-9_]+\\.(txt|md|log)$",
      "aliases": ["summary_file", "log_filename"]
    },
    {
      "key": "ai_insight_summary_filename",
      "type": "scalar",
      "description": "AI insight summary JSON file name",
      "default_value": "ai_insight_summary.json",
      "required": false,
      "pattern": "^[a-zA-Z0-9_]+\\.json$",
      "aliases": ["ai_summary_file"]
    },
    {
      "key": "ai_insight_report_filename",
      "type": "scalar",
      "description": "AI insight markdown report file name",
      "default_value": "ai_insight_report.md",
      "required": false,
      "pattern": "^[a-zA-Z0-9_]+\\.(md|txt)$",
      "aliases": ["ai_report_file"]
    },
    {
      "key": "ai_insight_trace_filename",
      "type": "scalar",
      "description": "AI insight trace JSON file name",
      "default_value": "ai_insight_trace.json",
      "required": false,
      "pattern": "^[a-zA-Z0-9_]+\\.json$",
      "aliases": ["ai_trace_file"]
    },
    {
      "key": "error_dashboard_filename",
      "type": "scalar",
      "description": "Error dashboard data JSON file name",
      "default_value": "error_dashboard_data.json",
      "required": false,
      "pattern": "^[a-zA-Z0-9_]+\\.json$",
      "aliases": ["dashboard_file", "error_dashboard"]
    },
    {
      "key": "debug_log_filename",
      "type": "scalar",
      "description": "Debug log JSON file name",
      "default_value": "debug_log.json",
      "required": false,
      "pattern": "^[a-zA-Z0-9_]+\\.json$",
      "aliases": ["debug_file", "log_json"]
    },
    {
      "key": "structured_logs_filename",
      "type": "scalar",
      "description": "Structured logs JSON file name",
      "default_value": "dcc_structured_logs.json",
      "required": false,
      "pattern": "^[a-zA-Z0-9_]+\\.json$",
      "aliases": ["structured_logs", "logs_file"]
    },
    {
      "key": "summary_json_filename",
      "type": "scalar",
      "description": "Summary JSON output file name",
      "default_value": "summary.json",
      "required": false,
      "pattern": "^[a-zA-Z0-9_]+\\.json$",
      "aliases": ["summary_json", "result_summary"]
    },
    {
      "key": "schema_validation_status_filename",
      "type": "scalar",
      "description": "Schema validation status JSON file name",
      "default_value": "schema_validation_status.json",
      "required": false,
      "pattern": "^[a-zA-Z0-9_]+\\.json$",
      "aliases": ["validation_status_file"]
    },
    {
      "key": "schema_register_file",
      "type": "file",
      "description": "Path to the schema register JSON file that defines the DCC processing schema",
      "default_value": "config/schemas/dcc_register_config.json",
      "required": true,
      "check_exists": true,
      "file_extensions": [".json"],
      "aliases": ["schema_file", "register_config"]
    },
    {
      "key": "data_dir",
      "type": "directory",
      "description": "Infrastructure directory for input data files",
      "default_value": "data",
      "required": false,
      "check_exists": false,
      "create_if_missing": true,
      "aliases": ["data_directory", "input_dir"]
    },
    {
      "key": "config_dir",
      "type": "directory",
      "description": "Infrastructure directory for configuration files",
      "default_value": "config",
      "required": false,
      "check_exists": false,
      "create_if_missing": true,
      "aliases": ["config_directory", "configuration_dir"]
    },
    {
      "key": "schema_dir",
      "type": "directory",
      "description": "Subdirectory within config_dir for schema definitions",
      "default_value": "schemas",
      "required": false,
      "check_exists": false,
      "create_if_missing": true,
      "aliases": ["schema_directory", "schemas_dir"]
    },
    {
      "key": "pending_status",
      "type": "object",
      "description": "Pending status configuration with schema resolution",
      "default_value": {
        "schema": "approval_code_schema",
        "code": "PEN",
        "field": "status",
        "description": "Resolved from approval_code_schema approval entry with code 'PEN'. Ensures single source of truth for pending status."
      },
      "required": false
    },
    {
      "key": "dynamic_column_creation",
      "type": "object",
      "description": "Dynamic column creation configuration for missing columns",
      "default_value": {
        "enabled": true,
        "missing_column_action": "create_with_default",
        "default_value": "NA",
        "description": "Executed by _initialize_missing_columns. If a schema column is not found in the input data, it is created using the global or column-specific default value."
      },
      "required": false
    }
  ]
}
