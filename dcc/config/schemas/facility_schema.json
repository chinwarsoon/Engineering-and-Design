{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dcc-pipeline.internal/schemas/facility",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_name": {"type": "string"},
    "type": {"type": "string"},
    "data_section": {"type": "string"},
    "field_definitions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "prefix": {"type": "object"},
        "building_description": {"type": "object"},
        "project_prefix_sort_order": {"type": "object"},
        "plant_area_name": {"type": "object"},
        "plant_area_order": {"type": "object"},
        "work_area": {"type": "object"},
        "contract": {"type": "object"},
        "Contract_MEICA": {"type": "object"},
        "used_for_pid": {"type": "object"},
        "sort_number": {"type": "object"}
      },
      "required": ["prefix", "building_description", "project_prefix_sort_order", "plant_area_name", "plant_area_order", "work_area", "used_for_pid", "sort_number"]
    },
    "facility": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "prefix": {"type": ["string", "null"]},
          "building_description": {"type": ["string", "null"]},
          "project_prefix_sort_order": {"type": "number"},
          "plant_area_name": {"type": ["string", "null"]},
          "plant_area_order": {"type": "number"},
          "work_area": {"type": ["string", "null"]},
          "contract": {"type": ["string", "null"]},
          "Contract_MEICA": {"type": ["string", "null"]},
          "used_for_pid": {"type": "boolean"},
          "sort_number": {"type": "number"}
        },
        "required": ["prefix", "building_description", "project_prefix_sort_order", "plant_area_name", "plant_area_order", "work_area", "used_for_pid", "sort_number"]
      }
    },
    "description": {"type": "string"},
    "created": {"type": "string"},
    "version": {"type": ["string", "number"]}
  },
  "required": ["schema_name", "type", "data_section", "field_definitions", "facility"],
  "schema_name": "facility_choices",
  "type": "standard_choices",
  "data_section": "facility",
  "field_definitions": {
    "prefix": {
      "data_type": "string",
      "required": true,
      "validation": {
        "pattern": "^[A-Z]{3}\\d{2}$",
        "min_length": 5,
        "max_length": 5,
        "unique": true
      }
    },
...
  },
  "facility": [
    {
      "prefix": "WDP00",
...
    }
  ],
  "description": "Standard facility codes",
  "created": "2026/04/02",
  "version": 1
}
