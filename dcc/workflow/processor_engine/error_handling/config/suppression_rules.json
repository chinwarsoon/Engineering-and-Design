{
  "version": "1.0",
  "description": "Suppression Rules Configuration - Define 'wrong but acceptable' error scenarios",
  "metadata": {
    "last_updated": "2026-04-10",
    "approved_by": "system_admin",
    "rule_count": 0
  },
  "rules": [
    {
      "rule_id": "SUP-001",
      "name": "Legacy Date Format Tolerance",
      "description": "Accept dates in old format (DD/MM/YYYY) for legacy submissions before 2024-01-01",
      "status": "ACTIVE",
      "priority": 100,
      "error_codes": ["P-V-V-0504"],
      "conditions": {
        "submission_session_before": "20240101",
        "column": "Submission_Date",
        "pattern_match": "^(0[1-9]|[12][0-9]|3[01])/(0[1-9]|1[012])/[0-9]{4}$"
      },
      "justification_template": "Historical data uses DD/MM/YYYY format from legacy system",
      "approved_by": "system_admin",
      "approved_at": "2026-01-15T10:00:00Z",
      "expires_at": "2026-12-31T23:59:59Z",
      "scope": {
        "type": "GLOBAL",
        "project_codes": [],
        "facilities": []
      },
      "severity_override": "WARNING",
      "audit_required": true,
      "created_by": "admin",
      "created_at": "2026-01-15T10:00:00Z"
    },
    {
      "rule_id": "SUP-002",
      "name": "Known Missing References for Memos",
      "description": "Memo and Notes document types don't require full discipline list",
      "status": "ACTIVE",
      "priority": 200,
      "error_codes": ["P-V-V-0506"],
      "conditions": {
        "document_type": ["MEM", "NTS", "MIN"],
        "column": "Discipline",
        "is_null": true
      },
      "justification_template": "{document_type} documents don't require discipline assignment per business rule BR-2024-003",
      "approved_by": "dcc_manager",
      "approved_at": "2026-02-01T14:30:00Z",
      "scope": {
        "type": "GLOBAL",
        "project_codes": [],
        "facilities": []
      },
      "severity_override": "INFO",
      "audit_required": false,
      "created_by": "dcc_manager",
      "created_at": "2026-02-01T14:30:00Z"
    },
    {
      "rule_id": "SUP-003",
      "name": "Test Environment Forward Fill Warnings",
      "description": "Suppress forward fill limit warnings in test environments",
      "status": "ACTIVE",
      "priority": 50,
      "error_codes": ["P-C-F-0401"],
      "conditions": {
        "environment": "TEST",
        "forward_fill_rows": "> 20"
      },
      "justification_template": "Test data often has gaps - forward fill warnings expected",
      "approved_by": "system_admin",
      "approved_at": "2026-03-01T09:00:00Z",
      "scope": {
        "type": "GLOBAL",
        "environments": ["TEST", "DEV"],
        "project_codes": [],
        "facilities": []
      },
      "severity_override": "INFO",
      "audit_required": false,
      "created_by": "qa_lead",
      "created_at": "2026-03-01T09:00:00Z"
    }
  ],
  "rule_types": {
    "GLOBAL": {
      "description": "Apply across all files/projects",
      "requires_approval": "admin",
      "audit_level": "INFO"
    },
    "PROJECT": {
      "description": "Apply to specific project code",
      "requires_approval": "manager",
      "audit_level": "WARNING"
    },
    "FACILITY": {
      "description": "Apply to specific facility code",
      "requires_approval": "manager",
      "audit_level": "WARNING"
    },
    "DOCUMENT": {
      "description": "Apply to specific document type",
      "requires_approval": "reviewer",
      "audit_level": "INFO"
    },
    "TEMPORARY": {
      "description": "Time-bound suppression (e.g., migration period)",
      "requires_approval": "admin",
      "audit_level": "WARNING",
      "max_duration_days": 90
    }
  },
  "condition_operators": {
    "equals": { "description": "Exact match", "applies_to": ["string", "number", "boolean"] },
    "not_equals": { "description": "Not equal", "applies_to": ["string", "number", "boolean"] },
    "contains": { "description": "String contains", "applies_to": ["string"] },
    "in": { "description": "Value in list", "applies_to": ["string", "number", "array"] },
    "not_in": { "description": "Value not in list", "applies_to": ["string", "number", "array"] },
    "matches": { "description": "Regex pattern match", "applies_to": ["string"] },
    "greater_than": { "description": "Numeric greater than", "applies_to": ["number"] },
    "less_than": { "description": "Numeric less than", "applies_to": ["number"] },
    "before": { "description": "Date before", "applies_to": ["date"] },
    "after": { "description": "Date after", "applies_to": ["date"] },
    "is_null": { "description": "Value is null/empty", "applies_to": ["any"] },
    "is_not_null": { "description": "Value is not null", "applies_to": ["any"] }
  },
  "approval_workflow": {
    "reviewer": {
      "can_approve": ["DOCUMENT"],
      "max_rules": 10
    },
    "manager": {
      "can_approve": ["DOCUMENT", "PROJECT", "FACILITY"],
      "max_rules": 50
    },
    "admin": {
      "can_approve": ["DOCUMENT", "PROJECT", "FACILITY", "GLOBAL", "TEMPORARY"],
      "max_rules": 999
    }
  }
}
