          "main_functions": ["fuzzy_match_column", "normalize_string", "batch_fuzzy_match"]
        },
        {
          "path": "engine/mappers",
          "type": "folder",
          "required": true,
          "description": "Column mapping logic"
        },
        {
          "path": "engine/mappers/__init__.py",
          "type": "init_file",
          "required": true,
          "description": "Mappers module exports"
        },
        {
          "path": "engine/mappers/detection.py",
