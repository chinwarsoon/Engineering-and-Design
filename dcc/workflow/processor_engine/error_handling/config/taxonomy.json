{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dcc-pipeline.internal/schemas/error-taxonomy",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {"type": "string"},
    "description": {"type": "string"},
    "engines": {"type": "object"},
    "modules": {"type": "object"},
    "functions": {"type": "object"},
    "families": {"type": "object"},
    "layers": {"type": "object"}
  },
  "required": ["version", "engines", "modules", "functions", "families", "layers"],
  "version": "1.0",
  "description": "Error Code Taxonomy - E-M-F-U Format (Engine-Module-Function-UniqueID)",
  "engines": {
    "PR": "Processor Engine",
    "MA": "Mapper Engine",
    "SC": "Schema Engine",
    "IN": "Initiation Engine",
    "RE": "Reporting Engine"
  },
  "modules": {
    "EH": "Error Handling",
    "LD": "Loader",
    "VL": "Validator",
    "CP": "Column Processing"
  },
  "functions": {
    "LD": "Load",
    "SV": "Save",
    "VL": "Validate",
    "EX": "Extract"
  },
  "families": {
    "VAL": "Validation Errors",
    "SYS": "System Errors",
    "DAT": "Data Errors",
    "IOE": "I/O Errors"
  },
  "layers": {
    "L1": "Input Layer",
    "L2": "Transformation Layer",
    "L3": "Output Layer"
  }
}
