{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dcc-pipeline.internal/schemas/error-remediation-types",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {"type": "string"},
    "description": {"type": "string"},
    "types": {"type": "object"},
    "selection_rules": {"type": "object"}
  },
  "version": "1.0",
  "description": "Remediation Strategy Types - Defines how errors are automatically or manually resolved",
  "types": {
    "AUTO_FIX": {
      "code": "R001",
      "name": "Auto Fix",
      "description": "Automatically correct the error without user intervention",
      "auto_eligible": true,
      "requires_approval": false,
      "requires_confirmation": false,
      "success_rate_threshold": 0.95,
      "applicable_layers": ["L2", "L3"],
      "examples": [
        "zero_pad_sequence_numbers",
        "trim_whitespace",
        "standardize_date_format",
        "correct_case_formatting"
      ],
      "implementation": {
        "class": "AutoFixStrategy",
        "module": "error_handling.resolution.remediator",
        "method": "apply_auto_fix"
      },
      "audit_level": "INFO",
      "can_rollback": true
    },
...
  }
}
