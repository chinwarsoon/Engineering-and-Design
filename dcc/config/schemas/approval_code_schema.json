{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dcc-pipeline.internal/schemas/approval-code",
  "title": "DCC Approval Code Schema",
  "description": "Standardized mapping of approval status variations to codes with built-in validation rules.",
  "version": "2.0.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "approval"
  ],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version"
    },
    "description": {
      "type": "string"
    },
    "created": {
      "type": "string",
      "format": "date"
    },
    "approval": {
      "type": "array",
      "description": "List of standardized approval codes and their status mappings",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "code",
          "status",
          "aliases"
        ],
        "properties": {
          "code": {
            "type": "string",
            "pattern": "^[A-Z]{3,4}$",
            "description": "Standardized 3-4 letter uppercase code"
          },
          "status": {
            "type": "string",
            "minLength": 1,
            "description": "The primary human-readable status name"
          },
          "aliases": {
            "type": "array",
            "description": "Variant strings found in documents that map to this code",
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "uniqueItems": true
          }
        }
      }
    }
  },
  "approval": [
    {
      "code": "REJ",
      "status": "Rejected",
      "aliases": ["Rejected", "REJ"]
    },
    {
      "code": "NAP",
      "status": "Not Approved",
      "aliases": ["Not Approved - Revise and resubmit", "Not Approved"]
    },
    {
      "code": "AWC",
      "status": "Approved with Comments",
      "aliases": ["Approved with Comments", "Approved as noted"]
    },
    {
      "code": "APP",
      "status": "Approved",
      "aliases": ["Approved", "APP"]
    },
    {
      "code": "INF",
      "status": "For Information",
      "aliases": ["For Information", "INF"]
    },
    {
      "code": "VOID",
      "status": "Void",
      "aliases": ["Void", "(VOID / NOT IN USE)", "(VOID  NOT IN USE)"]
    },
    {
      "code": "PEN",
      "status": "Awaiting S.O.'s response",
      "aliases": ["Pending Review", "Pending", "Awaiting S.O.'s response", "Awaiting S.O. Review"]
    }
  ]
}