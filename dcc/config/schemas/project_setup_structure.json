{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dcc-pipeline.internal/schemas/project-setup-structure",
  "title": "DCC Project Setup Structure Fragment",
  "description": "Project structure fragment for folders and root files. References definitions from project_setup_base.json",
  "version": "2.0.0",
  "type": "object",
  "allOf": [
    {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-base"}
  ],
  "additionalProperties": false,
  "properties": {
    "folders": {
      "type": "array",
      "description": "All required and optional directories for the DCC project",
      "items": {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-base#/definitions/folder_entry"}
    },
    "root_files": {
      "type": "array",
      "description": "Files required at the project root level",
      "items": {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-base#/definitions/root_file_entry"}
    },
    "workflow_files": {
      "type": "array",
      "description": "Required workflow notebooks and Python modules (located in workflow)",
      "items": {
        "allOf": [
          {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-base#/definitions/typed_file_entry"}
        ],
        "type": "object",
        "properties": {
          "type": {
            "enum": ["notebook", "python_module", "documentation"]
          }
        }
      }
    },
    "tool_files": {
      "type": "array",
      "description": "Required utility and setup script files (located in tools)",
      "items": {
        "allOf": [
          {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-base#/definitions/python_module_entry"}
        ],
        "type": "object",
        "properties": {
          "type": {
            "enum": ["python_script", "shell_script", "other"]
          }
        }
      }
    },
    "processor_engine": {
      "type": "array",
      "description": "Document processor engine modules (located in workflow/processor_engine)",
      "items": {
        "allOf": [
          {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-base#/definitions/path_entry"}
        ],
        "type": "object",
        "properties": {
          "type": {
            "enum": ["folder", "python_module", "documentation", "init_file", "test_file"]
          }
        }
      }
    },
    "mapper_engine": {
      "type": "array",
      "description": "Column mapper engine modules (located in workflow/mapper_engine)",
      "items": {
        "allOf": [
          {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-base#/definitions/path_entry"}
        ],
        "type": "object",
        "properties": {
          "type": {
            "enum": ["folder", "python_module", "documentation", "init_file"]
          }
        }
      }
    },
    "initiation_engine": {
      "type": "array",
      "description": "Initiation engine modules (located in workflow/initiation_engine)",
      "items": {
        "allOf": [
          {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-base#/definitions/path_entry"}
        ],
        "type": "object",
        "properties": {
          "type": {
            "enum": ["folder", "python_module", "documentation", "init_file"]
          }
        }
      }
    },
    "reporting_engine": {
      "type": "array",
      "description": "Reporting engine modules (located in workflow/reporting_engine)",
      "items": {
        "allOf": [
          {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-base#/definitions/path_entry"}
        ],
        "type": "object",
        "properties": {
          "type": {
            "enum": ["folder", "python_module", "documentation", "init_file"]
          }
        }
      }
    }
  }
}
