{
  "$schema": "https://eks.engineering/schemas/eks_ontology_setup_schema.json",
  "$id": "https://eks.engineering/configs/eks_ontology_config.json",
  "version": "1.6.0",
  "title": "EKS ISO 15926-Aligned Dynamic Ontology",
  "description": "Dynamic ontology configuration for EKS classes, inheritance, tag type mapping, aliases, and relationships. Expanded with Document hierarchy and lifecycle relationships.",
  "classes": [
    { 
      "name": "ISO15926_Entity", 
      "label": "ISO 15926 Entity" 
    },
    { 
      "name": "FunctionalObject", 
      "label": "Functional Object (Tag)", 
      "subClassOf": "ISO15926_Entity",
      "fragments": ["item_core", "process_conditions"]
    },
    { 
      "name": "PhysicalObject", 
      "label": "Physical Object (Equipment)", 
      "subClassOf": "ISO15926_Entity",
      "fragments": ["manufacturer", "asset_lifecycle"]
    },
    { 
      "name": "Document", 
      "label": "Document", 
      "subClassOf": "ISO15926_Entity" 
    },
    { "name": "InfrastructureObject", "label": "Infrastructure Object", "subClassOf": "ISO15926_Entity" },
    { "name": "GovernanceObject", "label": "Governance Object", "subClassOf": "ISO15926_Entity" },
    
    { "name": "TaggedEquipment", "label": "Tagged Equipment", "subClassOf": "FunctionalObject" },
    { 
      "name": "TaggedRotating", 
      "label": "Tagged Rotating Equipment", 
      "subClassOf": "TaggedEquipment",
      "fragments": ["rotating_equipment"]
    },
    { 
      "name": "TaggedStatic", 
      "label": "Tagged Static Equipment", 
      "subClassOf": "TaggedEquipment"
    },
    
    { 
      "name": "TaggedPiping", 
      "label": "Tagged Piping Component", 
      "subClassOf": "FunctionalObject",
      "fragments": ["piping_connection"]
    },
    { 
      "name": "TaggedInstrument", 
      "label": "Tagged Instrument", 
      "subClassOf": "FunctionalObject",
      "fragments": ["instrumentation"]
    },
    
    { "name": "PumpTag", "label": "Pump Tag", "subClassOf": "TaggedRotating", "tag_type_mapping": "AT_EQPMP", "tag_type_aliases": ["AT_PMP", "AT_PUMP"] },
    { 
      "name": "MotorTag", 
      "label": "Motor Tag", 
      "subClassOf": "TaggedRotating", 
      "tag_type_mapping": "AT_MOTOR", 
      "tag_type_aliases": ["AT_MTR", "AT_MOTOR_UNIT"],
      "fragments": ["motor_control"]
    },
    { "name": "TankTag", "label": "Tank Tag", "subClassOf": "TaggedStatic", "tag_type_mapping": "AT_EQTNK", "tag_type_aliases": ["AT_TANK"] },
    { "name": "VesselTag", "label": "Vessel Tag", "subClassOf": "TaggedStatic", "tag_type_mapping": "AT_EQVES", "tag_type_aliases": ["AT_VESSEL"] },
    { "name": "HeatExchangerTag", "label": "Heat Exchanger Tag", "subClassOf": "TaggedStatic", "tag_type_mapping": "AT_EQEXC", "tag_type_aliases": ["AT_HE_EX", "AT_HEAT_EXCHANGER"] },
    
    { 
      "name": "PipelineTag", 
      "label": "Pipeline Tag", 
      "subClassOf": "TaggedPiping", 
      "tag_type_mapping": "AT_PROCESS",
      "fragments": ["pipeline_route"]
    },
    { "name": "InlineComponentTag", "label": "Inline Component Tag", "subClassOf": "TaggedPiping", "tag_type_mapping": "AT_INCOMP" },
    
    { 
      "name": "ValveTag", 
      "label": "Valve Tag", 
      "subClassOf": "TaggedPiping", 
      "fragments": ["valve_internals"]
    },
    { 
      "name": "ControlValveTag", 
      "label": "Control Valve Tag", 
      "subClassOf": "ValveTag", 
      "tag_type_mapping": "AT_CVALVE",
      "fragments": ["actuator"]
    },
    { "name": "SafetyValveTag", "label": "Safety Valve Tag", "subClassOf": "ValveTag", "tag_type_mapping": "AT_PSV" },
    { "name": "ManualValveTag", "label": "Manual Valve Tag", "subClassOf": "ValveTag", "tag_type_mapping": "AT_HVALVE" },
    
    { "name": "ControlSystemInstrumentTag", "label": "Control System Instrument Tag", "subClassOf": "TaggedInstrument", "tag_type_mapping": "AT_INST_CS" },
    { "name": "FlowInstrumentTag", "label": "Flow Instrument Tag", "subClassOf": "TaggedInstrument", "tag_type_mapping": "AT_INST_FLO" },

    { "name": "PumpUnit", "label": "Pump Unit", "subClassOf": "PhysicalObject" },
    { "name": "ValveUnit", "label": "Valve Unit", "subClassOf": "PhysicalObject" },
    { "name": "MotorUnit", "label": "Motor Unit", "subClassOf": "PhysicalObject" },
    { "name": "InstrumentUnit", "label": "Instrument Unit", "subClassOf": "PhysicalObject" },
    { "name": "EquipmentUnit", "label": "Equipment Unit", "subClassOf": "PhysicalObject" },
    { "name": "ActuatorUnit", "label": "Actuator Unit", "subClassOf": "PhysicalObject" },

    { "name": "ElectricalPanel", "label": "Electrical Panel (MCC)", "subClassOf": "InfrastructureObject" },
    { "name": "ControlPanel", "label": "Control Panel (PLC/RIO)", "subClassOf": "InfrastructureObject" },
    { "name": "EngineeringStandard", "label": "Engineering Standard/Spec", "subClassOf": "GovernanceObject" },
    { "name": "Originator", "label": "Document Originator (Company)", "subClassOf": "GovernanceObject" },

    { "name": "Drawing", "label": "Engineering Drawing", "subClassOf": "Document", "document_type_mapping": "DWG" },
    { "name": "PID_Drawing", "label": "P&ID Drawing", "subClassOf": "Drawing", "document_type_mapping": "PI-PID" },
    { "name": "Specification", "label": "Technical Specification", "subClassOf": "Document", "document_type_mapping": "SPC" },
    { "name": "DataSheet", "label": "Equipment Data Sheet", "subClassOf": "Specification", "document_type_mapping": "DS" },
    { "name": "Manual", "label": "Vendor O&M Manual", "subClassOf": "Document", "document_type_mapping": "MAN" },
    { "name": "OpsManual", "label": "Operation Manual", "subClassOf": "Manual", "document_type_mapping": "OM" },
    { "name": "Report", "label": "Technical Report", "subClassOf": "Document", "document_type_mapping": "RPT" }
  ],
  "relationships": [
    { "name": "SUBCLASS_OF", "inverse": "SUPERCLASS_OF", "transitive": true, "description": "Establishes class hierarchy." },
    { "name": "IS_A", "transitive": false, "description": "Links instance to its ontology class." },
    { "name": "CONNECTS_TO", "symmetric": true, "transitive": false, "description": "Generic physical connectivity between objects (not transitive)." },
    { "name": "FLOWS_TO", "inverse": "FLOWS_FROM", "transitive": true, "symmetric": false, "description": "Directional process flow (transitive)." },
    { "name": "INSTALLED_AT", "inverse": "HAS_PHYSICAL", "transitive": false, "description": "Links equipment instance to its tag." },
    { "name": "REFERENCED_BY_DWG", "inverse": "REFERENCES_ASSET", "symmetric": false, "description": "Document references a functional object." },
    { "name": "CONTROLS", "inverse": "CONTROLLED_BY", "transitive": true, "description": "Hierarchical control signal relationship (transitive)." },
    { "name": "ENERGIZED_BY", "inverse": "POWERS", "transitive": true, "description": "Electrical power distribution link (transitive)." },
    { "name": "GOVERNED_BY", "inverse": "VALIDATES_ASSET", "transitive": true, "description": "Hierarchical governance/standards link (transitive)." },
    { "name": "SET_POINT_IN", "inverse": "SPECIFIES_SET_POINT", "transitive": false, "description": "Links operating parameter to source doc." },
    { "name": "SUPERSEDES", "inverse": "SUPERSEDED_BY", "transitive": true, "description": "Links new revision to its predecessor." },
    { "name": "SUPPLEMENTS", "inverse": "SUPPLEMENTED_BY", "transitive": true, "description": "Links Annexes/Addendums to primary docs." },
    { "name": "REFERENCES_DOC", "inverse": "REFERENCED_BY_DOC", "transitive": true, "description": "Cross-reference found in document text." },
    { "name": "PRODUCED_BY", "inverse": "ORIGINATED", "transitive": false, "description": "Links document to Originating company." },
    { "name": "FEEDS_FROM", "transitive": false, "description": "Legacy material or energy feed relationship." }
  ]
}
