{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://eks.engineering/schemas/eks_setup_schema.json",
    "version": "1.2.2",
    "title": "EKS Setup Schema - Declarations",
    "description": "Global property declarations. v1.2.1: discipline_registry changed to $ref-only. v1.2.2: project_rules_registry changed to $ref-only (inline values moved to eks_project_rules_config.json) per audit — SSOT enforced. Includes project-specific validation rules and metadata support for the config instance.",
    "allOf": [
        { "$ref": "eks_base_schema.json" }
    ],
    "type": "object",
    "properties": {
        "$schema": { "type": "string" },
        "$id": { "type": "string" },
        "version": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "project_rules_registry": {
            "type": "object",
            "description": "Reference to project rules config (SSOT — update eks_project_rules_config.json for new project rules)",
            "properties": {
                "$ref": { "type": "string" }
            },
            "required": ["$ref"]
        },
        "discipline_registry": {
            "type": "object",
            "description": "Reference to discipline fragment schema (SSOT — must update eks_discipline_schema.json for new disciplines)",
            "properties": {
                "$ref": { "type": "string" }
            },
            "required": ["$ref"]
        },
        "project_registry": {
            "type": "object",
            "description": "Reference to project code fragment schema",
            "properties": {
                "$ref": { "type": "string" }
            },
            "required": ["$ref"]
        },
        "department_registry": {
            "type": "object",
            "description": "Reference to department fragment schema",
            "properties": {
                "$ref": { "type": "string" }
            },
            "required": ["$ref"]
        },
        "facility_registry": {
            "type": "object",
            "description": "Reference to facility fragment schema",
            "properties": {
                "$ref": { "type": "string" }
            },
            "required": ["$ref"]
        },
        "global_paths": { "$ref": "https://eks.engineering/schemas/eks_base_schema.json#/definitions/global_paths_def" },
        "registry": { "$ref": "https://eks.engineering/schemas/eks_base_schema.json#/definitions/registry_def" },
        "parsers": { "$ref": "https://eks.engineering/schemas/eks_base_schema.json#/definitions/parsers_def" },
        "embedding": { "$ref": "https://eks.engineering/schemas/eks_base_schema.json#/definitions/embedding_def" },
        "vector_store": { "$ref": "https://eks.engineering/schemas/eks_base_schema.json#/definitions/vector_store_def" },
        "logging": { "$ref": "https://eks.engineering/schemas/eks_base_schema.json#/definitions/logging_def" }
    },
    "required": ["project_rules_registry", "discipline_registry", "project_registry", "department_registry", "facility_registry", "global_paths", "registry", "parsers", "embedding", "vector_store", "logging"],
    "additionalProperties": false
}
