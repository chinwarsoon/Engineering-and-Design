{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dcc-pipeline.internal/schemas/approval_code_schema",
  "title": "DCC Approval Code Schema",
  "description": "Standardized mapping of approval status variations to codes with built-in validation rules.",
  "version": "2.0.0",
  "approval": [
    {
      "code": "REJ",
      "status": "Rejected",
      "aliases": ["Rejected", "REJ"]
    },
    {
      "code": "NAP",
      "status": "Not Approved",
      "aliases": ["Not Approved - Revise and resubmit", "Not Approved"]
    },
    {
      "code": "AWC",
      "status": "Approved with Comments",
      "aliases": ["Approved with Comments", "Approved as noted"]
    },
    {
      "code": "APP",
      "status": "Approved",
      "aliases": ["Approved", "APP"]
    },
    {
      "code": "INF",
      "status": "For Information",
      "aliases": ["For Information", "INF"]
    },
    {
      "code": "VOID",
      "status": "Void",
      "aliases": ["Void", "(VOID / NOT IN USE)", "(VOID  NOT IN USE)"]
    },
    {
      "code": "PEN",
      "status": "Awaiting S.O.'s response",
      "aliases": ["Pending Review", "Pending", "Awaiting S.O.'s response", "Awaiting S.O. Review"]
    }
  ]
}