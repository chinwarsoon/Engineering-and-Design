{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://eks.engineering/schemas/eks_asset_base_schema.json",
    "version": "1.3.0",
    "title": "EKS Asset Base Schema — Fragment Definitions",
    "description": "Reusable property fragments for universal plant item schema. 14 fragments composed per asset type via asset_type_registry. Includes relationship metadata annotations per agent_rule Section 2.",
    "type": "object",
    "definitions": {
        "item_core": {
            "type": "object",
            "description": "Universal identity fields for every plant item. Shape-only — no required constraints at base level. Per-project required overrides defined in eks_project_rules_config.json (fragment_required_fields).",
            "properties": {
                "keytag":               { "type": "string" },
                "tag_type":             { "type": "string" },
                "tag_no":               { "type": "string" },
                "project_prefix":       { "type": "string" },
                "unit":                 { "type": "string" },
                "service":              { "type": "string" },
                "tag_loop_number":      { "type": "string" },
                "tag_suffix":           { "type": "string" },
                "description":          { "type": "string" },
                "short_description":    { "type": "string" },
                "hazardous_zone":       { "type": "string" },
                "contract_info":        { "type": "string" },
                "device_type_code":     { "type": "string" },
                "p_and_id_file":        { "type": ["string", "array"], "items": { "type": "string" }, "description": "Trigger: REFERENCED_BY_DWG" },
                "design_specification": { "type": "string", "description": "Trigger: GOVERNED_BY" }
            },
            "additionalProperties": false
        },
        "process_conditions": {
            "type": "object",
            "description": "Design and operating conditions",
            "properties": {
                "design_pressure":                  { "type": "number" },
                "pressure_rating":                  { "type": "string" },
                "operating_pressure_normal":        { "type": "number" },
                "operating_pressure_min":           { "type": "number" },
                "operating_pressure_max":           { "type": "number" },
                "operating_temperature_normal":     { "type": "number" },
                "flow_rate_nominal":                { "type": "number" },
                "flow_rate_min":                    { "type": "number" },
                "flow_rate_max":                    { "type": "number" },
                "test_pressure":                    { "type": "number" }
            },
            "additionalProperties": false
        },
        "manufacturer": {
            "type": "object",
            "description": "Manufacturer and product details",
            "properties": {
                "brand":                { "type": "string" },
                "model_number":         { "type": "string" },
                "serial_number":        { "type": "string", "description": "Trigger: INSTALLED_AT (PhysicalObject link)" },
                "manufacturer_name":    { "type": "string" },
                "manufacturer_website": { "type": "string" },
                "manufacturer_phone":   { "type": "string" },
                "manufacturer_fax":     { "type": "string" },
                "manufacturer_email":   { "type": "string" },
                "manufacturer_location":{ "type": "string" },
                "lot_number":           { "type": "string" },
                "manufacture_date":     { "type": "string", "format": "date" },
                "model_2d_file":        { "type": "string" },
                "model_3d_file":        { "type": "string" }
            },
            "additionalProperties": false
        },
        "asset_lifecycle": {
            "type": "object",
            "description": "Asset lifecycle, financial, and ACE fields",
            "properties": {
                "ace_category":             { "type": "string" },
                "generic_equipment_type":   { "type": "string" },
                "ace_asset_class":          { "type": "string" },
                "life_span":                { "type": "string" },
                "supplier":                 { "type": "string" },
                "cost_center":              { "type": "string" },
                "replacement_cost":         { "type": "number" },
                "wbs_element":              { "type": "string" },
                "est_replacement_date":     { "type": "string", "format": "date" },
                "date_of_commission":       { "type": "string", "format": "date" },
                "warranty_terms":           { "type": "string" },
                "warranty_start_date":      { "type": "string", "format": "date" },
                "warranty_expiry_date":     { "type": "string", "format": "date" },
                "product_certification":    { "type": "string" },
                "ace_asset_number":         { "type": "string" },
                "ace_asset_sub_number":     { "type": "string" }
            },
            "additionalProperties": false
        },
        "control_system": {
            "type": "object",
            "description": "Control and I&C interface",
            "properties": {
                "lcs_type":             { "type": "string" },
                "plc_panel":            { "type": "string", "description": "Trigger: CONTROLLED_BY" },
                "plc_panel_location":   { "type": "string" },
                "rio_panel":            { "type": "string", "description": "Trigger: CONTROLLED_BY" },
                "rio_panel_location":   { "type": "string" }
            },
            "additionalProperties": false
        },
        "piping_connection": {
            "type": "object",
            "description": "Piping interface for inline components, valves, and instruments",
            "properties": {
                "pipe_size_nominal_mm":     { "type": "number" },
                "pipeline_tag_number":      { "type": "string", "description": "Trigger: CONNECTS_TO" },
                "lining_material":          { "type": "string" },
                "end_condition":            { "type": "string" }
            },
            "additionalProperties": false
        },
        "valve_internals": {
            "type": "object",
            "description": "Valve trim, body, closure element, and locked position",
            "properties": {
                "valve_duty":           { "type": "string" },
                "valve_internal_type":  { "type": "string" },
                "body_material":        { "type": "string" },
                "stem_material":        { "type": "string" },
                "closure_element":      { "type": "string" },
                "seat_material":        { "type": "string" },
                "locked_position":      { "type": "string" }
            },
            "additionalProperties": false
        },
        "actuator": {
            "type": "object",
            "description": "Actuator specs for control valves including full actuator manufacturer and ACE lifecycle block",
            "properties": {
                "actuator_tag_number":              { "type": "string", "description": "Trigger: HAS_ACTUATOR" },
                "actuator_display_label":           { "type": "string" },
                "actuator_internal_type":           { "type": "string" },
                "fail_mode":                        { "type": "string" },
                "actuator_rpm":                     { "type": "number" },
                "actuator_motor_rpm":               { "type": "number" },
                "actuator_torque_range":            { "type": "string" },
                "actuator_locked_rotor_torque":     { "type": "number" },
                "actuator_rated_voltage":           { "type": "number" },
                "actuator_rated_frequency":         { "type": "number" },
                "actuator_rated_current":           { "type": "number" },
                "actuator_rated_torque_current":    { "type": "number" },
                "actuator_motor_rating_kw":         { "type": "number" },
                "actuator_stem_direction":          { "type": "string" },
                "actuator_brand":                   { "type": "string" },
                "actuator_model":                   { "type": "string" },
                "actuator_serial":                  { "type": "string" },
                "actuator_manufacturer_name":       { "type": "string" },
                "actuator_manufacturer_website":    { "type": "string" },
                "actuator_manufacturer_phone":      { "type": "string" },
                "actuator_manufacturer_fax":        { "type": "string" },
                "actuator_manufacturer_email":      { "type": "string" },
                "actuator_manufacturer_location":   { "type": "string" },
                "actuator_model_3d_file":           { "type": "string" },
                "actuator_lot_number":              { "type": "string" },
                "actuator_manufacture_date":        { "type": "string", "format": "date" },
                "actuator_ace_category":            { "type": "string" },
                "actuator_generic_equipment_type":  { "type": "string" },
                "actuator_ace_asset_class":         { "type": "string" },
                "actuator_life_span":               { "type": "string" },
                "actuator_supplier":                { "type": "string" },
                "actuator_cost_center":             { "type": "string" },
                "actuator_replacement_cost":        { "type": "number" },
                "actuator_wbs_element":             { "type": "string" },
                "actuator_est_replacement_date":    { "type": "string", "format": "date" },
                "actuator_date_of_commission":      { "type": "string", "format": "date" },
                "actuator_warranty_terms":          { "type": "string" },
                "actuator_warranty_start_date":     { "type": "string", "format": "date" },
                "actuator_warranty_expiry_date":    { "type": "string", "format": "date" },
                "actuator_product_certification":   { "type": "string" },
                "actuator_ace_asset_number":        { "type": "string" },
                "actuator_ace_asset_sub_number":    { "type": "string" }
            },
            "additionalProperties": false
        },
        "rotating_equipment": {
            "type": "object",
            "description": "Pump, motor, and compressor rotating equipment data",
            "properties": {
                "rpm":                          { "type": "number" },
                "efficiency":                   { "type": "number" },
                "impeller_type":                { "type": "string" },
                "impeller_material":            { "type": "string" },
                "impeller_wear_ring":           { "type": "string" },
                "rotor_material":               { "type": "string" },
                "stator_material":              { "type": "string" },
                "casing_material":              { "type": "string" },
                "gearbox_material":             { "type": "string" },
                "conveyor_hub_material":        { "type": "string" },
                "seal_type":                    { "type": "string" },
                "npsh_min":                     { "type": "number" },
                "submergence_min":              { "type": "number" },
                "head_loss":                    { "type": "number" },
                "suction_nozzle_size":          { "type": "number" },
                "discharge_nozzle_size":        { "type": "number" },
                "design_capacity":              { "type": "number" },
                "design_capacity_unit":         { "type": "string" },
                "duty_standby":                 { "type": "string" },
                "insulation_class":             { "type": "string" },
                "voltage":                      { "type": "number" },
                "frequency":                    { "type": "number" },
                "phase":                        { "type": "string" },
                "motor_rating":                 { "type": "number" },
                "motor_speed_class":            { "type": "string" },
                "motor_rated_current":          { "type": "number" },
                "motor_torque_range":           { "type": "string" },
                "motor_locked_rotor_torque":    { "type": "number" },
                "motor_rated_torque_current":   { "type": "number" }
            },
            "additionalProperties": false
        },
        "instrumentation": {
            "type": "object",
            "description": "Sensor, transmitter, and alarm specifications",
            "properties": {
                "isa_instrument_id":        { "type": "string" },
                "instrument_function":      { "type": "string" },
                "measurement_principle":    { "type": "string" },
                "measurement_sample_point": { "type": "string" },
                "operating_range":          { "type": "string" },
                "sensor_model":             { "type": "string" },
                "sensor_material":          { "type": "string" },
                "sensor_ip_rating":         { "type": "string" },
                "sensor_range":             { "type": "string" },
                "sensor_wetted_parts":      { "type": "string" },
                "thermowell":               { "type": "string" },
                "housing_material":         { "type": "string" },
                "ingress_protection":       { "type": "string" },
                "lightning_arrestor":       { "type": "string" },
                "output_signal":            { "type": "string" },
                "output_signal_2":          { "type": "string" },
                "accuracy":                 { "type": "string" },
                "calibration_range":        { "type": "string" },
                "supply_voltage":           { "type": "string" },
                "alarm_limit_hh":           { "type": "number", "description": "Trigger: SET_POINT_IN" },
                "alarm_limit_h":            { "type": "number", "description": "Trigger: SET_POINT_IN" },
                "alarm_limit_l":            { "type": "number", "description": "Trigger: SET_POINT_IN" },
                "alarm_limit_ll":           { "type": "number", "description": "Trigger: SET_POINT_IN" },
                "set_point":                { "type": "number", "description": "Trigger: SET_POINT_IN" },
                "tube_material":            { "type": "string" },
                "tube_size":                { "type": "string" },
                "ams_category":             { "type": "string" }
            },
            "additionalProperties": false
        },
        "pipeline_route": {
            "type": "object",
            "description": "Piping geometry, routing, and connectivity (AT_PROCESS only)",
            "properties": {
                "pipe_material":            { "type": "string" },
                "outside_diameter_mm":      { "type": "number" },
                "wall_thickness_mm":        { "type": "number" },
                "design_specification":     { "type": "string", "description": "Trigger: GOVERNED_BY" },
                "insulation_material":      { "type": "string" },
                "insulation_thickness":     { "type": "number" },
                "from_component":           { "type": ["string", "null"], "description": "Trigger: FLOW_FROM / CONNECTS_TO" },
                "to_component":             { "type": ["string", "null"], "description": "Trigger: FLOW_TO / CONNECTS_TO" }
            },
            "additionalProperties": false
        },
        "specialist_equipment": {
            "type": "object",
            "description": "Specialty equipment properties for UV treatment, filtration, and conveyor equipment types (AT_EQUIP conditional)",
            "properties": {
                "aperture_size":        { "type": "string" },
                "diaphragm_material":   { "type": "string" },
                "lineshaft_type":       { "type": "string" },
                "uv_lamp_type":         { "type": "string" },
                "removal_dosage":       { "type": "number" },
                "flux":                 { "type": "number" }
            },
            "additionalProperties": false
        },
        "motor_control": {
            "type": "object",
            "description": "Motor electrical control and MCC interface fields (AT_MOTOR only)",
            "properties": {
                "starter_type":     { "type": "string" },
                "mcc_fed_from":     { "type": "string", "description": "Trigger: ENERGIZED_BY" },
                "equipment_number": { "type": "string", "description": "Trigger: CONTROLLED_BY / RELATES_TO" }
            },
            "additionalProperties": false
        },
        "asset_context": {
            "type": "object",
            "description": "Explicit relationship and spatial/system/project context for graph linkage. Replaces inline trigger annotations with structured fields. All fields optional at base; project rules define required per asset type. Location hierarchy is extensible — unit serves as primary anchor with dynamic sub-levels. System hierarchy is extensible for future subsystem levels.",
            "properties": {
                "project_context": {
                    "type": "object",
                    "description": "Project-level identification — used for BELONGS_TO_PROJECT edges and multi-project registry isolation",
                    "properties": {
                        "project_code":         { "type": "string", "description": "Unique project identifier (e.g., WSD11)" },
                        "project_name":         { "type": "string" },
                        "project_phase":        { "type": "string", "enum": ["concept", "FEED", "detail_design", "construction", "commissioning", "operations"] },
                        "project_client":       { "type": "string" },
                        "project_contractor":   { "type": "string" },
                        "project_office":       { "type": "string" },
                        "contract_package":     { "type": "string" }
                    },
                    "additionalProperties": false
                },
                "location_hierarchy": {
                    "type": "object",
                    "description": "Extensible nested physical location hierarchy anchored on unit (expandable key). Current levels: site, area, unit, building, floor, room. Future levels can be added as properties without schema migration. Location is a context to be linked (LOCATED_IN edges) — no specific location keytag is generated.",
                    "properties": {
                        "site":                 { "type": "string", "description": "Site — LOCATED_IN" },
                        "area":                 { "type": "string", "description": "Area/Block — LOCATED_IN" },
                        "unit":                 { "type": "string", "description": "Unit/Plant — PRIMARY ANCHOR, LOCATED_IN" },
                        "building":             { "type": "string", "description": "Building/Structure — LOCATED_IN" },
                        "floor":                { "type": "string", "description": "Floor/Level — LOCATED_IN" },
                        "room":                 { "type": "string", "description": "Room/Compartment — LOCATED_IN" },
                        "coordinates": {
                            "type": "object",
                            "description": "Optional absolute coordinates for GIS integration",
                            "properties": {
                                "x":   { "type": "number" },
                                "y":   { "type": "number" },
                                "z":   { "type": "number" },
                                "crs": { "type": "string", "description": "Coordinate reference system (e.g., EPSG:4326)" }
                            },
                            "additionalProperties": false
                        }
                    },
                    "additionalProperties": true,
                    "description": "Extensible — future location levels (zone, bay, skid, module) added as properties without schema migration"
                },
                "system_hierarchy": {
                    "type": "object",
                    "description": "Extensible functional system decomposition — used for PART_OF_SYSTEM edges. Each level references a System entity by keytag.",
                    "properties": {
                        "system_code":          { "type": "string", "description": "System keytag — PART_OF_SYSTEM" },
                        "system_name":          { "type": "string" },
                        "subsystem_code":       { "type": "string", "description": "Subsystem keytag — PART_OF_SYSTEM" },
                        "subsystem_name":       { "type": "string" },
                        "process_function":     { "type": "string", "description": "Functional role (e.g., 'cooling_water_supply')" },
                        "discipline":           { "type": "string", "enum": ["process", "mechanical", "electrical", "instrument", "civil", "piping", "structural"] },
                        "utility_category":     { "type": "string", "enum": ["process", "utility", "offsite", "safety", "fire_protection", "HVAC", "power", "instrument_air", "nitrogen", "steam", "water"] }
                    },
                    "additionalProperties": true,
                    "description": "Extensible — future subsystem levels added as properties without schema migration"
                },
                "asset_relationships": {
                    "type": "object",
                    "description": "Direct asset-to-asset links — used for typed edges. Values are target asset keytags.",
                    "properties": {
                        "connects_to":          { "type": ["string", "array"], "items": { "type": "string" }, "description": "Direct connection — CONNECTS_TO" },
                        "flows_from":           { "type": ["string", "array"], "items": { "type": "string" }, "description": "Upstream process flow — FLOWS_FROM" },
                        "flows_to":             { "type": ["string", "array"], "items": { "type": "string" }, "description": "Downstream process flow — FLOWS_TO" },
                        "controlled_by":        { "type": ["string", "array"], "items": { "type": "string" }, "description": "Controller (PLC/DCS/panel) — CONTROLLED_BY" },
                        "energized_by":         { "type": ["string", "array"], "items": { "type": "string" }, "description": "Power source (MCC/panel) — ENERGIZED_BY" },
                        "has_actuator":         { "type": ["string", "array"], "items": { "type": "string" }, "description": "Actuator asset — HAS_ACTUATOR" },
                        "instrumented_by":      { "type": ["string", "array"], "items": { "type": "string" }, "description": "Instrument asset — INSTRUMENTED_BY" },
                        "references_dwg":       { "type": ["string", "array"], "items": { "type": "string" }, "description": "P&ID drawing number(s) — REFERENCED_BY_DWG" },
                        "governed_by_spec":     { "type": ["string", "array"], "items": { "type": "string" }, "description": "Design spec document ID(s) — GOVERNED_BY" },
                        "installed_at":         { "type": "string", "description": "Physical location keytag — INSTALLED_AT" },
                        "set_point_in":         { "type": ["string", "array"], "items": { "type": "string" }, "description": "Alarm/setpoint source — SET_POINT_IN" },
                        "redundant_to":         { "type": ["string", "array"], "items": { "type": "string" }, "description": "Redundant counterpart — REDUNDANT_TO" },
                        "spare_for":            { "type": ["string", "array"], "items": { "type": "string" }, "description": "Spare for duty asset — SPARE_FOR" }
                    },
                    "additionalProperties": false
                },
                "document_relationships": {
                    "type": "object",
                    "description": "Asset-to-document links — used for REFERENCES_ASSET, SUPERSEDES, PRODUCED_BY edges",
                    "properties": {
                        "references_documents": { "type": ["string", "array"], "items": { "type": "string" }, "description": "Documents referencing this asset — REFERENCES_ASSET" },
                        "supersedes":           { "type": ["string", "array"], "items": { "type": "string" }, "description": "Documents this asset supersedes — SUPERSEDES" },
                        "produced_by":          { "type": ["string", "array"], "items": { "type": "string" }, "description": "Originator company/document — PRODUCED_BY" },
                        "approved_by":          { "type": ["string", "array"], "items": { "type": "string" }, "description": "Approval document — APPROVED_BY" },
                        "inspected_by":         { "type": ["string", "array"], "items": { "type": "string" }, "description": "Inspection record — INSPECTED_BY" }
                    },
                    "additionalProperties": false
                },
                "lifecycle_context": {
                    "type": "object",
                    "description": "Operational context for lifecycle and criticality edges",
                    "properties": {
                        "commissioning_status": { "type": "string", "enum": ["not_started", "in_progress", "completed", "deferred"] },
                        "operational_status":   { "type": "string", "enum": ["operational", "standby", "maintenance", "decommissioned", "abandoned", "preserved"] },
                        "criticality":          { "type": "string", "enum": ["critical", "high", "medium", "low"] },
                        "safety_class":         { "type": "string", "enum": ["SIL1", "SIL2", "SIL3", "SIL4", "non_safety"] },
                        "redundancy_group":     { "type": "string" },
                        "maintenance_strategy": { "type": "string", "enum": ["run_to_failure", "preventive", "predictive", "condition_based", "RCM"] },
                        "regulatory_tag":       { "type": "boolean" }
                    },
                    "additionalProperties": false
                }
            },
            "additionalProperties": false
        }
    }
}
