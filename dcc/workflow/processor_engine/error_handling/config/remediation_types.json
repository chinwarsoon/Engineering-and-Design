{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dcc-pipeline.internal/schemas/remediation-types",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {"type": "string"},
    "types": {
      "type": "object",
      "additionalProperties": {"type": "string"}
    }
  },
  "required": ["version", "types"],
  "version": "1.0",
  "types": {
    "MANUAL": "User must manually correct data",
    "AUTOMATIC": "System can automatically fix data",
    "IGNORE": "Error can be safely ignored",
    "RETRY": "Task can be retried"
  }
}
