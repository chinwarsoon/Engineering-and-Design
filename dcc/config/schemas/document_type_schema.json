{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://dcc-pipeline.internal/schemas/document-type",
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "schema_name": {"type": "string"},
      "type": {"type": "string"},
      "data_section": {"type": "string"},
      "field_definitions": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "code": {"type": "object"},
          "description": {"type": "object"}
        },
        "required": ["code", "description"]
      },
      "document": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "code": {"type": "string"},
            "description": {"type": "string"}
          },
          "required": ["code", "description"]
        }
      },
      "description": {"type": "string"},
      "created": {"type": "string"},
      "version": {"type": ["string", "number"]}
    },
    "required": ["schema_name", "type", "data_section", "field_definitions", "document"],
    "schema_name": "document_type_choices",
    "type": "standard_choices",
    "data_section": "document",
    "field_definitions": {
        "code": {
            "data_type": "string",
            "required": true,
            "validation": {
                "pattern": "^[A-Z0-9]{2,3}$",
                "min_length": 2,
                "max_length": 3,
                "unique": true
            }
        },
        "description": {
            "data_type": "string",
            "required": true,
            "validation": {
                "min_length": 1,
                "max_length": 120,
                "unique": true
            }
        }
    },
    "document": [
        {
            "code": "AD",
            "description": "Addendum"
        },
...
    ],
    "description": "Standard document type classifications",
    "created": "2026/04/02",
    "version": 2
}
