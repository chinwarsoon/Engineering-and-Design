{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dcc-pipeline.internal/schemas/department",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_name": {"type": "string"},
    "type": {"type": "string"},
    "data_section": {"type": "string"},
    "data_item_type": {"type": "string"},
    "field_definitions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "value": {"type": "object"}
      }
    },
    "choices": {
      "type": "array",
      "items": {"type": "string"}
    },
    "description": {"type": "string"},
    "created": {"type": "string"},
    "version": {"type": ["string", "number"]}
  },
  "schema_name": "department_choices",
  "type": "standard_choices",
  "data_section": "choices",
  "data_item_type": "scalar",
  "field_definitions": {
    "value": {
      "data_type": "string",
      "required": true,
      "validation": {
        "min_length": 1,
        "max_length": 50,
        "unique": true
      }
    }
  },
  "choices": [
    "Project",
    "QAQC", 
    "Contract",
    "Procurement",
    "Process",
    "Piping",
    "CSA",
    "Architechture",
    "Civil",
    "Structural",
    "Building Service",
    "Electrical",
    "ICA",
    "Mechanical",
    "PMT",
    "BIM",
    "NA"
  ],
  "description": "Standard department classifications for document management",
  "created": "2026-03-28",
  "version": "1.0"
}
