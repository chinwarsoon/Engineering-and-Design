{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dcc-pipeline.internal/schemas/project-setup",
  "title": "DCC Project Setup Validation Schema",
  "description": "Schema for validating required folders and files for DCC project distribution and setup. Optimized using fragment pattern per agent_rule.md Section 2.",
  "version": "2.0.0",
  "type": "object",
  "additionalProperties": false,
  "allOf": [
    {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-base"}
  ],
  "definitions": {
    "folder_entry": {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-base#/definitions/folder_entry"},
    "root_file_entry": {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-base#/definitions/root_file_entry"},
    "file_entry": {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-base#/definitions/file_entry"},
    "typed_file_entry": {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-base#/definitions/typed_file_entry"},
    "python_module_entry": {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-base#/definitions/python_module_entry"},
    "path_entry": {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-base#/definitions/path_entry"},
    "pattern_rule": {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-base#/definitions/pattern_rule"},
    "validation_rule": {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-base#/definitions/validation_rule"},
    "environment_entry": {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-environment#/definitions/environment_entry"},
    "validation_rule_entry": {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-validation#/definitions/validation_rule_entry"},
    "dependencies_config": {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-dependencies#/definitions/dependencies_config"}
  },
  "properties": {
    "folders": {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-structure#/properties/folders"},
    "root_files": {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-structure#/properties/root_files"},
    "schema_files": {"$ref": "https://dcc-pipeline.internal/schemas/project#/definitions/schema_files_config"},
    "discovery_rules": {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-discovery#/properties/discovery_rules"},
    "workflow_files": {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-structure#/properties/workflow_files"},
    "tool_files": {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-structure#/properties/tool_files"},
    "processor_engine": {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-structure#/properties/processor_engine"},
    "mapper_engine": {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-structure#/properties/mapper_engine"},
    "schema_validation": {"$ref": "https://dcc-pipeline.internal/schemas/project#/properties/schema_validation"},
    "schema_engine": {"$ref": "https://dcc-pipeline.internal/schemas/project#/properties/schema_engine"},
    "initiation_engine": {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-structure#/properties/initiation_engine"},
    "reporting_engine": {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-structure#/properties/reporting_engine"},
    "environment": {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-environment#/properties/environment"},
    "validation_rules": {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-validation#/properties/validation_rules"},
    "dependencies": {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-dependencies#/properties/dependencies"},
    "registry": {"$ref": "https://dcc-pipeline.internal/schemas/master-registry#/properties/registry"}
  },
  "required": [
    "version",
    "folders",
    "root_files",
    "schema_files",
    "workflow_files"
  ]
}
