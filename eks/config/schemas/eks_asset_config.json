    "asset_type_registry": {
        "AT_EQUIP": {
            "label": "Equipment",
            "fragments": ["item_core", "process_conditions", "manufacturer", "asset_lifecycle", "control_system", "rotating_equipment"],
            "conditional_fragments": [
                { "fragment": "specialist_equipment", "when": "device_type_code", "in": ["UV", "FILT", "CONV", "SCR", "DOSING"] }
            ]
