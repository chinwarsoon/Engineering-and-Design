{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dcc-pipeline.internal/schemas/error-code-anatomy",
  "title": "Error Code Anatomy Schema",
  "description": "JSON Schema for validating LL-M-F-XXXX error code format (Layer-Module-Function-UniqueID)",
  "version": "1.1",
  "definitions": {
    "layer_code": {
      "type": "string",
      "pattern": "^[A-Z0-9]{2}$",
      "description": "2-character layer/phase code (P1, P2, L3, S1, V5, S-E, S-F, S-C, S-R, S-A)"
    },
    "engine_code": {
      "type": "string",
      "enum": ["P", "M", "I", "S", "R", "H", "V", "P1", "P2", "L3", "S1", "V5"],
      "description": "Engine code - single letter or 2-char layer code"
    },
    "module_code": {
      "type": "string",
      "enum": ["C", "V", "A", "D", "S", "F", "L", "G", "E", "P", "I"],
      "description": "Single letter code representing the module within the engine"
    },
    "function_code": {
      "type": "string",
      "enum": ["P", "V", "C", "F", "S"],
      "description": "Single letter code representing the function type (S=System)"
    },
    "unique_id": {
      "type": "string",
      "pattern": "^[0-9]{4}$",
      "description": "4-digit sequential number (0001-9999)"
    },
    "error_code_format": {
      "type": "string",
      "pattern": "^[A-Z0-9]{2}-[A-Z]-[A-Z]-[0-9]{4}$",
      "description": "Complete error code in LL-M-F-XXXX format (Layer-Module-Function-ID)"
    },
    "system_error_code_format": {
      "type": "string",
      "pattern": "^S-[A-Z]-S-[0-9]{4}$",
      "description": "System error code in S-C-S-XXXX format (System-Category-System-ID)"
    }
  },
  "type": "object",
  "required": ["error_code"],
  "properties": {
    "error_code": {
      "allOf": [
        { "$ref": "#/definitions/error_code_format" }
      ]
    },
    "components": {
      "type": "object",
      "required": ["engine", "module", "function", "unique_id"],
      "properties": {
        "engine": {
          "type": "object",
          "required": ["code", "name"],
          "properties": {
            "code": { "$ref": "#/definitions/engine_code" },
            "name": {
              "type": "string",
              "enum": ["Processor", "Mapper", "Initiation", "Schema", "Reporting", "Historical", "Validation"]
            },
            "description": { "type": "string" }
          }
        },
        "module": {
          "type": "object",
          "required": ["code", "name"],
          "properties": {
            "code": { "$ref": "#/definitions/module_code" },
            "name": {
              "type": "string",
              "enum": ["Core", "Validation", "Aggregate", "Date", "Setup", "File", "Loader", "Generator", "Export", "Preflight"]
            },
            "description": { "type": "string" }
          }
        },
        "function": {
          "type": "object",
          "required": ["code", "name"],
          "properties": {
            "code": { "$ref": "#/definitions/function_code" },
            "name": {
              "type": "string",
              "enum": ["Process", "Validate", "Calculate", "Fill"]
            },
            "description": { "type": "string" }
          }
        },
        "unique_id": {
          "type": "object",
          "required": ["number", "padded"],
          "properties": {
            "number": {
              "type": "integer",
              "minimum": 1,
              "maximum": 9999
            },
            "padded": { "$ref": "#/definitions/unique_id" },
            "family_code": {
              "type": "string",
              "pattern": "^[0-9]$",
              "description": "First digit of unique_id indicates error family"
            }
          }
        }
      }
    },
    "layer": {
      "type": "string",
      "enum": ["L0", "L1", "L2", "L2.5", "L3", "L4", "L5"],
      "description": "Validation layer where error is detected"
    },
    "severity": {
      "type": "string",
      "enum": ["CRITICAL", "HIGH", "MEDIUM", "WARNING", "INFO"],
      "description": "Error severity level"
    },
    "taxonomy": {
      "type": "object",
      "required": ["engine", "module", "function", "family"],
      "properties": {
        "engine": { "type": "string" },
        "engine_code": { "$ref": "#/definitions/engine_code" },
        "module": { "type": "string" },
        "module_code": { "$ref": "#/definitions/module_code" },
        "function": { "type": "string" },
        "function_code": { "$ref": "#/definitions/function_code" },
        "family": { "type": "string" },
        "family_code": {
          "type": "string",
          "pattern": "^[0-9]$"
        }
      }
    }
  },
  "examples": [
    {
      "error_code": "P1-A-P-0101",
      "components": {
        "layer": { "code": "P1", "name": "Phase 1", "description": "Input/Anchor processing phase" },
        "module": { "code": "A", "name": "Anchor", "description": "Anchor column validation" },
        "function": { "code": "P", "name": "Process", "description": "Main processing function" },
        "unique_id": { "number": 101, "padded": "0101", "family_code": "0" }
      },
      "layer": "L1",
      "severity": "CRITICAL",
      "taxonomy": {
        "layer": "Phase 1",
        "layer_code": "P1",
        "module": "Anchor",
        "module_code": "A",
        "function": "Process",
        "function_code": "P",
        "family": "Anchor",
        "family_code": "1"
      }
    },
    {
      "error_code": "S-E-S-0101",
      "components": {
        "category": { "code": "E", "name": "Environment", "description": "System environment error" },
        "system": { "code": "S", "name": "System", "description": "System-level error" },
        "unique_id": { "number": 101, "padded": "0101", "family_code": "0" }
      },
      "severity": "FATAL",
      "taxonomy": {
        "category": "Environment",
        "category_code": "E",
        "system": "System",
        "system_code": "S",
        "family": "Environment",
        "family_code": "1"
      }
    }
  ]
}
