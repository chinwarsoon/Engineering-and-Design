<!DOCTYPE html>

<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>TWRP C4B DCC Submission Explorer Pro | Analytics Edition</title>

    <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>



        /* Specific Table Data styling */
        #mainTable {
            font-size: var(--font-size); /* Links table to the global variable */
        }

#mainTable td {
    padding: var(--td-padding);
    white-space: nowrap; /* Keeps data on one line for horizontal scrolling */
    vertical-align: middle;
}

#mainTable th {
    font-size: calc(var(--font-size) + 1px); /* Headers slightly larger for hierarchy */
    font-weight: 700;
    background: var(--bg);
}

#mainTable th:first-child,
#mainTable td:first-child {
    position: sticky;
    left: 0;
    z-index: 40; /* Increased to stay above other headers */
    background: var(--card-bg); /* Prevents transparency while scrolling */
    border-right: 2px solid var(--border);
}

/* Fix for the top-left corner header specifically */
#mainTable th:first-child {
    z-index: 50; /* Highest priority to stay above row data AND other headers */
    background: var(--bg);
}



        :root {

            --primary: #2563eb; --bg: #f8fafc; --card-bg: #ffffff;

            --border: #e2e8f0; --text-main: #1e293b; --accent: #10b981;

            --pivot-bg: rgba(37, 99, 235, 0.08);

            --td-padding: 8px 12px; --font-size: 13px; /* Update the global font-size variable here for general scaling */

        }

        body.dark-mode {

            --bg: #0f172a; --card-bg: #1e293b; --border: #334155;

            --text-main: #f1f5f9; --pivot-bg: rgba(37, 99, 235, 0.15);

        }

        body.compact { --td-padding: 4px 8px; --font-size: 11px; } /* Fine-tune the Compact Mode button behavior */



        body { font-family: system-ui, -apple-system, sans-serif; background: var(--bg); color: var(--text-main); padding: 20px; transition: 0.2s; line-height: 1.5; font-size: var(--font-size); }

        .card { max-width: 1600px; margin: 0 auto; background: var(--card-bg); padding: 2rem; border-radius: 12px; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); }

#debugPanel {
    display: none; /* Hidden by default */
    background: #1a202c;
    color: #4ade80;
    padding: 15px;
    margin-top: 20px;
    border-radius: 8px;
    font-family: 'Courier New', monospace;
    font-size: 12px;
    max-height: 200px;
    overflow-y: auto;
    border: 1px solid #2d3748;
}
.debug-entry {
    margin-bottom: 4px;
    border-left: 2px solid #2d3748;
    padding-left: 8px;
}
.debug-timestamp { color: #718096; margin-right: 8px; }
        
/* The unified style for all dashboard control modules */
.dashboard-module {
    background: var(--pivot-bg) !important;
    border: 1px dashed var(--primary) !important;
    border-radius: 8px;
    padding: 15px;
    margin-top: 20px;
    width: 100%;
    box-sizing: border-box;
}

/* Ensure the outer IDs don't add extra padding/borders */
#step1, #step2, #filterContainerSection, #groupBySection {
    background: none;
    border: none;
    padding: 0;
}

/* Ensure the date input has space for the icon */
.date-picker-custom {
    width: 50%;
    padding-right: 2px; /* Prevent text from hitting the icon */
    font-size: 11px;    /* Slightly smaller font to prevent overflow */
    cursor: pointer;
}

.date-picker-input {
    width: 50%;
    min-height: 38px;
    padding: 8px !important;
    font-family: inherit;
    appearance: auto !important; /* Forces browser default UI */
    -webkit-appearance: date-field !important;
}


/* Ensure the native browser date picker icon is visible and clickable */
/* Ensure the calendar icon is visible and doesn't block clicks */
/*input[type="date"]::-webkit-calendar-picker-indicator {
/*    display: block;
/*    cursor: pointer;
/*    position: absolute;
/*    right: 8px;
/*    height: 100%;
/*    width: 20px;
/*    opacity: 1;
/*}
/* Position the native browser calendar icon correctly */
input[type="date"]::-webkit-calendar-picker-indicator {
    display: block !important;
    position: absolute;
    background-position: right;
    background-size: contain;
    cursor: pointer;
    margin-left: 0;
    padding: 0;
    right: 1px;
    top: 50%;
    transform: translateY(-50%);
    opacity: 1;
    z-index: 10;
}

/* Force the date picker to be interactive */
input[type="date"] {
    width: 48% !important; /* Adjust this percentage to your preference */
    min-width: 100px;      /* Prevents it from becoming too small on mobile */
    appearance: auto !important;
    -webkit-appearance: date-field !important;
    cursor: pointer;
    position: relative;
    height: 35px;
    padding: 5px 35px 5px 5px; /* Added right padding to make room for icon */
    box-sizing: border-box;
    background-color: var(--card-bg);
}


        /* Ensure all filter items have the same vertical alignment */
.filter-item {
    background: var(--card-bg); /* White background for the filter card */
    padding: 10px;
    border-radius: 6px;
    border: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 5px;
}

/* Ensure the grid layout in the container is tight */
#filterArea {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 12px;
    margin-top: 5px;
}
        
        /* Force specific height on all interactive elements */
        .multiselect-display, 
        input[type="date"], 
        input[type="text"] {
            height: 40px; /* Fixed height for uniformity */
            box-sizing: border-box; /* Ensures padding doesn't add to height */
            display: flex;
            align-items: center;
        }
        
        /* Prevent text overflow from pushing the height out */
        .multiselect-display span:first-child {
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 85%;
        }
        
        /* Ensure date inputs in the flex container match the 40px height */
        .filter-item div[style*="display: flex"] {
            height: 40px; 
            justify-content: space-between;
        }

        .filter-item div[style*="display: flex"] input[type="date"] {
            flex: 1;
        }


/* Ensure the table wrapper doesn't clip the filters */
.table-wrapper { 
    overflow: auto; 
    max-height: 600px; 
    border: 1px solid var(--border); 
    border-radius: 8px; 
    position: relative;
    z-index: 10; /* Lower than the filters */
}



        /* Allow columns to be resized smaller than content; truncate overflowing text */
        table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
            background: var(--card-bg);
            table-layout: fixed; /* enables fixed column width for resizing */
        }

        

        th { 

            background: var(--bg);
            padding: var(--td-padding);
            text-align: left; 
            position: sticky; /* Sort Indicator Styling *//* Forces sticky behavior */
            padding-right: 35px !important; /* Make room for the arrow and resizer */
            top: 0; z-index: 20; 
            cursor: pointer; border-bottom: 2px solid var(--border); 
            white-space: nowrap; min-width: 120px;
            user-select: none;
            z-index: 20; /* Maintain sticky header hierarchy */
        }

.sort-icon {
    position: absolute;
    right: 16px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 0.8em;
    opacity: 0.3;
    transition: opacity 0.2s;
}

th:hover .sort-icon {
    opacity: 0.7;
}

.sort-icon.active {
    opacity: 1;
    color: var(--primary);
}


/* Add this to your :root or top of CSS to prevent layout overflow globally */
* {
    box-sizing: border-box;
}

#filterContainerSection {
    display: block; /* Overrides hidden when class is removed */
    clear: both;
    width: 100%;
    min-height: 50px; /* Forces it to have some height */
    margin-bottom: 20px; /* Adjust this value to increase the gap below */

    /* Ensure the filter container can show overflowing dropdowns */
    position: relative;
    z-index: 100; /* Higher than the table headers */
}

#filterArea {
    display: grid !important; /* Forces the grid layout */
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 15px;
}

#loadFilesContainer {
    width: 100%;
    overflow: hidden; /* Prevents children from poking out */
}

#upload {
    width: 100%;
    max-width: 100%; /* Forces it to stay inside the blue box */
    padding: 8px;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 12px;
}

/* Specific fix for the 'Choose File' button inside the input */
#upload::-webkit-file-upload-button {
    background: var(--primary);
    color: white;
    border: none;
    padding: 5px 10px;
    border-radius: 4px;
    cursor: pointer;
}

#headerListContainer.hidden {
    display: none;
}


/* Shared styling for control containers */
#step2 > div, #groupBySection {
    background: var(--pivot-bg) !important; /* Uses your primary theme color */
    border: 1px dashed var(--primary) !important;
    transition: all 0.2s ease-in-out;
}

/* Ensure the inner list stands out against the light blue background */
.filters-container.grid-layout {
    background: var(--card-bg);
    border: 1px solid var(--border);
    padding: 12px;
}


/* Optional: Make the toggle button look distinct */
#toggleStep2Btn {
    border-style: dashed;
    opacity: 0.8;
}
#toggleStep2Btn:hover {
    opacity: 1;
    background: var(--pivot-bg);
}


/* Universal style for both Filter Selection and Grouping */
/* 2. Style the Chip (The Container) */
/* The container chip */
.toggle-chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 20px;
    cursor: pointer;
    font-size: 12px;
    transition: 0.2s;
}

.toggle-chip:hover {
    border-color: var(--primary);
    background: rgba(var(--primary-rgb), 0.05);
}

.toggle-chip.active {
    background: var(--pivot-bg) !important;
    border-color: var(--primary) !important;
    color: var(--primary);
}

/* Hide the native checkbox completely */
.toggle-chip input[type="checkbox"] {
    appearance: none !important;
    -webkit-appearance: none !important;
    display: none !important;
    width: 0 !important;
    height: 0 !important;
    position: absolute !important;
}

/* 3. The "Circle" Icon Style */
/* The single circle indicator */
/* 2. Style the single circle */
.status-icon {
    width: 10px;
    height: 10px;
    border: 1.5px solid currentColor;
    border-radius: 50%;
    display: inline-block;
    flex-shrink: 0;
    background: transparent;
    transition: background 0.2s;
    box-sizing: border-box; /* Prevents border from doubling the size */
}


/* Fill the circle when active */
.toggle-chip.active .status-icon {
    background: currentColor; /* This fills the existing circle */
}

/* 4. Remove any "ghost" circles from old CSS rules */
.toggle-chip::before, .toggle-chip::after {
    content: none !important;
}

#stats {
    background: var(--pivot-bg);
    color: var(--primary);
    padding: 4px 12px;
    border-radius: 20px;
    font-family: monospace; /* Keeps numbers from jumping around */
    font-size: 14px;
    border: 1px solid var(--primary);
}

        /* Frozen First Column */

        th:first-child, td:first-child {

            position: sticky;

            left: 0;

            z-index: 30;

            background: var(--card-bg);

            border-right: 2px solid var(--border);

        }

/*        th:first-child { z-index: 40; background: var(--bg); } */



        /* Column Resizer Handle */

        .resizer {

            position: absolute;

            right: 0;

            top: 0;

            height: 100%;

            width: 6px;

            cursor: col-resize;

            z-index: 50;

        }

        .resizer:hover { background: var(--primary); }

        .resizing { border-right: 2px dashed var(--primary) !important; }



        td {
            padding: var(--td-padding);
            border-bottom: 1px solid var(--border);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            background: var(--card-bg);
        }

        

        /* Filters and UI */

        .header-section { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }

        .controls-row { display: flex; justify-content: space-between; align-items: center; gap: 10px; margin-bottom: 15px; flex-wrap: wrap; }

        .filters-container {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
            gap: 15px;
            background: rgba(0,0,0,0.03);
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 20px;
            max-height: 300px;
            overflow-y: auto;
            border: 1px solid var(--border);
        }

        .multiselect-box {
            position: relative;
            width: 100%;
        }

        .multiselect-display {
            padding: 8px;
            border: 1px solid var(--border);
            border-radius: 6px;
            background: var(--card-bg);
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            min-height: 38px;
        }

        /* Fix for dropdown menus being cut off */
.multiselect-options {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    z-index: 2000; /* Must be higher than sticky table headers (40) */
    max-height: 350px;
    overflow-y: auto;
    box-shadow: 0 10px 20px rgba(0,0,0,0.15);
    padding: 10px;
}

.column-toggle-menu {
    position: absolute;
    right: 280px;
    top: 40px;
    background: var(--card-bg);
    border: 1px solid var(--border);
    padding: 15px;
    border-radius: 8px;
    z-index: 2000;
    box-shadow: 0 10px 20px rgba(0,0,0,0.2);
    min-width: 200px;
}

        .hidden { display: none; }

        .btn { background: var(--primary); color: white; border: none; padding: 8px 16px; border-radius: 6px; cursor: pointer; font-weight: 700; display: inline-flex; align-items: center; gap: 5px; }

        .btn-outline { background: transparent; border: 1px solid var(--border); color: var(--text-main); }

        .btn-accent { background: var(--accent); color: white; }

        select, input[type="text"], input[type="date"] { padding: 6px 10px; border: 1px solid var(--border); border-radius: 6px; background: var(--card-bg); color: var(--text-main); }

    /* This ensures the outer ID doesn't create a "second box" */
    #groupBySection {
        background: none !important;
        border: none !important;
        padding: 0 !important;
        margin-top: 20px;
        margin-bottom: 20px; /* Adjust this value for more or less space */
    }

        #groupCheckboxArea { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 8px; max-height: 120px; overflow-y: auto; margin: 10px 0; }

#groupCheckboxArea .toggle-chip {
    padding: 4px 10px;
    font-size: 11px;
}
        label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; opacity: 0.7; }

    </style>

</head>

<body>



<div class="card">

    <div class="header-section">

        <h2 style="margin:0;">📊 TWRP C4B DCC Submission Explorer Pro</h2>

        <div style="display:flex; gap:10px;">

            <button onclick="toggleTheme()" class="btn btn-outline" id="themeBtn">🌙 Dark Mode</button>

            <button class="btn-outline" onclick="toggleDevMode()" style="color: #ed8936; border-color: #ed8936;">
               Dev Mode: <span id="devStatus">OFF</span>
            </button>

        </div>



    </div>

    <div id="debugPanel">
            <div style="display:flex; justify-content:space-between; margin-bottom:10px; border-bottom:1px solid #2d3748;">
                <span style="font-weight:bold; color: #cbd5e0;">SYSTEM ACTIVITY LOG</span>
                <button onclick="document.getElementById('debugList').innerHTML=''" style="background:none; border:none; color:#fc8181; cursor:pointer; font-size:10px;">[Clear Log]</button>
            </div>
            <div id="debugList"></div>
    </div>    

<div id="step1" style="margin-top:10px; width: 100%;">
    <div style="background: var(--pivot-bg); padding: 15px; border-radius: 8px; border: 1px dashed var(--primary); width: 100%;">
        
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
            <label style="color: var(--primary); font-weight: 700;">📂 1. Load Excel File and Select Work Sheet:</label>
            <button class="btn btn-outline" id="toggleStep1Btn" onclick="toggleStep1Box()" style="padding: 2px 8px; font-size: 10px; border-style: dashed;">
                ▲ Hide
            </button>
        </div>

        <div id="loadFilesContainer">
            <div style="display: flex; flex-direction: column; gap: 10px; width: 100%;">
                <input type="file" id="upload" accept=".xlsx, .xls" />
                <select id="sheetSelector" class="hidden" onchange="loadSheet(this.value)" style="width: 100%;"></select>
            </div>
        </div>
    </div>
</div>



<div id="step2" class="hidden" style="margin-top:20px;">
    <div style="background: rgba(0,0,0,0.03); padding: 15px; border-radius: 8px; border: 1px solid var(--border);">
        
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
            <label style="color: var(--primary); font-weight: 700;">🔍 2. Choose Filterable Columns</label>
            <button class="btn btn-outline" id="toggleStep2Btn" onclick="toggleStep2Box()" style="padding: 2px 8px; font-size: 10px; border-style: dashed;">
                ▲ Hide Selection
            </button>
        </div>

        <div id="headerListContainer">
            <div id="headerList" class="filters-container grid-layout" style="max-height: 200px; background: var(--card-bg);">
                </div>
            <button class="btn" style="width: 100%; margin-top: 10px; justify-content: center;" onclick="buildInterface()">
                Initialize Dashboard
            </button>
        </div>
    </div>
</div>


    <div id="step3" class="hidden">

        <hr style="margin: 20px 0; border: 0; border-top: 1px solid var(--border);">

        

<div id="groupBySection">
    <div class="dashboard-module">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
            <label style="color: var(--primary); font-weight: 700;">📊 3. Grouping & Analytics</label>
            <button class="btn btn-outline" id="toggleGroupBtn" onclick="toggleGroupBox()" style="padding: 2px 8px; font-size: 10px; border-style: dashed;">
                ▲ Hide Controls
            </button>
        </div>

        <div id="groupControlsContainer">
            <div id="groupCheckboxArea" class="filters-container grid-layout" 
                 style="max-height: 150px; background: var(--card-bg); margin-bottom: 15px; padding: 10px; border-radius: 6px; border: 1px solid var(--border);">
            </div>

            <div style="display: flex; align-items: center; gap: 20px; flex-wrap: wrap; border-top: 1px solid rgba(0,0,0,0.1); padding-top: 15px;">
                <div style="display: flex; align-items: center; gap: 8px;">
                    <label style="font-size: 11px; opacity: 0.8;">Aggregator:</label>
                    <select id="aggColumn" onchange="runFilter()" style="height: 35px; min-width: 150px;"></select>
                </div>
                <div style="display: flex; align-items: center; gap: 8px;">
                    <label style="font-size: 11px; opacity: 0.8;">Date Binning:</label>
                    <select id="dateGranularity" onchange="runFilter()" style="height: 35px;">
                        <option value="none">Actual Date</option>
                        <option value="month">Month & Year</option>
                        <option value="quarter">Quarter</option>
                        <option value="year">Year Only</option>
                    </select>
                </div>
            </div>
        </div>
    </div>
</div>



<div id="filterContainerSection" class="hidden" style="margin-top:20px;">
    <div style="background: var(--pivot-bg); padding: 15px; border-radius: 8px; border: 1px dashed var(--primary); width: 100%;">
        
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
            <label style="color: var(--primary); font-weight: 700;">🔍 4. Active Filters</label>
            <button class="btn btn-outline" id="toggleFilterBtn" onclick="toggleFilterBox()" style="padding: 2px 8px; font-size: 10px; border-style: dashed;">
                ▲ Hide Filters
            </button>
        </div>

        <div id="filterControlsWrapper">
            <div id="filterArea" class="filters-container" style="background: transparent; border: none; padding: 0; box-shadow: none;"></div>
        </div>
    </div>
</div>

        <div class="controls-row">

            <div id="stats" style="font-weight: 700;"></div>

            <div style="display: flex; gap: 8px; align-items: center; position: relative;">

   
                <input type="text" id="globalSearch" placeholder="Return to Search..." onkeyup="if(event.key === 'Enter') runFilter()">

                <button class="btn btn-outline" onclick="toggleColumnMenu(event)">👁️ Columns</button>

                <div id="columnToggleMenu" class="hidden column-toggle-menu">

                    <div id="columnChecklist"></div>

                </div>

                <button class="btn btn-accent" onclick="downloadExcel()">📥 Export Excel</button>
                <button onclick="document.body.classList.toggle('compact')" class="btn btn-outline">📏 Compact</button>
                <button class="btn btn-outline" onclick="resetColumnWidths()">↔️ Reset Widths</button>
                <button class="btn btn-outline" onclick="resetFilters()">Reset All</button>
                

            </div>

        </div>





        <div id="chartSection" class="hidden" style="margin-bottom: 20px; padding: 15px; background: var(--card-bg); border: 1px solid var(--border); border-radius: 8px;">

            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">

                <label>📈 Data Trends</label>

                <div style="display: flex; gap: 10px;">

                    <select id="chartType" onchange="runFilter()">

                        <option value="bar">Bar</option><option value="line">Line</option><option value="pie">Pie</option>

                    </select>

                    <button class="btn btn-outline" style="padding: 4px 10px; font-size: 11px;" onclick="downloadChart()">🖼️ Save Chart</button>

                </div>

            </div>

            <div style="height: 300px;"><canvas id="dataChart"></canvas></div>

        </div>



        <div class="table-wrapper">

            <table id="mainTable">

                <thead id="tHead"></thead>

                <tbody id="tBody"></tbody>

            </table>

        </div>

    </div>


</div>



<script>

    let workbook = null, rawData = [], headers = [], selectedFilterCols = [], currentGroupedData = [], filteredDataGlobal = [], hiddenColumns = new Set(), myChart = null;

    // Persist resized column widths across re-renders
    let columnWidths = {};

    // Track whether we've auto-fitted column widths on the current dataset
    let autoFitDone = false;

    let activeSelections = {}, sortConfig = { column: null, direction: 'asc' };

function toggleFilterBox() {
    const wrapper = document.getElementById('filterControlsWrapper');
    const btn = document.getElementById('toggleFilterBtn');
    
    if (wrapper.style.display === "none") {
        wrapper.style.display = "block";
        btn.innerHTML = "▲ Hide Filters";
    } else {
        wrapper.style.display = "none";
        btn.innerHTML = "▼ Show Filters";
    }
}


function toggleStep1Box() {
    const container = document.getElementById('loadFilesContainer');
    const btn = document.getElementById('toggleStep1Btn');
    
    if (container.style.display === "none") {
        container.style.display = "block";
        btn.innerHTML = "▲ Hide";
    } else {
        container.style.display = "none";
        btn.innerHTML = "▼ Show";
    }
}




function toggleGroupBox() {
    const container = document.getElementById('groupControlsContainer');
    const btn = document.getElementById('toggleGroupBtn');
    
    if (container.style.display === "none") {
        container.style.display = "block";
        btn.innerHTML = "▲ Hide Controls";
    } else {
        container.style.display = "none";
        btn.innerHTML = "▼ Show Controls";
    }
}


function toggleStep2Box() {
    const container = document.getElementById('headerListContainer');
    const btn = document.getElementById('toggleStep2Btn');

    
    // Using display: none for a clean "closed" state
    if (container.style.display === "none") {
        container.style.display = "block";
        btn.innerHTML = "▲ Hide Selection";
    } else {
        container.style.display = "none";
        btn.innerHTML = "▼ Show Selection";
    }
}


