    function toggleDropdown(e, col) {
        e.stopPropagation();
        const menu = document.getElementById(`options-${col}`);
        const isOpen = !menu.classList.contains('hidden');
        document.querySelectorAll('.multiselect-options').forEach(m => m.classList.add('hidden'));
        if (!isOpen) menu.classList.remove('hidden');
    }

    function filterDrop(col, term) {
        const listEl = document.getElementById(`list-${col}`);
        const items = listEl.querySelectorAll('.option-item');
        const searchTerm = term.toLowerCase();
        items.forEach(item => item.style.display = item.innerText.toLowerCase().includes(searchTerm) ? "flex" : "none");
    }

    function handleSelect(col, val, checked) {
        if (!activeSelections[col]) activeSelections[col] = new Set();
        checked ? activeSelections[col].add(val) : activeSelections[col].delete(val);
        document.getElementById(`label-${col}`).innerText = activeSelections[col].size > 0 ? `${activeSelections[col].size} Selected` : "All Items";
        runFilter();
    }

    function bulkSelect(col, s, e) {
        e.stopPropagation();
        const items = document.getElementById(`list-${col}`).querySelectorAll('input');
        if (!activeSelections[col]) activeSelections[col] = new Set();
        items.forEach(i => {
            if (i.parentElement.parentElement.style.display !== "none") {
                i.checked = s;
                s ? activeSelections[col].add(i.dataset.val) : activeSelections[col].delete(i.dataset.val);
            }
        });
        document.getElementById(`label-${col}`).innerText = activeSelections[col].size > 0 ? `${activeSelections[col].size} Selected` : "All Items";
        runFilter();
    }




function runFilter() {
    // Reset sorting whenever filters/grouping change so the UI stays consistent.
    sortConfig = { column: null, direction: 'asc' };

    // 1. Get the global search term and normalize it
    const search = document.getElementById('globalSearch').value.toLowerCase();
    
    // 2. Filter the data based on your criteria
    filteredDataGlobal = rawData.filter(row => {

        // Check Global Search first for performance
        const rowString = Object.values(row).join(' ').toLowerCase();
        if (search && !rowString.includes(search)) return false;

        // Check Column-Specific Filters
        return selectedFilterCols.every(col => {
            const minInput = document.getElementById(`date-min-${col}`);
            const maxInput = document.getElementById(`date-max-${col}`);

            // CASE A: Date Range Filtering
            if (minInput && maxInput) {
                // Normalize row value into a JavaScript Date for comparison
                const rawVal = row[col];
                const isEmptyDate = rawVal === null || rawVal === undefined || String(rawVal).trim() === "";
                const cellDate = isEmptyDate ? null : excelSerialToJsDate(rawVal);

                // Select the checkbox
                const showBlanks = document.getElementById(`blank-${col}`)?.checked;

                const hasMin = minInput.value !== "";
                const hasMax = maxInput.value !== "";

                // Skip rows with empty or invalid dates in this specific column
                // if (!cellDate || isNaN(cellDate.getTime())) {
                    // If the cell is empty but the user set a filter, exclude it.
                    // If no filter is set (both inputs empty), include it.
                //    return !minInput.value && !maxInput.value;
                //}

                // 1. Handle Null/Empty Cells
                if (!cellDate || isNaN(cellDate.getTime())) {
                        // If "Blanks" is checked, include this row.
                        if (showBlanks) return true;
                        
                        // If "Blanks" is NOT checked and no date range is set, 
                        // we show everything (standard behavior).
                        // Otherwise, if a range IS set, hide the blank.
                        return !hasMin && !hasMax;
                }
                     

                // 2. Handle Actual Date Values
                // If "Blanks" is checked but NO date range is specified, 
                // we want ONLY blanks, so we hide actual dates.
                if (showBlanks && !hasMin && !hasMax) return false;
                

                // Normalize cell time to midnight to ignore time-of-day differences
                // Convert HTML date strings (YYYY-MM-DD) to comparable timestamps
                const cellTime = new Date(cellDate).setHours(0, 0, 0, 0);
                const minTime = minInput.value ? new Date(minInput.value).setHours(0, 0, 0, 0) : null;
                const maxTime = maxInput.value ? new Date(maxInput.value).setHours(0, 0, 0, 0) : null;

                if (minTime && cellTime < minTime) return false;
                if (maxTime && cellTime > maxTime) return false;
                return true;
            }

            // CASE B: Multiselect Dropdown Filtering
            const strVal = String(formatExcelDate(row[col]));
            const selections = activeSelections[col];
            const rawVal = row[col];
            // Determine what this cell "looks like" to the filter
            const displayVal = (rawVal === null || rawVal === undefined || String(rawVal).trim() === "") 
              ? "(Blanks)" 
              : String(formatExcelDate(rawVal));
            
            // If the set is empty or doesn't exist, all items are "selected"
            if (!selections || selections.size === 0) return true; 

            // Check if the current cell's display value is in the user's "Selected" set
            // return selections.has(strVal);
            return selections.has(displayVal);
        });
    });

    // 2. Update the counter UI (e.g., "15 / 100")
    const statsEl = document.getElementById('stats');
    if (statsEl) {
        statsEl.innerText = `${filteredDataGlobal.length} / ${rawData.length}`;
    }

    // 3. Refresh the table and charts
    updateTable(filteredDataGlobal);

    // 5. Log activity if Dev Mode is active
    if (typeof logDebug === "function") {
        logDebug(`Filter executed: ${filteredDataGlobal.length} results found.`);
    }
}



    function updateTable(data) {

        const tHead = document.getElementById('tHead'), tBody = document.getElementById('tBody');

        const groupByCols = Array.from(document.querySelectorAll('.group-check:checked')).map(cb => cb.value);
        const aggValue = document.getElementById('aggColumn').value, [mode, targetCol] = aggValue.split('|');
        const gran = document.getElementById('dateGranularity').value;

        // Helper to escape HTML and prevent XSS
        const escapeHTML = (str) => {
            if (typeof str !== 'string') return str;
            return str.replace(/[&<>"']/g, m => ({
                '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
            })[m]);
        };

        if (groupByCols.length > 0) {

             const map = {}; let total = 0;

            data.forEach(row => {

                const key = groupByCols.map(c => getGranularDate(row[c], gran)).join(' | ');

                if (!map[key]) map[key] = { ...Object.fromEntries(groupByCols.map(c => [c, getGranularDate(row[c], gran)])), _val: 0, _set: new Set(), _sortKey: parseDateSort(key) };

                let val = mode === 'SUM' ? (Number(row[targetCol]) || 0) : (mode === 'DISTINCT' ? (map[key]._set.add(row[targetCol] ?? 'N/A'), 0) : 1);

                map[key]._val += val; if (mode !== 'DISTINCT') total += val;

            });

            if (mode === 'DISTINCT') { const s = new Set(); data.forEach(r => s.add(r[targetCol])); total = s.size; }

            currentGroupedData = Object.values(map).sort((a, b) => a._sortKey > b._sortKey ? 1 : -1).map(g => {

                const f = mode === 'DISTINCT' ? g._set.size : g._val;

                return { ...Object.fromEntries(groupByCols.map(c => [c, g[c]])), [mode||'Count']: f, '%': total > 0 ? (f / total) * 100 : 0 };

            });


            const k = Object.keys(currentGroupedData[0]);
            tHead.innerHTML = `<tr>${k.map(x => {
               const icon = getSortIcon(x);
               const widthStyle = columnWidths[x] ? `style=\"width:${columnWidths[x]}px;\"` : '';
               return `<th data-col=\"${x}\" ${widthStyle} onclick=\"handleSort('${x}', true)\">${x} ${icon}</th>`;
            }).join('')}</tr>`;

 //           const k = Object.keys(currentGroupedData[0]);

 //           tHead.innerHTML = `<tr>${k.map(x => `<th onclick="handleSort('${x}', true)">${x}</th>`).join('')}</tr>`;

            tBody.innerHTML = currentGroupedData.map(r => `<tr>${k.map(x => x === '%' ? `<td>${r[x].toFixed(1)}%</td>` : `<td>${r[x]}</td>`).join('')}</tr>`).join('');

            updateChart(currentGroupedData);

        } else {

            const vis = headers.filter(h => !hiddenColumns.has(h));
            document.getElementById('chartSection').classList.add('hidden');

            // FIXED: Apply sort icons to Raw Data Headers
            tHead.innerHTML = `<tr>${vis.map(h => {
                const icon = getSortIcon(h);
                const widthStyle = columnWidths[h] ? `style=\"width:${columnWidths[h]}px;\"` : '';
                return `<th data-col=\"${h}\" ${widthStyle} onclick=\"handleSort('${h}', false)\">${h} ${icon}</th>`;
            }).join('')}</tr>`;


            

//            const vis = headers.filter(h => !hiddenColumns.has(h));
//            tHead.innerHTML = `<tr>${vis.map(h => `<th onclick="handleSort('${h}', false)">${h}</th>`).join('')}</tr>`;

            tBody.innerHTML = data.slice(0, 300).map(r => `<tr>${vis.map(h => {
                const cellWidthStyle = columnWidths[h] ? `style=\"width:${columnWidths[h]}px;\"` : '';
                return `<td ${cellWidthStyle}>${formatExcelDate(r[h]) ?? ''}</td>`;
            }).join('')}</tr>`).join('');

        }

        initResizers();

        // Auto-fit columns on first render (then allow users to shrink columns manually)
        if (!autoFitDone) {
            autoFitColumns();
            autoFitDone = true;
        }

    }

function getSortIcon(columnName) {
    if (sortConfig.column !== columnName) {
        return `<span class="sort-icon">↕</span>`; // Neutral state
    }
    return sortConfig.direction === 'asc' 
        ? `<span class="sort-icon active">▲</span>` 
        : `<span class="sort-icon active">▼</span>`;
}

function handleSort(col, isG) {
    // 1. Toggle Direction
    sortConfig.direction = (sortConfig.column === col && sortConfig.direction === 'asc') ? 'desc' : 'asc';
    sortConfig.column = col;
    
    // 2. Determine which data array to sort
    const targetData = isG ? currentGroupedData : filteredDataGlobal;
    
    // 3. Perform the sort
    targetData.sort((a, b) => {
        let valA = a[col] ?? '';
        let valB = b[col] ?? '';

        // Handle numeric sorting
        if (typeof valA === 'number' && typeof valB === 'number') {
            return (valA - valB) * (sortConfig.direction === 'asc' ? 1 : -1);
        }

        // Handle string sorting (case-insensitive)
        valA = String(valA).toLowerCase();
        valB = String(valB).toLowerCase();
        
        if (valA < valB) return sortConfig.direction === 'asc' ? -1 : 1;
        if (valA > valB) return sortConfig.direction === 'asc' ? 1 : -1;
        return 0;
    });

    // 4. Force Table Refresh
    // We pass the global filtered data; if Grouping is active, updateTable handles it
    updateTable(filteredDataGlobal);
}


    function updateTableFromGrouped() {

        const tBody = document.getElementById('tBody'); const k = Object.keys(currentGroupedData[0]);

        tBody.innerHTML = currentGroupedData.map(r => `<tr>${k.map(x => x === '%' ? `<td>${r[x].toFixed(1)}%</td>` : `<td>${r[x]}</td>`).join('')}</tr>`).join('');

        updateChart(currentGroupedData);

        initResizers();

    }



    function updateChart(gData) {

        const ctx = document.getElementById('dataChart').getContext('2d');

        const type = document.getElementById('chartType').value;

        document.getElementById('chartSection').classList.remove('hidden');

        const labels = gData.map(g => Object.values(g).slice(0, -2).join(' | '));

        const vals = gData.map(g => Object.values(g)[Object.values(g).length - 2]);

        if (myChart) myChart.destroy();

        myChart = new Chart(ctx, { type, data: { labels, datasets: [{ label: 'Metric', data: vals, backgroundColor: '#2563eb' }]}, options: { responsive: true, maintainAspectRatio: false }});

    }



    function downloadExcel() {
        // 1. Determine if we are currently in "Grouping" mode
        const groupByCols = Array.from(document.querySelectorAll('.group-check:checked'));
        const isGroupingActive = groupByCols.length > 0;
        
        // 2. Select the correct dataset based on the active UI view
        const dataToExport = isGroupingActive ? currentGroupedData : filteredDataGlobal;
        
        if (!dataToExport || dataToExport.length === 0) {
            alert("No data available to export with current filters.");
            return;
        }
    
        // 3. Create worksheet and download
        const ws = XLSX.utils.json_to_sheet(dataToExport);
        const wb = XLSX.utils.book_new();
        XLSX.utils.book_append_sheet(wb, ws, "Exported_Results");
        
        // Tip: Dynamic filename based on view
        const fileName = isGroupingActive ? "Analytics_Summary.xlsx" : "Filtered_Records.xlsx";
        XLSX.writeFile(wb, fileName);
    }



    function downloadChart() {
        const link = document.createElement('a');
        link.download = 'Chart.png';
        link.href = document.getElementById('dataChart').toDataURL('image/png');
        link.click();
    }

    function parseDateSort(s) {
        const d = new Date(s);
        if (!isNaN(d)) return d.getTime();
        return s;
    }

    function getGranularDate(v, m) {
        const d = excelSerialToJsDate(v);

        if (!d || isNaN(d)) return formatExcelDate(v);

        if (m === 'month') return d.toLocaleString('default', { month: 'short', year: 'numeric' });
        if (m === 'quarter') return `Q${Math.floor(d.getMonth() / 3) + 1} ${d.getFullYear()}`;
        if (m === 'year') return String(d.getFullYear());

        return d.toLocaleDateString();
    }

    function jsDateToExcelStr(s) {
        return s ? jsDateToExcelObj(new Date(s)) : null;
    }

    function jsDateToExcelObj(d) {
        return Math.round((d - new Date(1899, 11, 30)) / (24 * 60 * 60 * 1000));
    }

    function formatExcelDate(v) {
        if (v instanceof Date) return v.toLocaleDateString();
        if (isExcelDate(v)) return XLSX.utils.format_cell({ v, t: 'd' });
        return v;
    }

    function toggleCol(c) {
        hiddenColumns.has(c) ? hiddenColumns.delete(c) : hiddenColumns.add(c);
        runFilter();
    }

    function toggleColumnMenu(e) {
        e.stopPropagation();
        document.getElementById('columnToggleMenu').classList.toggle('hidden');
    }

    function resetFilters() {
        // 1. Clear the global search input
        document.getElementById('globalSearch').value = "";

        // 2. Reset the sorting configuration to default
        sortConfig = { column: null, direction: 'asc' };

        // 3. Re-initialize the interface and data
        buildInterface();
    }

    function resetColumnWidths() {
        // Clear any saved widths and allow the browser to auto-fit again
        columnWidths = {};
        autoFitDone = false;
        runFilter();
    }

    function toggleTheme() {
        document.body.classList.toggle('dark-mode');
        document.getElementById('themeBtn').innerText = document.body.classList.contains('dark-mode') ? "☀️ Light" : "🌙 Dark";
    }

let devModeActive = false;

function toggleDevMode() {
    devModeActive = !devModeActive;
    const panel = document.getElementById('debugPanel');
    const status = document.getElementById('devStatus');
    
    panel.style.display = devModeActive ? 'block' : 'none';
    status.innerText = devModeActive ? 'ON' : 'OFF';
    
    logDebug("Developer Mode " + (devModeActive ? "Enabled" : "Disabled"));
}

function logDebug(message) {
    if (!devModeActive) return;
    
    const list = document.getElementById('debugList');
    const entry = document.createElement('div');
    entry.className = 'debug-entry';
    
    const now = new Date();
    const ts = now.getHours().toString().padStart(2, '0') + ":" + 
               now.getMinutes().toString().padStart(2, '0') + ":" + 
               now.getSeconds().toString().padStart(2, '0');
               
    entry.innerHTML = `<span class="debug-timestamp">[${ts}]</span> ${message}`;
    list.prepend(entry); // Newest on top
}

</script>

</body>

</html>

