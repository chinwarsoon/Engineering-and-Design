{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dcc-pipeline.internal/schemas/project",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_name": {"type": "string"},
    "type": {"type": "string"},
    "data_section": {"type": "string"},
    "field_definitions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "code": {"type": "object"},
        "description": {"type": "object"}
      },
      "required": ["code", "description"]
    },
    "project": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "code": {"type": "string"},
          "description": {"type": "string"}
        },
        "required": ["code", "description"]
      }
    },
    "description": {"type": "string"},
    "created": {"type": "string"},
    "version": {"type": ["string", "number"]}
  },
  "required": ["schema_name", "type", "data_section", "field_definitions", "project"],
  "schema_name": "project_choices",
  "type": "standard_choices",
  "data_section": "project",
  "field_definitions": {
    "code": {
      "data_type": "string",
      "required": true,
      "validation": {
        "pattern": "^\\d{6}$",
        "min_length": 6,
        "max_length": 6,
        "unique": true
      }
    },
    "description": {
      "data_type": "string",
      "required": true,
      "validation": {
        "min_length": 1,
        "max_length": 100,
        "unique": true
      }
    }
  },
  "project": [
    {
      "code": "131242",
      "description": "TWRP"
    }
  ],
  "description": "Standard project codes",
  "created": "2026/04/02",
  "version": 1
}
