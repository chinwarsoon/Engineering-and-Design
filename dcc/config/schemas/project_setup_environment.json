{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dcc-pipeline.internal/schemas/project-setup-environment",
  "title": "DCC Project Setup Environment Fragment",
  "description": "Environment specification fragment for project setup",
  "version": "2.0.0",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "environment_entry": {
      "type": "object",
      "additionalProperties": false,
      "description": "Environment specification (conda, pip, etc.)",
      "properties": {
        "name": {
          "type": "string",
          "description": "Environment name (e.g., conda, venv)"
        },
        "required": {
          "type": "boolean",
          "description": "Whether this environment is mandatory"
        },
        "file": {
          "type": "string",
          "description": "Environment specification file (e.g., dcc.yml, requirements.txt)"
        },
        "location": {
          "type": "string",
          "enum": ["root", "config", "tools"],
          "description": "Where the environment file is located"
        },
        "setup_commands": {
          "type": "array",
          "description": "Commands to set up the environment",
          "items": {"type": "string"}
        },
        "key_dependencies": {
          "type": "array",
          "description": "Primary dependencies for this project",
          "items": {"type": "string"}
        }
      },
      "required": ["name", "required", "file", "location"]
    }
  },
  "properties": {
    "environment": {
      "type": "array",
      "description": "Environment specifications for the project",
      "items": {"$ref": "#/definitions/environment_entry"}
    }
  }
}
