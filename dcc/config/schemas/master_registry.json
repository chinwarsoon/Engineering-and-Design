{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dcc-pipeline.internal/schemas/master-registry",
  "type": "object",
  "title": "DCC Master Registry",
  "description": "Master registry containing project configuration, document types, tools, workflows, and environment settings. Provides default configuration for project_setup.json.",
  "additionalProperties": false,
  "properties": {
    "registry": {
      "description": "Master registry reference containing project configuration, document types, tools, and workflows",
      "$ref": "#"
    },
    "version": {
      "type": "string",
      "description": "Registry version",
      "default": "1.0.0"
    },
    "document_types": {
      "type": "object",
      "description": "Document type definitions and their associated schemas",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "schema_file": {"type": "string"},
          "description": {"type": "string"}
        },
        "required": ["schema_file"]
      }
    },
    "tools": {
      "type": "object",
      "description": "Available tools and their functions",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "tool_file": {"type": "string"},
          "description": {"type": "string"},
          "functions": {"type": "array", "items": {"type": "string"}}
        },
        "required": ["tool_file"]
      }
    },
    "workflows": {
      "type": "object",
      "description": "Workflow definitions and documentation",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "notebook": {"type": "string"},
          "workflow_file": {"type": "string"},
          "workflow_files": {"type": "array", "items": {"type": "string"}},
          "description": {"type": "string"},
          "steps": {"type": "array", "items": {"type": "string"}},
          "tool_file": {"type": "string"},
          "functions": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "documentation": {
      "type": "object",
      "description": "Documentation references",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "file": {"type": "string"},
          "description": {"type": "string"}
        },
        "required": ["file"]
      }
    },
    "project_structure": {
      "type": "object",
      "description": "Project folder and file structure requirements",
      "properties": {
        "required_folders": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {"type": "string"},
              "purpose": {"type": "string"},
              "required": {"type": "boolean"}
            },
            "required": ["name", "purpose", "required"]
          }
        },
        "required_files": {"type": "object"},
        "optional_patterns": {"type": "object"}
      }
    },
    "environment": {
      "type": "object",
      "description": "Environment and dependency configuration",
      "properties": {
        "conda_environment_file": {
          "type": "object",
          "properties": {
            "file": {"type": "string"},
            "path": {"type": "string"},
            "description": {"type": "string"},
            "required": {"type": "boolean"},
            "setup_command": {"type": "string"},
            "activate_command": {"type": "string"},
            "key_dependencies": {"type": "array", "items": {"type": "string"}}
          }
        }
      }
    }
  },
  "required": ["document_types", "tools", "workflows", "project_structure", "environment"],
  "default": {
    "version": "1.0.0",
    "document_types": {
        "DCC_SUBMITTAL": {
            "schema_file": "config/dcc_register.json",
            "description": "DCC Submittal Register"
        },
        "DCC_SUBMITTAL_ENHANCED": {
            "schema_file": "config/schemas/dcc_register_enhanced.json",
            "description": "Enhanced DCC Register with Universal Processing"
        },
        "RFI_TRACKER": {
            "schema_file": "config/rfi_register.json",
            "description": "Request for Information Logs"
        }
    },
    "tools": {
        "PROJECT_SETUP": {
            "tool_file": "tools/project_setup_tools.py",
            "description": "Comprehensive project setup and analysis tools",
            "functions": [
                "analyze_columns",
                "compare_column_handling", 
                "validate_document_id_logic",
                "update_column_sequence",
                "reorganize_schema_columns",
                "run_complete_analysis"
            ]
        },
        "UNIVERSAL_COLUMN_MAPPER": {
            "tool_file": "workflow/universal_column_mapper.py",
            "description": "Universal column mapper with fuzzy matching and schema integration",
            "functions": [
                "load_main_schema",
                "detect_columns",
                "rename_dataframe_columns",
                "get_column_bounds"
            ]
        },
        "UNIVERSAL_DOCUMENT_PROCESSOR": {
            "tool_file": "workflow/universal_document_processor.py",
            "description": "Universal document processor with schema-driven calculations and null handling",
            "functions": [
                "load_schema",
                "process_data",
                "apply_null_handling",
                "apply_calculations",
                "validate_data"
            ]
        }
    },
    "workflows": {
        "UNIVERSAL_PROCESSING": {
            "notebook": "workflow/dcc_register_main.ipynb",
            "description": "Complete universal document processing workflow",
            "steps": [
                "Load enhanced schema",
                "Universal column mapping",
                "Document processing",
                "Data export"
            ]
        },
        "UNIVERSAL_COLUMN_MAPPING": {
            "workflow_file": "workflow/explaination/universal-column-mapping-workflow.md",
            "description": "Universal column mapping workflow with fuzzy matching and schema integration",
            "tool_file": "workflow/universal_column_mapper.py",
            "functions": [
                "load_main_schema",
                "detect_columns",
                "rename_dataframe_columns",
                "get_column_bounds"
            ]
        },
        "UNIVERSAL_DOCUMENT_PROCESSING_WORKFLOW": {
            "workflow_file": "workflow/explaination/universal-document-processing-workflow.md",
            "description": "Universal document processing workflow with schema-driven calculations and null handling",
            "tool_file": "workflow/universal_document_processor.py",
            "functions": [
                "load_schema",
                "process_data",
                "apply_null_handling",
                "apply_calculations",
                "validate_data"
            ]
        },
        "DCC_MAIN": {
            "notebook": "workflow/dcc_mdl.ipynb",
            "description": "Main DCC processing workflow with column updates"
        },
        "DCC_COPY": {
            "notebook": "workflow/dcc_mdl_copy.ipynb",
            "description": "Backup copy of DCC processing workflow"
        },
        "PDF_TRANSMITTAL": {
            "notebook": "workflow/pdf_transmittal_extraction.ipynb",
            "description": "PDF transmittal extraction workflow"
        },
        "COMMON_JSON_TOOLS": {
            "notebook": "workflow/common_json_tools.ipynb",
            "description": "Common JSON processing tools and utilities"
        },
        "EXCEL_EXPLORER": {
            "notebook": "workflow/excel-explorer-workflow.md",
            "description": "Excel data exploration and analysis workflow"
        },
        "STAGE_BASED_PROCESSING": {
            "workflow_files": [
                "workflow/stage-map.md",
                "workflow/stage1-file-upload.md",
                "workflow/stage2-sheet-selection.md",
                "workflow/stage3-range-configuration.md",
                "workflow/stage4-data-loading.md",
                "workflow/stage5-column-selection.md",
                "workflow/stage6-filter-configuration.md",
                "workflow/stage7-data-processing.md",
                "workflow/stage8-data-visualization.md",
                "workflow/stage9-export.md"
            ],
            "description": "Complete stage-based processing workflow from file upload to export"
        },
        "COLUMN_UPDATE_LOGIC": {
            "workflow_file": "workflow/column_update_logic.md",
            "description": "Column update logic documentation with mermaid flowchart"
        },
        "SCHEMA_PROCESSING_RULES": {
            "workflow_file": "workflow/schema-processing-rules.md",
            "description": "Comprehensive schema and processing rules documentation"
        }
    },
    "documentation": {
        "PROJECT_PLAN": {
            "file": "reference/dcc/project-plan.md",
            "description": "Comprehensive project plan and status tracking"
        },
        "WORKFLOW_DIAGRAM": {
            "file": "workflow/universal-processing-workflow.md",
            "description": "Complete workflow documentation with Mermaid diagrams"
        }
    },
    "project_structure": {
        "required_folders": [
            {"name": "config/schemas", "purpose": "Schema definitions", "required": true},
            {"name": "data", "purpose": "Input data files", "required": true},
            {"name": "output", "purpose": "Generated output", "required": false},
            {"name": "reference", "purpose": "Documentation and instructions", "required": false},
            {"name": "workflow", "purpose": "Processing notebooks and modules", "required": true},
            {"name": "tools", "purpose": "Setup and utility scripts", "required": true}
        ],
        "required_files": {
            "schemas": [
                {"file": "dcc_register_enhanced.json", "description": "Main schema definition", "required": true},
                {"file": "department_schema.json", "description": "Department validation", "required": true},
                {"file": "discipline_schema.json", "description": "Discipline validation", "required": true},
                {"file": "document_type_schema.json", "description": "Document type validation", "required": true},
                {"file": "approval_code_schema.json", "description": "Status code mapping", "required": true}
            ],
            "workflow": [
                {"file": "universal_document_processor.py", "description": "Schema-driven processing engine", "required": false},
                {"file": "universal_column_mapper.py", "description": "Column name mapping utility", "required": false},
                {"file": "dcc_register_main.ipynb", "description": "Main orchestration notebook", "required": false}
            ]
        },
        "optional_patterns": {
            "data": "*.xlsx",
            "reference": "*.md"
        }
    },
    "environment": {
        "conda_environment_file": {
            "file": "dcc.yml",
            "path": "../dcc.yml",
            "description": "Conda environment specification with all required Python packages",
            "required": true,
            "setup_command": "conda env create -f dcc.yml",
            "activate_command": "conda activate dcc",
            "key_dependencies": [
                "python=3.13",
                "pandas",
                "numpy",
                "matplotlib",
                "seaborn",
                "jupyter",
                "ipykernel",
                "duckdb",
                "openpyxl"
            ]
        }
    }
  }
}
