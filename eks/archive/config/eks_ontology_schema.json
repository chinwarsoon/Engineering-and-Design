{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://eks.engineering/schemas/eks_ontology_schema.json",
  "version": "1.0.0",
  "title": "EKS Ontology Schema",
  "description": "JSON Schema for dynamic EKS ontology configuration. Defines classes, inheritance, tag type mapping, aliases, and relationships.",
  "type": "object",
  "definitions": {
    "ontology_class": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "subClassOf": { "type": "string" },
        "tag_type_mapping": { "type": "string" },
        "tag_type_aliases": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "fragments": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of asset schema fragments that apply to this class."
        }
      },
      "required": ["name", "label"],
      "additionalProperties": false
    },
    "relationship": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "inverse": { "type": "string" },
        "transitive": { "type": "boolean" },
        "symmetric": { "type": "boolean" },
        "description": { "type": "string" }
      },
      "required": ["name"],
      "additionalProperties": false
    }
  },
  "properties": {
    "$schema": { "type": "string" },
    "$id": { "type": "string" },
    "version": { "type": "string" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "classes": {
      "type": "array",
      "items": { "$ref": "#/definitions/ontology_class" },
      "minItems": 1
    },
    "relationships": {
      "type": "array",
      "items": { "$ref": "#/definitions/relationship" },
      "minItems": 1
    }
  },
  "required": ["classes", "relationships"],
  "additionalProperties": false
}
