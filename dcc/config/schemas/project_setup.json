            "get_calculation_handler",
            "register_calculation_handler"
          ]
        },
        {
          "path": "./calculations",
          "type": "folder",
          "required": true,
          "description": "Calculation implementations"
        },
        {
          "path": "./calculations/__init__.py",
          "type": "init_file",
          "required": true,
          "description": "Calculations module exports"
        },
        {
          "path": "./calculations/aggregate.py",
          "type": "python_module",
          "required": true,
          "description": "Grouping/aggregation calculations",
          "main_functions": [
            "apply_aggregate_calculation",
            "apply_latest_by_date_calculation",
            "apply_latest_non_pending_status"
          ]
        },
        {
          "path": "./calculations/composite.py",
          "type": "python_module",
          "required": true,
          "description": "Composite, row index, delay calculations",
          "main_functions": [
            "apply_composite_calculation",
            "apply_row_index",
            "apply_delay_of_resubmission",
