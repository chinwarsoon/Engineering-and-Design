{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dcc-pipeline.internal/schemas/project-setup-base",
  "title": "DCC Project Setup Base Schema",
  "description": "Base schema with reusable definitions for project setup validation",
  "version": "3.0.0",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "file_entry": {
      "type": "object",
      "additionalProperties": false,
      "description": "Generic file entry with common metadata",
      "properties": {
        "filename": {
          "type": "string",
          "description": "Filename or relative path"
        },
        "required": {
          "type": "boolean",
          "description": "Whether this file is mandatory"
        },
        "description": {
          "type": "string",
          "description": "Purpose of this file"
        },
        "approximate_size": {
          "type": "string",
          "description": "Expected approximate file size"
        }
      },
      "required": ["filename", "required", "description"]
    },
    "typed_file_entry": {
      "allOf": [
        {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-base#/definitions/file_entry"}
      ],
      "type": "object",
      "additionalProperties": false,
      "description": "Typed file entry with file type specification",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["json", "yml", "yaml", "md", "txt", "py", "other"],
          "description": "File type extension"
        }
      },
      "required": ["filename", "required", "type", "description"]
    },
    "python_module_entry": {
      "allOf": [
        {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-base#/definitions/typed_file_entry"}
      ],
      "type": "object",
      "additionalProperties": false,
      "description": "Python module file entry",
      "properties": {
        "type": {
          "type": "string",
          "description": "Type of Python module"
        }
      },
      "required": ["filename", "required", "type", "description"]
    },
    "path_entry": {
      "type": "object",
      "additionalProperties": false,
      "description": "File system path entry",
      "properties": {
        "path": {
          "type": "string",
          "description": "Relative path from project root"
        },
        "type": {
          "type": "string",
          "description": "Type of path entry"
        },
        "description": {
          "type": "string",
          "description": "Purpose of this path"
        }
      },
      "required": ["path", "type", "description"]
    },
    "folder_entry": {
      "type": "object",
      "additionalProperties": false,
      "description": "Folder/directory entry",
      "properties": {
        "name": {
          "type": "string",
          "description": "Relative path of the folder from project root"
        },
        "required": {
          "type": "boolean",
          "description": "Whether this folder is mandatory"
        },
        "purpose": {
          "type": "string",
          "description": "Description of the folder's purpose"
        },
        "auto_created": {
          "type": "boolean",
          "description": "Whether this folder is auto-created on first run",
          "default": false
        }
      },
      "required": ["name", "required", "purpose"]
    },
    "root_file_entry": {
      "type": "object",
      "additionalProperties": false,
      "description": "File at project root level",
      "properties": {
        "name": {
          "type": "string",
          "description": "Filename at root level"
        },
        "required": {
          "type": "boolean",
          "description": "Whether this file is mandatory"
        },
        "purpose": {
          "type": "string",
          "description": "Description of the file's purpose"
        },
        "extension": {
          "type": "string",
          "enum": ["yml", "yaml", "md", "txt", "py", "json", "other"],
          "description": "File type extension"
        }
      },
      "required": ["name", "required", "purpose"]
    },
    "pattern_rule": {
      "type": "object",
      "additionalProperties": false,
      "description": "Pattern-based discovery rule",
      "properties": {
        "pattern": {
          "type": "string",
          "description": "File pattern to match"
        },
        "directory": {
          "type": "string",
          "description": "Directory to search in"
        },
        "recursive": {
          "type": "boolean",
          "description": "Whether to search recursively",
          "default": false
        },
        "auto_register": {
          "type": "boolean",
          "description": "Whether to auto-register discovered files",
          "default": false
        },
        "category": {
          "type": "string",
          "description": "Category of discovered files"
        },
        "exclude_patterns": {
          "type": "array",
          "description": "Patterns to exclude",
          "items": {"type": "string"}
        }
      },
      "required": ["pattern", "directory", "category"]
    },
    "validation_rule": {
      "type": "object",
      "additionalProperties": false,
      "description": "Validation rule configuration",
      "properties": {
        "rule": {
          "type": "string",
          "description": "Validation rule identifier"
        },
        "enabled": {
          "type": "boolean",
          "description": "Whether this rule is active",
          "default": true
        },
        "description": {
          "type": "string",
          "description": "Purpose of this validation rule"
        },
        "severity": {
          "type": "string",
          "enum": ["error", "warning", "info"],
          "default": "error",
          "description": "Validation failure severity level"
        },
        "parameters": {
          "type": "object",
          "description": "Rule-specific configuration parameters"
        }
      },
      "required": ["rule", "description"]
    },
    "validation_rule_entry": {
      "type": "object",
      "additionalProperties": false,
      "description": "Individual validation rule configuration",
      "properties": {
        "rule": {
          "type": "string",
          "description": "Validation rule identifier"
        },
        "enabled": {
          "type": "boolean",
          "description": "Whether this rule is active",
          "default": true
        },
        "description": {
          "type": "string",
          "description": "Purpose of this validation rule"
        },
        "severity": {
          "type": "string",
          "enum": ["error", "warning", "info"],
          "default": "error",
          "description": "Validation failure severity level"
        },
        "parameters": {
          "type": "object",
          "description": "Rule-specific configuration parameters"
        }
      },
      "required": ["rule", "description"]
    },
    "dependency_entry": {
      "type": "object",
      "additionalProperties": false,
      "description": "Python module dependency",
      "properties": {
        "module": {
          "type": "string",
          "description": "Python module name"
        },
        "members": {
          "type": "array",
          "description": "Required classes/functions from this module",
          "items": {"type": "string"}
        },
        "optional": {
          "type": "boolean",
          "description": "Whether this dependency is optional",
          "default": false
        }
      },
      "required": ["module"]
    },
    "engine_dependency": {
      "type": "object",
      "additionalProperties": false,
      "description": "Engine module dependency with required members",
      "properties": {
        "module": {
          "type": "string",
          "description": "Python module name"
        },
        "members": {
          "type": "array",
          "description": "Required classes/functions from this module",
          "items": {"type": "string"}
        },
        "optional": {
          "type": "boolean",
          "description": "Whether this dependency is optional",
          "default": false
        }
      },
      "required": ["module"]
    },
    "dependencies_config": {
      "type": "object",
      "additionalProperties": false,
      "description": "Complete dependencies configuration",
      "properties": {
        "required": {
          "type": "array",
          "description": "Required Python packages",
          "items": {"type": "string"}
        },
        "optional": {
          "type": "array",
          "description": "Optional Python packages",
          "items": {"type": "string"}
        },
        "engines": {
          "type": "array",
          "description": "Engine modules with their exports",
          "items": {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-base#/definitions/engine_dependency"}
        }
      },
      "required": ["required"]
    },
    "environment_entry": {
      "type": "object",
      "additionalProperties": false,
      "description": "Environment specification (conda, pip, etc.)",
      "properties": {
        "name": {
          "type": "string",
          "description": "Environment name (e.g., conda, venv)"
        },
        "required": {
          "type": "boolean",
          "description": "Whether this environment is mandatory"
        },
        "file": {
          "type": "string",
          "description": "Environment specification file (e.g., dcc.yml, requirements.txt)"
        },
        "location": {
          "type": "string",
          "enum": ["root", "config", "tools"],
          "description": "Where the environment file is located"
        },
        "setup_commands": {
          "type": "array",
          "description": "Commands to set up the environment",
          "items": {"type": "string"}
        },
        "key_dependencies": {
          "type": "array",
          "description": "Primary dependencies for this project",
          "items": {"type": "string"}
        }
      },
      "required": ["name", "required"]
    },
    "engine_entry": {
      "type": "object",
      "additionalProperties": false,
      "description": "Processing engine module configuration",
      "properties": {
        "name": {
          "type": "string",
          "description": "Engine name"
        },
        "path": {
          "type": "string",
          "description": "Relative path to engine module"
        },
        "type": {
          "type": "string",
          "enum": ["folder", "python_module", "documentation", "init_file", "test_file"],
          "description": "Type of engine component"
        },
        "required": {
          "type": "boolean",
          "description": "Whether this engine component is mandatory"
        },
        "description": {
          "type": "string",
          "description": "Purpose of this engine component"
        }
      },
      "required": ["name", "path", "type", "required", "description"]
    },
    "project_metadata": {
      "type": "object",
      "additionalProperties": false,
      "description": "Project metadata and identification",
      "properties": {
        "project_id": {
          "type": "string",
          "description": "Unique project identifier"
        },
        "project_name": {
          "type": "string",
          "description": "Human-readable project name"
        },
        "version": {
          "type": "string",
          "description": "Project version"
        },
        "created_date": {
          "type": "string",
          "format": "date",
          "description": "Project creation date"
        },
        "last_modified": {
          "type": "string",
          "format": "date",
          "description": "Last modification date"
        }
      },
      "required": ["project_id", "project_name", "version"]
    },
    "schema_registry": {
      "type": "object",
      "additionalProperties": false,
      "description": "Schema file registry configuration",
      "properties": {
        "schema_files": {
          "type": "array",
          "description": "List of schema files",
          "items": {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-base#/definitions/file_entry"}
        },
        "discovery_enabled": {
          "type": "boolean",
          "description": "Whether auto-discovery is enabled",
          "default": true
        },
        "strict_validation": {
          "type": "boolean",
          "description": "Whether to enforce strict validation",
          "default": true
        }
      },
      "required": ["schema_files"]
    },
    "department_entry": {
      "type": "object",
      "additionalProperties": false,
      "description": "Department classification with code and description",
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[A-Z]{2,4}$",
          "minLength": 2,
          "maxLength": 4,
          "description": "Standardized 2-4 character department code"
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "description": "Full name of the department"
        }
      },
      "required": ["code", "description"]
    },
    "discipline_entry": {
      "type": "object",
      "additionalProperties": false,
      "description": "Engineering discipline classification with code and description",
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[A-Z0-9]{1,3}$",
          "minLength": 1,
          "maxLength": 3,
          "description": "Standardized 1-3 character alphanumeric discipline code"
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "description": "Full name of the engineering discipline"
        }
      },
      "required": ["code", "description"]
    },
    "facility_entry": {
      "type": "object",
      "additionalProperties": false,
      "description": "Facility classification with code and details",
      "properties": {
        "prefix": {
          "type": ["string", "null"],
          "pattern": "^[A-Z]{3}\\d{2}$",
          "minLength": 5,
          "maxLength": 5,
          "description": "Standardized 5-character facility prefix"
        },
        "building_description": {
          "type": ["string", "null"],
          "description": "Building description"
        },
        "project_prefix_sort_order": {
          "type": "integer",
          "description": "Sort order for project prefix"
        },
        "plant_area_name": {
          "type": ["string", "null"],
          "description": "Plant area name"
        },
        "plant_area_order": {
          "type": "integer",
          "description": "Plant area sort order"
        },
        "work_area": {
          "type": ["string", "null"],
          "description": "Work area designation"
        },
        "used_for_pid": {
          "type": "boolean",
          "description": "Whether used for P&ID"
        },
        "sort_number": {
          "type": "integer",
          "description": "Sort number"
        }
      },
      "required": ["prefix", "building_description", "project_prefix_sort_order", "plant_area_name", "plant_area_order", "work_area", "used_for_pid", "sort_number"]
    },
    "document_type_entry": {
      "type": "object",
      "additionalProperties": false,
      "description": "Document type classification with code and description",
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[A-Z0-9]{2,3}$",
          "minLength": 2,
          "maxLength": 3,
          "description": "Standardized 2-3 character alphanumeric document type code"
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120,
          "description": "Full name/description of the document type"
        }
      },
      "required": ["code", "description"]
    },
    "project_entry": {
      "type": "object",
      "additionalProperties": false,
      "description": "Project classification with code and description",
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[A-Z]{2,4}\\d{2}$",
          "minLength": 4,
          "maxLength": 6,
          "description": "Standardized project code"
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200,
          "description": "Project description"
        }
      },
      "required": ["code", "description"]
    },
    "column_types": {
      "type": "object",
      "additionalProperties": false,
      "description": "Reusable column type definitions for dcc_register_enhanced",
      "properties": {
        "id_column": {
          "type": "object",
          "additionalProperties": false,
          "description": "Common ID column patterns (auto-generated, composite)",
          "properties": {
            "data_type": {"type": "string", "enum": ["string", "numeric"]},
            "is_calculated": {"type": "boolean", "default": true},
            "create_if_missing": {"type": "boolean", "default": true},
            "validation": {
              "type": "array",
              "items": {"$ref": "#/definitions/validation_rule_entry"}
            }
          }
        },
        "code_column": {
          "type": "object",
          "additionalProperties": false,
          "description": "Schema-referenced categorical codes",
          "properties": {
            "data_type": {"type": "string", "enum": ["categorical"]},
            "is_calculated": {"type": "boolean", "default": false},
            "schema_reference": {"type": "string"},
            "null_handling": {"$ref": "#/definitions/null_handling_strategy"},
            "validation": {
              "type": "array",
              "items": {"$ref": "#/definitions/validation_rule_entry"}
            }
          }
        },
        "date_column": {
          "type": "object",
          "additionalProperties": false,
          "description": "Date handling with multi-level forward fill",
          "properties": {
            "data_type": {"type": "string", "enum": ["date"]},
            "is_calculated": {"type": "boolean", "default": false},
            "null_handling": {"$ref": "#/definitions/multi_level_forward_fill"},
            "validation": {
              "type": "array",
              "items": {"$ref": "#/definitions/validation_rule_entry"}
            }
          }
        },
        "sequence_column": {
          "type": "object",
          "additionalProperties": false,
          "description": "Zero-padded sequences",
          "properties": {
            "data_type": {"type": "string"},
            "is_calculated": {"type": "boolean", "default": false},
            "null_handling": {"$ref": "#/definitions/forward_fill_with_padding"},
            "validation": {
              "type": "array",
              "items": {"$ref": "#/definitions/validation_rule_entry"}
            }
          }
        },
        "status_column": {
          "type": "object",
          "additionalProperties": false,
          "description": "Status with schema validation",
          "properties": {
            "data_type": {"type": "string", "enum": ["categorical"]},
            "is_calculated": {"type": "boolean", "default": false},
            "schema_reference": {"type": "string"},
            "validation": {
              "type": "array",
              "items": {"$ref": "#/definitions/validation_rule_entry"}
            }
          }
        }
      }
    },
    "validation_patterns": {
      "type": "object",
      "additionalProperties": false,
      "description": "Reusable validation pattern definitions",
      "properties": {
        "pattern_validation": {
          "type": "object",
          "additionalProperties": false,
          "description": "Reusable regex patterns",
          "properties": {
            "type": {"type": "string", "enum": ["pattern"]},
            "pattern": {"type": "string"},
            "description": {"type": "string"}
          }
        },
        "schema_validation": {
          "type": "object",
          "additionalProperties": false,
          "description": "Schema reference validation",
          "properties": {
            "type": {"type": "string", "enum": ["schema_reference_check"]},
            "reference": {"type": "string"},
            "description": {"type": "string"}
          }
        },
        "range_validation": {
          "type": "object",
          "additionalProperties": false,
          "description": "Min/max value validation",
          "properties": {
            "type": {"type": "string", "enum": ["min_value", "max_value"]},
            "min_value": {"type": ["number", "null"]},
            "max_value": {"type": ["number", "null"]},
            "description": {"type": "string"}
          }
        }
      }
    },
    "null_handling_strategies": {
      "type": "object",
      "additionalProperties": false,
      "description": "Reusable null handling strategy definitions",
      "properties": {
        "forward_fill_with_padding": {
          "type": "object",
          "additionalProperties": false,
          "description": "Forward fill with zero padding",
          "properties": {
            "strategy": {"type": "string", "enum": ["forward_fill"]},
            "group_by": {"type": "array", "items": {"type": "string"}},
            "fill_value": {"type": "string"},
            "formatting": {
              "type": "object",
              "properties": {
                "zero_pad": {"type": "integer"},
                "description": {"type": "string"}
              }
            }
          }
        },
        "multi_level_forward_fill": {
          "type": "object",
          "additionalProperties": false,
          "description": "Hierarchical filling strategy",
          "properties": {
            "strategy": {"type": "string", "enum": ["multi_level_forward_fill"]},
            "levels": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "group_by": {"type": "array", "items": {"type": "string"}},
                  "description": {"type": "string"}
                }
              }
            },
            "final_fill": {"type": "string"}
          }
        }
      }
    },
    "global_parameters": {
      "type": "object",
      "additionalProperties": false,
      "description": "Global pipeline parameters required for initiating DCC processing pipeline",
      "properties": {
        "fail_fast": {
          "type": "boolean",
          "description": "Whether to stop processing on first error",
          "default": false
        },
        "debug_dev_mode": {
          "type": "boolean", 
          "description": "Enable debug and development mode",
          "default": false
        },
        "is_colab": {
          "type": "boolean",
          "description": "Running in Google Colab environment",
          "default": false
        },
        "overwrite_existing_downloads": {
          "type": "boolean",
          "description": "Whether to overwrite existing download files",
          "default": true
        },
        "duration_is_working_day": {
          "type": "boolean",
          "description": "Whether duration calculations use working days",
          "default": true
        },
        "pc_name": {
          "type": "string",
          "description": "PC name identifier",
          "default": "CESL-22120"
        },
        "start_col": {
          "type": "string",
          "pattern": "^[A-Z]{1,2}$",
          "description": "Starting column for data processing",
          "default": "P"
        },
        "end_col": {
          "type": "string",
          "pattern": "^[A-Z]{1,2}$",
          "description": "Ending column for data processing",
          "default": "AP"
        },
        "header_row_index": {
          "type": "integer",
          "minimum": 0,
          "description": "Header row index in Excel files",
          "default": 4
        },
        "first_review_duration": {
          "type": "integer",
          "minimum": 1,
          "description": "Default first review duration in days",
          "default": 20
        },
        "second_review_duration": {
          "type": "integer",
          "minimum": 1,
          "description": "Default second review duration in days",
          "default": 14
        },
        "resubmission_duration": {
          "type": "integer",
          "minimum": 1,
          "description": "Default resubmission duration in days",
          "default": 14
        },
        "progress_stage": {
          "type": "string",
          "enum": ["not_start", "in_progress", "completed"],
          "description": "Pipeline progress stage",
          "default": "not_start"
        },
        "upload_sheet_name": {
          "type": "string",
          "description": "Upload sheet name in Excel file",
          "default": "Prolog Submittals"
        },
        "win_upload_file": {
          "type": "string",
          "description": "Windows upload file path",
          "default": "data/Submittal and RFI Tracker Lists.xlsx"
        },
        "win_download_path": {
          "type": "string",
          "description": "Windows download path",
          "default": "output"
        },
        "linux_upload_file": {
          "type": "string",
          "description": "Linux upload file path",
          "default": "data/Submittal and RFI Tracker Lists.xlsx"
        },
        "linux_download_path": {
          "type": "string",
          "description": "Linux download path",
          "default": "output"
        },
        "colab_upload_file": {
          "type": "string",
          "description": "Colab upload file path",
          "default": "/content/sample_data/Submittal and RFI Tracker Lists.xlsx"
        },
        "colab_download_path": {
          "type": "string",
          "description": "Colab download path",
          "default": "/content/output"
        },
        "upload_file_name": {
          "type": "string",
          "description": "Upload file name",
          "default": "data/Submittal and RFI Tracker Lists.xlsx"
        },
        "download_file_path": {
          "type": "string",
          "description": "Download file path",
          "default": "output"
        },
        "pending_status": {
          "type": "object",
          "additionalProperties": false,
          "description": "Pending status configuration",
          "properties": {
            "schema": {
              "type": "string",
              "description": "Schema to reference for status codes",
              "default": "approval_code_schema"
            },
            "code": {
              "type": "string",
              "description": "Status code for pending",
              "default": "PEN"
            },
            "field": {
              "type": "string",
              "description": "Field to reference in schema",
              "default": "status"
            },
            "description": {
              "type": "string",
              "description": "Description of pending status configuration",
              "default": "Resolved from approval_code_schema approval entry with code 'PEN'. Ensures single source of truth for pending status."
            }
          },
          "required": ["schema", "code", "field"]
        },
        "dynamic_column_creation": {
          "type": "object",
          "additionalProperties": false,
          "description": "Dynamic column creation configuration",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable dynamic column creation",
              "default": true
            },
            "missing_column_action": {
              "type": "string",
              "enum": ["create_with_default", "skip", "error"],
              "description": "Action when column is missing",
              "default": "create_with_default"
            },
            "default_value": {
              "type": "string",
              "description": "Default value for missing columns",
              "default": "NA"
            },
            "description": {
              "type": "string",
              "description": "Description of dynamic column creation",
              "default": "Executed by _initialize_missing_columns. If a schema column is not found in the input data, it is created using the global or column-specific default value."
            }
          },
          "required": ["enabled", "missing_column_action", "default_value"]
        }
      },
      "required": ["fail_fast", "debug_dev_mode", "pc_name", "start_col", "end_col", "header_row_index"]
    }
  }
}
