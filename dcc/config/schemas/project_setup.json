{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dcc-pipeline.internal/schemas/project-setup",
  "title": "DCC Project Setup Validation Schema",
  "description": "Schema for validating required folders and files for DCC project distribution and setup. Optimized using fragment pattern per agent_rule.md Section 2.",
  "version": "2.0.0",
  "type": "object",
  "additionalProperties": false,
  "allOf": [
    {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-base"}
  ],
  "definitions": {
    "folder_entry": {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-structure#/definitions/folder_entry"},
    "root_file_entry": {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-structure#/definitions/root_file_entry"},
    "file_entry": {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-base#/definitions/file_entry"},
    "typed_file_entry": {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-base#/definitions/typed_file_entry"},
    "python_module_entry": {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-base#/definitions/python_module_entry"},
    "path_entry": {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-base#/definitions/path_entry"},
    "pattern_rule": {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-base#/definitions/pattern_rule"},
    "validation_rule": {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-base#/definitions/validation_rule"},
    "environment_entry": {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-environment#/definitions/environment_entry"},
    "validation_rule_entry": {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-validation#/definitions/validation_rule_entry"},
    "dependencies_config": {"$ref": "https://dcc-pipeline.internal/schemas/project-setup-dependencies#/definitions/dependencies_config"}
  },
  "properties": {
    "folders": {
      "$ref": "https://dcc-pipeline.internal/schemas/project-setup-structure#/properties/folders"
    },
    "root_files": {
      "$ref": "https://dcc-pipeline.internal/schemas/project-setup-structure#/properties/root_files"
    },
    "schema_files": {
      "type": "array",
      "description": "Required JSON schema definition files (located in config/schemas). Supports auto-discovery via discovery_rules.",
      "items": {"$ref": "#/definitions/file_entry"}
    },
    "discovery_rules": {
      "type": "array",
      "description": "Pattern-based rules for auto-discovering schema files. See agent_rule.md Section 2.8",
      "items": {"$ref": "#/definitions/pattern_rule"},
      "default": [
        {
          "pattern": "*_schema.json",
          "directory": "config/schemas",
          "auto_register": true,
          "category": "validation_schema",
          "exclude_patterns": ["**/backup/**"]
        },
        {
          "pattern": "**/error_handling/config/*.json",
          "directory": "workflow",
          "recursive": true,
          "auto_register": true,
          "category": "engine_schema"
        }
      ]
    },
    "workflow_files": {
      "type": "array",
      "description": "Required workflow notebooks and Python modules (located in workflow)",
      "items": {
        "allOf": [
          {"$ref": "#/definitions/typed_file_entry"}
        ],
        "type": "object",
        "properties": {
          "type": {
            "enum": ["notebook", "python_module", "documentation"]
          }
        }
      }
    },
    "tool_files": {
      "type": "array",
      "description": "Required utility and setup script files (located in tools)",
      "items": {
        "allOf": [
          {"$ref": "#/definitions/python_module_entry"}
        ],
        "type": "object",
        "properties": {
          "type": {
            "enum": ["python_script", "shell_script", "other"]
          }
        }
      }
    },
    "processor_engine": {
      "type": "array",
      "description": "Document processor engine modules (located in workflow/processor_engine)",
      "items": {
        "allOf": [
          {"$ref": "#/definitions/path_entry"}
        ],
        "type": "object",
        "properties": {
          "type": {
            "enum": ["folder", "python_module", "documentation", "init_file", "test_file"]
          }
        }
      }
    },
    "mapper_engine": {
      "type": "array",
      "description": "Column mapper engine modules (located in workflow/mapper_engine)",
      "items": {
        "allOf": [
          {"$ref": "#/definitions/path_entry"}
        ],
        "type": "object",
        "properties": {
          "type": {
            "enum": ["folder", "python_module", "documentation", "init_file"]
          }
        }
      }
    },
    "schema_validation": {
      "type": "array",
      "description": "Schema validation modules (located in workflow)",
      "items": {
        "allOf": [
          {"$ref": "#/definitions/python_module_entry"}
        ],
        "type": "object",
        "properties": {
          "type": {
            "enum": ["python_module"]
          }
        }
      }
    },
    "schema_engine": {
      "type": "array",
      "description": "Schema engine modules (located in workflow/schema_engine)",
      "items": {
        "allOf": [
          {"$ref": "#/definitions/path_entry"}
        ],
        "type": "object",
        "properties": {
          "type": {
            "enum": ["folder", "python_module", "documentation", "init_file"]
          }
        }
      }
    },
    "initiation_engine": {
      "type": "array",
      "description": "Initiation engine modules (located in workflow/initiation_engine)",
      "items": {
        "allOf": [
          {"$ref": "#/definitions/path_entry"}
        ],
        "type": "object",
        "properties": {
          "type": {
            "enum": ["folder", "python_module", "documentation", "init_file"]
          }
        }
      }
    },
    "reporting_engine": {
      "type": "array",
      "description": "Reporting engine modules (located in workflow/reporting_engine)",
      "items": {
        "allOf": [
          {"$ref": "#/definitions/path_entry"}
        ],
        "type": "object",
        "properties": {
          "type": {
            "enum": ["folder", "python_module", "documentation", "init_file"]
          }
        }
      }
    },
    "environment": {
      "$ref": "https://dcc-pipeline.internal/schemas/project-setup-environment#/properties/environment"
    },
    "validation_rules": {
      "$ref": "https://dcc-pipeline.internal/schemas/project-setup-validation#/properties/validation_rules"
    },
    "dependencies": {
      "$ref": "https://dcc-pipeline.internal/schemas/project-setup-dependencies#/properties/dependencies"
    }
  },
  "required": [
    "folders",
    "root_files",
    "schema_files",
    "workflow_files",
    "tool_files",
    "processor_engine",
    "mapper_engine",
    "schema_validation",
    "schema_engine",
    "initiation_engine",
    "reporting_engine",
    "environment",
    "validation_rules",
    "dependencies"
  ],
  "project_setup": {
        "folders": [
        {
          "name": "config/schemas",
          "required": true,
          "purpose": "Schema definitions"
        },
        {
          "name": "data",
          "required": false,
          "purpose": "Input data files"
        },
        {
          "name": "output",
          "required": false,
          "purpose": "Generated output",
          "auto_created": true
        },
        {
          "name": "reference",
          "required": false,
          "purpose": "Documentation and instructions"
        },
        {
          "name": "workflow",
          "required": true,
          "purpose": "Processing notebooks and modules"
        },
        {
          "name": "tools",
          "required": true,
          "purpose": "Setup and utility scripts"
        }
      ],
      "root_files": [
        {
          "name": "dcc.yml",
          "required": true,
          "purpose": "Conda environment specification",
          "extension": "yml"
        },
        {
          "name": "README.md",
          "required": false,
          "purpose": "Project overview",
          "extension": "md"
        }
      ],
      "schema_files": [
        {
          "filename": "dcc_register_enhanced.json",
          "required": true,
          "description": "Main schema with column definitions, aliases, null handling",
          "approximate_size": "~56KB"
        },
        {
          "filename": "department_schema.json",
          "required": true,
          "description": "Department validation rules",
          "approximate_size": "~454B"
        },
        {
          "filename": "discipline_schema.json",
          "required": true,
          "description": "Discipline validation rules",
          "approximate_size": "~379B"
        },
        {
          "filename": "document_type_schema.json",
          "required": true,
          "description": "Document type validation rules",
          "approximate_size": "~350B"
        },
        {
          "filename": "approval_code_schema.json",
          "required": true,
          "description": "Status code definition and mappings (APP, REJ, PEN, etc.)",
          "approximate_size": "~1316B"
        },
        {
          "filename": "facility_schema.json",
          "required": true,
          "description": "Facility code validation rules and mappings",
          "approximate_size": "~350B"
        },
        {
          "filename": "project_schema.json",
          "required": true,
          "description": "Project code definitions and validation rules",
          "approximate_size": "~300B"
        },
        {
          "filename": "calculation_strategies.json",
          "required": true,
          "description": "Column calculation strategies and formulas for derived fields",
          "approximate_size": "~2KB"
        },
        {
          "filename": "master_registry.json",
          "required": true,
          "description": "Master registry tracking all project submissions and document versions",
          "approximate_size": "~5KB"
        },
        {
          "filename": "workflow/processor_engine/error_handling/config/taxonomy.json",
          "required": true,
          "description": "Error taxonomy - engine/module/function classification",
          "approximate_size": "~311B"
        },
        {
          "filename": "workflow/processor_engine/error_handling/config/error_codes.json",
          "required": true,
          "description": "Error code registry with severity and remediation mappings",
          "approximate_size": "~602B"
        },
        {
          "filename": "workflow/processor_engine/error_handling/config/anatomy_schema.json",
          "required": true,
          "description": "Error code anatomy validation (E-M-F-XXXX format)",
          "approximate_size": "~153B"
        },
        {
          "filename": "workflow/processor_engine/error_handling/config/approval_workflow.json",
          "required": true,
          "description": "Suppression and overrule approval workflow definitions",
          "approximate_size": "~222B"
        },
        {
          "filename": "workflow/processor_engine/error_handling/config/remediation_types.json",
          "required": true,
          "description": "Remediation strategy types (AUTO_FIX, MANUAL_FIX, etc.)",
          "approximate_size": "~217B"
        },
        {
          "filename": "workflow/processor_engine/error_handling/config/status_lifecycle.json",
          "required": true,
          "description": "Error status state machine (OPEN, RESOLVED, ARCHIVED, etc.)",
          "approximate_size": "~165B"
        },
        {
          "filename": "workflow/processor_engine/error_handling/config/suppression_rules.json",
          "required": true,
          "description": "Suppression rules for 'wrong but acceptable' scenarios",
          "approximate_size": "~144B"
        },
        {
          "filename": "workflow/processor_engine/error_handling/config/messages/en.json",
          "required": true,
          "description": "English error messages and templates",
          "approximate_size": "~125B"
        },
        {
          "filename": "workflow/processor_engine/error_handling/config/messages/zh.json",
          "required": false,
          "description": "Chinese error messages and templates (i18n)",
          "approximate_size": "~125B"
        }
      ],
      "workflow_files": [
        {
          "filename": "dcc_engine_pipeline.py",
          "required": true,
          "type": "python_module",
          "description": "Modular engine pipeline using five engine folders: initiation, schema, mapper, processor, reporting",
          "main_functions": [
            "run_engine_pipeline",
            "test_environment"
          ],
          "approximate_size": "~15KB"
        },
      {
        "filename": "dcc_register_processor_main.ipynb",
        "required": false,
        "type": "notebook",
        "description": "Main orchestration notebook - Step-by-step processing (legacy)",
        "approximate_size": "~85KB"
      },
      {
        "filename": "dcc_register_processor_main.py",
        "required": false,
        "type": "python_module",
        "description": "Main Python pipeline (legacy - use dcc_engine_pipeline.py instead)",
        "approximate_size": "~12KB"
      },
        {
          "filename": "universal_document_processor.py",
        "required": false,
          "type": "python_module",
        "description": "Schema-driven processing engine (legacy - now in processor_engine)",
          "approximate_size": "~25KB"
        },
        {
          "filename": "universal_column_mapper.py",
        "required": false,
          "type": "python_module",
        "description": "Fuzzy column name mapping (legacy - now in mapper_engine)",
          "approximate_size": "~20KB"
        },
        {
          "filename": "schema_validation.py",
        "required": false,
          "type": "python_module",
        "description": "Standalone schema validation (legacy - now in schema_engine)",
          "approximate_size": "~10KB"
        }
      ],
      "tool_files": [
        {
          "filename": "project_setup_tools.py",
          "required": true,
          "type": "python_script",
          "description": "Main validation tool - Checks all required files and folders",
          "main_functions": [
            "validate_project_structure",
            "analyze_columns",
            "check_workflow_dependencies",
            "reorganize_schema_columns"
          ]
        }
      ],
      "processor_engine": [
        {
          "path": ".",
          "type": "folder",
          "required": true,
          "description": "Main engine package"
        },
        {
          "path": "./__init__.py",
          "type": "init_file",
          "required": true,
          "description": "Engine package exports"
        },
        {
          "path": "./readme.md",
          "type": "documentation",
          "required": false,
          "description": "Engine module documentation"
        },
        {
          "path": "./core",
          "type": "folder",
          "required": true,
          "description": "Core engine components"
        },
        {
          "path": "./core/__init__.py",
          "type": "init_file",
          "required": true,
          "description": "Core module exports"
        },
        {
          "path": "./core/base.py",
