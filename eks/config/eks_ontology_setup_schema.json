{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://eks.engineering/schemas/eks_ontology_setup_schema.json",
  "version": "1.1.0",
  "title": "EKS Ontology Setup Schema — Declarations",
  "description": "Global declarations for EKS ontology. Validates the ontology config instance and implements inheritance from the base schema.",
  "allOf": [
    { "$ref": "eks_ontology_base_schema.json" }
  ],
  "type": "object",
  "properties": {
    "$schema": { "type": "string" },
    "$id": { "type": "string" },
    "version": { "type": "string" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "classes": {
      "type": "array",
      "items": { "$ref": "https://eks.engineering/schemas/eks_ontology_base_schema.json#/definitions/ontology_class" },
      "minItems": 1
    },
    "relationships": {
      "type": "array",
      "items": { "$ref": "https://eks.engineering/schemas/eks_ontology_base_schema.json#/definitions/relationship" },
      "minItems": 1
    }
  },
  "required": ["classes", "relationships"],
  "additionalProperties": false
}
