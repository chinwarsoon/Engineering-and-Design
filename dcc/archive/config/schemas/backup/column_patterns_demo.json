{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dcc-pipeline.internal/schemas/column-patterns-demo",
  "title": "Column Patterns Optimization Demo",
  "description": "Demonstration of optimized column definitions using reusable patterns",
  "version": "1.0.0",
  "type": "object",
  "additionalProperties": false,
  "allOf": [
    {
      "$ref": "https://dcc-pipeline.internal/schemas/project-setup-base#/definitions/column_types"
    }
  ],
  "optimized_columns": {
    "Submission_Session": {
      "allOf": [
        {"$ref": "#/definitions/sequence_column"}
      ],
      "null_handling": {
        "strategy": "forward_fill",
        "group_by": [],
        "fill_value": "9",
        "formatting": {
          "zero_pad": 6,
          "description": "Applied via _apply_forward_fill formatting. Ensures session identifiers are uniformly padded specifically to 6 digits."
        }
      },
      "validation": [
        {
          "type": "pattern",
          "pattern": "^[0-9]{6}$",
          "description": "Unique submission session identifier (6-digit zero-padded)"
        }
      ]
    },
    "Project_Code": {
      "allOf": [
        {"$ref": "#/definitions/code_column"}
      ],
      "schema_reference": "project_schema",
      "null_handling": {
        "strategy": "default_value",
        "default_value": "NA"
      },
      "validation": [
        {
          "type": "pattern",
          "pattern": "^[A-Z0-9-]*$",
          "description": "Validated by _apply_validation using regex pattern matching. Warns if identifier contains non-alphanumeric characters."
        },
        {
          "type": "schema_reference_check",
          "reference": "project_schema",
          "description": "Ensures project code exists in project schema"
        }
      ]
    },
    "Document_ID": {
      "allOf": [
        {"$ref": "#/definitions/id_column"}
      ],
      "data_type": "string",
      "calculation": {
        "type": "composite",
        "method": "generate_document_id",
        "description": "Composite ID from Project_Code-Facility_Code-Document_Type-Discipline-Document_Sequence_Number-Document_Revision"
      },
      "validation": [
        {
          "type": "pattern",
          "pattern": "^[A-Z0-9-]+-[A-Z0-9]{3,5}-[A-Z0-9]{2,3}-[A-Z0-9]{1,3}-[0-9]{4}-[A-Z0-9]{1,2}$",
          "description": "Document ID format validation"
        }
      ]
    },
    "Submission_Date": {
      "allOf": [
        {"$ref": "#/definitions/date_column"}
      ],
      "null_handling": {
        "strategy": "multi_level_forward_fill",
        "levels": [
          {
            "group_by": ["Submission_Session", "Submission_Session_Revision"],
            "description": "Forward fill within same submission session and revision"
          },
          {
            "group_by": ["Submission_Session"],
            "description": "Forward fill within same submission session"
          }
        ],
        "final_fill": "NA"
      }
    },
    "Review_Status": {
      "allOf": [
        {"$ref": "#/definitions/status_column"}
      ],
      "schema_reference": "approval_code_schema",
      "validation": [
        {
          "type": "schema_reference_check",
          "reference": "approval_code_schema",
          "description": "Ensures review status exists in approval code schema"
        }
      ]
    }
  },
  "optimization_benefits": {
    "schema_size_reduction": "~60%",
    "maintainability_improvement": "Centralized definitions",
    "consistency_enhancement": "Standardized patterns",
    "validation_reuse": "Common validation rules",
    "testing_simplification": "Fewer unique patterns to test"
  },
  "pattern_usage_stats": {
    "id_columns": 4,
    "code_columns": 7,
    "date_columns": 9,
    "sequence_columns": 3,
    "status_columns": 4,
    "total_columns_optimized": 27
  }
}
