{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dcc-pipeline.internal/schemas/dcc-master-registry",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "folder_entry": {
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Relative path of the folder" },
        "purpose": { "type": "string", "description": "Description of the folder's purpose" },
        "required": { "type": "boolean", "description": "Whether this folder is mandatory" }
      },
      "required": ["name", "purpose", "required"]
    }
  },
  "properties": {
    "registry": {
      "type": "object",
      "description": "Mapping of register IDs to their configurations",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "schema": {
            "type": "object",
            "properties": { "$ref": { "type": "string" } },
            "required": ["$ref"],
            "description": "Reference to the schema file associated with this register"
          },
          "workflow": { "type": "string", "description": "Workflow identifier for processing this register" },
          "description": { "type": "string", "description": "Human-readable description of the register" },
          "upload_file": { "type": "string", "description": "Default path to the Excel file to upload/process" },
          "sheet_name": { "type": "string", "description": "The specific Excel sheet name for this register" },
          "download_path": { "type": "string", "description": "Default directory for output data" },
          "active": { "type": "boolean", "description": "Whether this register is currently active", "default": true }
        },
        "required": ["schema", "workflow"]
      }
    },
    "validation_inventory": {
      "type": "object",
      "description": "Inventory of categorical validation schemas",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "file": {
            "type": "object",
            "properties": { "$ref": { "type": "string" } },
            "required": ["$ref"],
            "description": "Reference to the categorical schema file"
          },
          "data_key": { "type": "string", "description": "The key within the schema file where data is located" },
          "is_global": { "type": "boolean", "description": "If true, the data is shared across all registers" }
        },
        "required": ["file", "data_key"]
      }
    },
    "project_structure": {
      "type": "object",
      "description": "Project folder and file structure requirements",
      "properties": {
        "required_folders": {
          "type": "array",
          "items": { "$ref": "#/definitions/folder_entry" }
        }
      }
    }
  },
  "default": {
    "registry": {
      "dcc_submittal": {
        "schema": { "$ref": "https://dcc-pipeline.internal/schemas/dcc-register-enhanced" },
        "workflow": "UNIVERSAL_REGISTER",
        "description": "Standard document submittal tracking",
        "upload_file": "data/Submittal and RFI Tracker Lists.xlsx",
        "sheet_name": "Prolog Submittals ",
        "download_path": "output",
        "active": true
      },
      "rfi_tracker": {
        "schema": { "$ref": "https://dcc-pipeline.internal/schemas/rfi-register" },
        "workflow": "UNIVERSAL_REGISTER",
        "description": "Request for Information log",
        "upload_file": "data/Submittal and RFI Tracker Lists.xlsx",
        "sheet_name": "RFI Tracker",
        "download_path": "output",
        "active": true
      }
    },
    "validation_inventory": {
      "approval_code": { "file": { "$ref": "https://dcc-pipeline.internal/schemas/approval-code" }, "data_key": "approval", "is_global": true },
      "project": { "file": { "$ref": "https://dcc-pipeline.internal/schemas/project" }, "data_key": "projects", "is_global": true },
      "department": { "file": { "$ref": "https://dcc-pipeline.internal/schemas/department" }, "data_key": "choices", "is_global": true },
      "discipline": { "file": { "$ref": "https://dcc-pipeline.internal/schemas/discipline" }, "data_key": "disciplines", "is_global": true },
      "document_type": { "file": { "$ref": "https://dcc-pipeline.internal/schemas/document-type" }, "data_key": "document_types", "is_global": true },
      "facility": { "file": { "$ref": "https://dcc-pipeline.internal/schemas/facility" }, "data_key": "facilities", "is_global": false }
    }
  }
}
