        }
    }).join('');

// 5. Update the rest of the UI (Aggregators and Column Visibility Menu)
    const numericCols = headers.filter(h => rawData.some(r => typeof r[h] === 'number' && !isExcelDate(r[h])));
    document.getElementById('aggColumn').innerHTML = `<option value="">-- Count --</option>
        <optgroup label="Unique Distinct">${headers.map(h => `<option value="DISTINCT|${h}">${h}</option>`).join('')}</optgroup>
        <optgroup label="Sum">${numericCols.map(h => `<option value="SUM|${h}">${h}</option>`).join('')}</optgroup>`;

        document.getElementById('groupCheckboxArea').innerHTML = headers.map(h => `
