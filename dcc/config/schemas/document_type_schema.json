{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dcc-pipeline.internal/schemas/document-type",
  "title": "DCC Document Type Schema",
  "description": "Standard document type classifications with built-in validation rules.",
  "version": "2.0.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "document_types"
  ],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version"
    },
    "description": {
      "type": "string"
    },
    "created": {
      "type": "string"
    },
    "document_types": {
      "type": "array",
      "description": "List of standardized document types and their descriptions",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "code",
          "description"
        ],
        "properties": {
          "code": {
            "type": "string",
            "pattern": "^[A-Z0-9]{2,3}$",
            "minLength": 2,
            "maxLength": 3,
            "description": "Standardized 2-3 character alphanumeric document type code"
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120,
            "description": "Full name/description of the document type"
          }
        }
      },
      "uniqueItems": true
    }
  },
  "document_types": [
    {
      "code": "AD",
      "description": "Addendum"
    },
    {
      "code": "AL",
      "description": "Approval Letter"
    },
    {
      "code": "BR",
      "description": "Brochure"
    },
    {
      "code": "CA",
      "description": "Calculation"
    },
    {
      "code": "CT",
      "description": "Certificate"
    },
    {
      "code": "CH",
      "description": "Chart"
    },
    {
      "code": "CL",
      "description": "Checklist"
    },
    {
      "code": "DS",
      "description": "Data Sheet"
    },
    {
      "code": "DW",
      "description": "Drawing"
    },
    {
      "code": "IT",
      "description": "Inspection and Test Plan"
    },
    {
      "code": "LY",
      "description": "Layout"
    },
    {
      "code": "MS",
      "description": "Method Statement"
    },
    {
      "code": "PR",
      "description": "Procedure"
    },
    {
      "code": "RE",
      "description": "Report"
    },
    {
      "code": "SP",
      "description": "Specification"
    }
  ]
}