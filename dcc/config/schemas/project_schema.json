{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dcc-pipeline.internal/schemas/project",
  "title": "DCC Project Schema",
  "description": "Standardized project code definitions and validation rules for the DCC pipeline.",
  "version": "2.0.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "projects"
  ],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version"
    },
    "description": {
      "type": "string"
    },
    "created": {
      "type": "string",
      "format": "date"
    },
    "projects": {
      "type": "array",
      "description": "List of active project codes and human-readable descriptions",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "code",
          "description"
        ],
        "properties": {
          "code": {
            "type": "string",
            "pattern": "^\\d{6}$",
            "minLength": 6,
            "maxLength": 6,
            "description": "Standardized 6-digit numerical project code"
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "description": "Full project name or description"
          }
        }
      },
      "uniqueItems": true
    }
  },
  "projects": [
    {
      "code": "131242",
      "description": "TWRP"
    }
  ]
}