function bulkToggleCols(showAll, event) {
    if (event) event.stopPropagation(); // Keep the menu open
    
    if (showAll) {
        // Show all: Clear the hidden set
        hiddenColumns.clear();
    } else {
        // Clear all: Add every header to the hidden set
        headers.forEach(h => hiddenColumns.add(h));
    }

    // Update the checkboxes visually
    const checkboxes = document.querySelectorAll('.col-visibility-check');
    checkboxes.forEach(cb => {
        cb.checked = showAll;
    });

    // Refresh the table
    runFilter();
}

