          "type": "folder",
          "required": true,
          "description": "Utility functions"
        },
        {
          "path": "engine/utils/__init__.py",
          "type": "init_file",
          "required": true,
          "description": "Utils module exports"
        },
        {
          "path": "engine/utils/columns.py",
          "type": "python_module",
          "required": true,
          "description": "Column bounds and coverage analysis",
          "main_functions": ["get_column_bounds", "analyze_column_coverage"]
        }
      ],
      "schema_validation": [
        {
          "filename": "schema_validation.py",
          "type": "python_module",
          "required": true,
          "description": "Schema loading, validation, and dependency resolution",
          "main_functions": [
            "SchemaLoader",
            "SchemaValidator",
            "validate_validation_status",
            "write_validation_status",
            "load_validation_status"
          ]
        }
      ],
      "schema_engine": [
        {
          "path": "engine",
          "type": "folder",
          "required": true,
          "description": "Main schema engine package"
        },
        {
          "path": "engine/__init__.py",
          "type": "init_file",
          "required": true,
          "description": "Schema engine package exports"
        },
        {
          "path": "engine/readme.md",
          "type": "documentation",
          "required": false,
          "description": "Schema engine documentation"
        },
        {
          "path": "engine/core",
          "type": "folder",
          "required": true,
          "description": "Core schema engine components"
        },
        {
          "path": "engine/core/__init__.py",
          "type": "init_file",
          "required": true,
          "description": "Core module exports"
        },
        {
          "path": "engine/core/reports.py",
          "type": "python_module",
          "required": true,
          "description": "Report formatting utilities",
          "main_functions": ["format_report"]
        },
        {
          "path": "engine/loader",
          "type": "folder",
          "required": true,
          "description": "Schema loading and dependency resolution"
