{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dcc-pipeline.internal/schemas/error-codes",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {"type": "string"},
    "codes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "code": {"type": "string"},
          "message": {"type": "string"},
          "severity": {"type": "string", "enum": ["fatal", "error", "warning", "info"]},
          "remediation": {"type": "string"}
        },
        "required": ["code", "message", "severity"]
      }
    }
  },
  "required": ["version", "codes"],
  "version": "1.0",
  "codes": [
    {
      "code": "VAL-001",
      "message": "Required field missing",
      "severity": "error",
      "remediation": "Check for missing values in the input data"
    },
    {
      "code": "SYS-001",
      "message": "File not found",
      "severity": "fatal",
      "remediation": "Ensure the required file exists at the specified path"
    }
  ]
}
