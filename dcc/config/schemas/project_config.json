{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dcc-pipeline.internal/schemas/project_config",
  "title": "DCC Project Configuration Data",
  "description": "Actual configuration items for DCC project setup. Follows agent_rule.md Section 2.3 flat structure with array of objects.",
  "version": "1.0.0",
  "type": "object",
  "additionalProperties": false,
  "project_metadata": {
    "project_id": "dcc-engineering-design",
    "project_name": "DCC Engineering and Design Pipeline",
    "version": "1.0.0",
    "created_date": "2026-04-15",
    "last_modified": "2026-04-15"
  },
  "folders": [
        {"name": "config/schemas", "purpose": "Schema definitions and categorical lookups", "required": true},
        {"name": "data", "purpose": "Input Excel data files and trackers", "required": true},
        {"name": "output", "purpose": "Processed data exports (Excel, CSV, JSON)", "required": true},
        {"name": "workflow", "purpose": "Core processing engines and orchestration notebooks", "required": true},
        {"name": "tools", "purpose": "Utility scripts and setup helpers", "required": true},
        {"name": "Log", "purpose": "System, issue, and update logs", "required": true},
        {"name": "ui", "purpose": "Diagnostic dashboards and HTML explorers", "required": true}
  ],
  "root_files": [
        {"name": "dcc.yml", "purpose": "Conda environment specification", "required": true, "extension": "yml"},
        {"name": "README.md", "purpose": "Project documentation and setup instructions", "required": true, "extension": "md"}
  ],
  "schema_files": [
        {"filename": "project_setup_base.json", "required": true, "description": "Base schema with reusable definitions", "category": "base_schema"},
        {"filename": "project_setup.json", "required": true, "description": "Project setup validation schema", "category": "project_schema"},
        {"filename": "project_config.json", "required": true, "description": "Project configuration data", "category": "config_data"},
        {"filename": "dcc_register_base.json", "required": true, "description": "DCC register base definitions", "category": "base_schema"},
        {"filename": "project_code_schema.json", "required": true, "description": "Defines project codes and descriptions", "category": "data_schema"},
        {"filename": "global_parameters.json", "required": false, "description": "[DEPRECATED] Global parameters configuration - use dcc_global_parameters.json instead", "category": "config_data"},
        {"filename": "dcc_global_parameters.json", "required": true, "description": "DCC global processing parameter values", "category": "config_data"}
  ],
  "discovery_rules": [
        {"pattern": "*_schema.json", "directory": "config/schemas", "recursive": false, "auto_register": true, "category": "validation_schema", "exclude_patterns": ["**/backup/**"]},
        {"pattern": "*_config.json", "directory": "config/schemas", "recursive": false, "auto_register": true, "category": "config_data"},
        {"pattern": "dcc_register_*.json", "directory": "config/schemas", "recursive": false, "auto_register": true, "category": "register_schema"},
        {"pattern": "*.json", "directory": "workflow/processor_engine/error_handling/config", "recursive": true, "auto_register": true, "category": "engine_schema", "exclude_patterns": ["**/messages/**"]}
  ],
  "workflow_files": [
        {"filename": "dcc_engine_pipeline.py", "required": true, "description": "Main pipeline orchestration", "type": "python_module"}
  ],
  "tool_files": [
        {"filename": "project_setup_tools.py", "required": true, "description": "Project setup utilities", "type": "python_script"}
  ],
  "folder_creation": {
    "auto_create_output_directories": true,
    "auto_create_debug_directories": true,
    "auto_create_log_directories": true,
    "create_missing_parents": true,
    "required_directories": [
      {"name": "output", "auto_create": true, "purpose": "Processed data exports"},
      {"name": "output/csv", "auto_create": true, "purpose": "CSV file exports"},
      {"name": "output/excel", "auto_create": true, "purpose": "Excel file exports"},
      {"name": "output/summary", "auto_create": true, "purpose": "Summary reports"},
      {"name": "Log", "auto_create": true, "purpose": "System logs"}
    ],
    "optional_directories": [
      {"name": "temp", "auto_create": false, "purpose": "Temporary files"},
      {"name": "backup", "auto_create": false, "purpose": "Backup files"}
    ]
  },
  "environment": [
        {
          "name": "conda",
          "required": true,
          "file": "dcc.yml",
          "location": "root",
          "setup_commands": ["conda env create -f dcc.yml", "conda activate dcc"],
          "key_dependencies": ["python=3.13", "pandas", "numpy", "matplotlib", "seaborn", "jupyter", "duckdb", "openpyxl"]
        }
  ],
  "dependencies": {
      "required": ["pandas", "numpy", "openpyxl", "jsonschema"],
      "optional": ["matplotlib", "seaborn", "duckdb", "plotly", "pytest"],
      "engines": [
            {"module": "initiation_engine.core.validator", "members": ["ProjectSetupValidator"], "optional": false},
            {"module": "schema_engine.loader.schema_loader", "members": ["SchemaLoader"], "optional": false},
            {"module": "schema_engine.validator.schema_validator", "members": ["SchemaValidator"], "optional": false}
      ]
  },
  "system_parameters": {
    "fail_fast": false,
    "debug_dev_mode": false,
    "is_colab": false,
    "overwrite_existing_downloads": true,
    "pc_name": "CESL-22120",
    "progress_stage": "not_start"
  },
  "required": ["folders", "root_files", "schema_files", "environment", "dependencies", "project_metadata", "system_parameters"]
}
