{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://eks.engineering/schemas/eks_setup_schema.json",
    "version": "1.4.0",
    "title": "EKS Setup Schema - Declarations",
    "description": "Global property declarations. v1.2.1: discipline_registry changed to $ref-only. v1.2.2: project_rules_registry changed to $ref-only (inline values moved to eks_project_rules_config.json) per audit — SSOT enforced. v1.3.0: added project_setup property (T1.67). v1.4.0: reshaped project_setup to DCC-aligned object model (folders/root_files/schema_files/environment/dependencies/discovery_rules/validation_rules/project_metadata) per T1.85.",
    "allOf": [
        { "$ref": "eks_base_schema.json" }
    ],
    "type": "object",
    "properties": {
        "$schema": { "type": "string" },
        "$id": { "type": "string" },
        "version": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "project_rules_registry": {
            "type": "object",
            "description": "Reference to project rules config (SSOT — update eks_project_rules_config.json for new project rules)",
            "properties": {
                "$ref": { "type": "string" }
            },
            "required": ["$ref"]
        },
        "discipline_registry": {
            "type": "object",
            "description": "Reference to discipline fragment schema (SSOT — must update eks_discipline_schema.json for new disciplines)",
            "properties": {
                "$ref": { "type": "string" }
            },
            "required": ["$ref"]
        },
        "project_registry": {
            "type": "object",
            "description": "Reference to project code fragment schema",
            "properties": {
                "$ref": { "type": "string" }
            },
            "required": ["$ref"]
        },
        "department_registry": {
            "type": "object",
            "description": "Reference to department fragment schema",
            "properties": {
                "$ref": { "type": "string" }
            },
            "required": ["$ref"]
        },
        "facility_registry": {
            "type": "object",
            "description": "Reference to facility fragment schema",
            "properties": {
                "$ref": { "type": "string" }
            },
            "required": ["$ref"]
        },
        "global_paths": { "$ref": "https://eks.engineering/schemas/eks_base_schema.json#/definitions/global_paths_def" },
        "registry": { "$ref": "https://eks.engineering/schemas/eks_base_schema.json#/definitions/registry_def" },
        "parsers": { "$ref": "https://eks.engineering/schemas/eks_base_schema.json#/definitions/parsers_def" },
        "embedding": { "$ref": "https://eks.engineering/schemas/eks_base_schema.json#/definitions/embedding_def" },
        "vector_store": { "$ref": "https://eks.engineering/schemas/eks_base_schema.json#/definitions/vector_store_def" },
        "logging": { "$ref": "https://eks.engineering/schemas/eks_base_schema.json#/definitions/logging_def" },
        "project_setup": {
            "type": "object",
            "description": "Project setup validation rules — DCC-aligned object model (T1.85)",
            "properties": {
                "folders": {
                    "type": "array",
                    "description": "Required and optional project folders",
                    "items": { "$ref": "https://eks.engineering/schemas/eks_base_schema.json#/definitions/folder_entry_def" }
                },
                "root_files": {
                    "type": "array",
                    "description": "Files required at project root level",
                    "items": { "$ref": "https://eks.engineering/schemas/eks_base_schema.json#/definitions/root_file_entry_def" }
                },
                "schema_files": {
                    "type": "array",
                    "description": "Required JSON schema definition files",
                    "items": { "$ref": "https://eks.engineering/schemas/eks_base_schema.json#/definitions/schema_file_entry_def" }
                },
                "discovery_rules": {
                    "type": "array",
                    "description": "Pattern-based rules for auto-discovering files",
                    "items": { "$ref": "https://eks.engineering/schemas/eks_base_schema.json#/definitions/discovery_rule_def" }
                },
                "environment": {
                    "type": "array",
                    "description": "Environment specifications for the project",
                    "items": { "$ref": "https://eks.engineering/schemas/eks_base_schema.json#/definitions/environment_entry_def" }
                },
                "dependencies": {
                    "$ref": "https://eks.engineering/schemas/eks_base_schema.json#/definitions/dependency_config_def"
                },
                "validation_rules": {
                    "type": "array",
                    "description": "Validation rules for project setup",
                    "items": { "$ref": "https://eks.engineering/schemas/eks_base_schema.json#/definitions/validation_rule_entry_def" }
                },
                "project_metadata": {
                    "$ref": "https://eks.engineering/schemas/eks_base_schema.json#/definitions/project_metadata_def"
                }
            },
            "required": ["folders", "root_files", "schema_files", "dependencies", "project_metadata"],
            "additionalProperties": false
        }
    },
    "required": ["project_rules_registry", "discipline_registry", "project_registry", "department_registry", "facility_registry", "global_paths", "registry", "parsers", "embedding", "vector_store", "logging", "project_setup"],
    "additionalProperties": false
}
