{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dcc-pipeline.internal/schemas/pipeline-message/setup",
  "title": "Pipeline Message Setup Schema",
  "description": "Structure for pipeline message catalogs",
  "version": "1.0.0",
  "type": "object",
  "allOf": [
    { "$ref": "https://dcc-pipeline.internal/schemas/pipeline-message/base" }
  ],
  "properties": {
    "metadata": {
      "$ref": "https://dcc-pipeline.internal/schemas/pipeline-message/base#/definitions/message_metadata"
    },
    "messages": {
      "type": "object",
      "description": "Map of message IDs to their definitions",
      "additionalProperties": {
        "type": "object",
        "required": ["template", "level"],
        "properties": {
          "template": { "$ref": "https://dcc-pipeline.internal/schemas/pipeline-message/base#/definitions/template" },
          "level": { "$ref": "https://dcc-pipeline.internal/schemas/pipeline-message/base#/definitions/verbosity_level" },
          "icon": { "$ref": "https://dcc-pipeline.internal/schemas/pipeline-message/base#/definitions/icon" },
          "category": { "$ref": "https://dcc-pipeline.internal/schemas/pipeline-message/base#/definitions/message_category" }
        }
      }
    }
  },
  "additionalProperties": false
}
