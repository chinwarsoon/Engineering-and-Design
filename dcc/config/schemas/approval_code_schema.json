{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dcc-pipeline.internal/schemas/approval-code",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_name": {"type": "string"},
    "type": {"type": "string"},
    "data_section": {"type": "string"},
    "field_definitions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "code": {"type": "object"},
        "status": {"type": "object"},
        "aliases": {"type": "object"}
      }
    },
    "approval": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "code": {"type": "string"},
          "status": {"type": "string"},
          "aliases": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    },
    "description": {"type": "string"},
    "created": {"type": "string"},
    "version": {"type": ["string", "number"]}
  },
  "schema_name": "approval_code_schema",
  "type": "status_to_code_mapping",
  "data_section": "approval",
  "field_definitions": {
    "code": {
      "data_type": "string",
      "required": true,
      "validation": {
        "pattern": "^[A-Z]{3,4}$",
        "min_length": 3,
        "max_length": 4,
        "unique": true
      }
    },
    "status": {
      "data_type": "string",
      "required": true,
      "validation": {
        "min_length": 1,
        "max_length": 100,
        "unique": true
      }
    },
    "aliases": {
      "data_type": "array[string]",
      "required": true,
      "validation": {
        "min_items": 1,
        "unique_items": true,
        "global_unique_items": true
      }
    }
  },
  "approval": [
    {
      "code": "REJ",
      "status": "Rejected",
      "aliases": [
        "Rejected",
        "REJ"
      ]
    },
    {
      "code": "NAP",
      "status": "Not Approved",
      "aliases": [
        "Not Approved - Revise and resubmit",
        "Not Approved"
      ]
    },
    {
      "code": "AWC",
      "status": "Approved with Comments",
      "aliases": [
        "Approved with Comments",
        "Approved as noted"
      ]
    },
    {
      "code": "APP",
      "status": "Approved",
      "aliases": [
        "Approved",
        "APP"
      ]
    },
    {
      "code": "INF",
      "status": "For Information",
      "aliases": [
        "For Information",
        "INF"
      ]
    },
    {
      "code": "VOID",
      "status": "Void",
      "aliases": [
        "Void",
        "(VOID / NOT IN USE)",
        "(VOID  NOT IN USE)"
      ]
    },
    {
      "code": "PEN",
      "status": "Awaiting S.O.'s response",
      "aliases": [
        "Pending Review",
        "Pending",
        "Awaiting S.O.'s response",
        "Awaiting S.O. Review"
      ]
    }
  ],
  "description": "Mapping of approval status variations to standardized codes",
  "created": "2026-03-28",
  "version": "1.0"
}
