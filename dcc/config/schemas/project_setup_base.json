{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dcc-pipeline.internal/schemas/project-setup-base",
  "title": "DCC Project Setup Base Schema",
  "description": "Base schema with reusable definitions for project setup validation",
  "version": "2.0.0",
  "type": "object",
  "definitions": {
    "file_entry": {
      "type": "object",
      "description": "Generic file entry with common metadata",
      "properties": {
        "filename": {
          "type": "string",
          "description": "Filename or relative path"
        },
        "required": {
          "type": "boolean",
          "description": "Whether this file is mandatory"
        },
        "description": {
          "type": "string",
          "description": "Purpose of this file"
        },
        "approximate_size": {
          "type": "string",
          "description": "Expected approximate file size"
        }
      },
      "required": ["filename", "required", "description"]
    },
    "typed_file_entry": {
      "allOf": [
        {"$ref": "#/definitions/file_entry"}
      ],
      "type": "object",
      "description": "File entry with type classification",
      "properties": {
        "type": {
          "type": "string",
          "description": "Type of file"
        }
      },
      "required": ["filename", "required", "type", "description"]
    },
    "python_module_entry": {
      "allOf": [
        {"$ref": "#/definitions/typed_file_entry"}
      ],
      "type": "object",
      "description": "Python module with exported functions",
      "properties": {
        "type": {
          "enum": ["python_module", "python_script"]
        },
        "main_functions": {
          "type": "array",
          "description": "Key functions/classes provided",
          "items": {"type": "string"}
        }
      }
    },
    "path_entry": {
      "type": "object",
      "description": "Path-based entry (for folders, modules, etc.)",
      "properties": {
        "path": {
          "type": "string",
          "description": "Relative path"
        },
        "type": {
          "type": "string",
          "description": "Type of entry"
        },
        "required": {
          "type": "boolean",
          "description": "Whether this entry is mandatory"
        },
        "description": {
          "type": "string",
          "description": "Purpose of this entry"
        },
        "main_functions": {
          "type": "array",
          "description": "Key functions/classes provided (for modules)",
          "items": {"type": "string"}
        }
      },
      "required": ["path", "type", "required", "description"]
    },
    "pattern_rule": {
      "type": "object",
      "description": "Pattern-based discovery rule for auto-registration",
      "properties": {
        "pattern": {
          "type": "string",
          "description": "Glob pattern for matching files (e.g., '*_schema.json', '**/config/*.json')"
        },
        "directory": {
          "type": "string",
          "description": "Base directory for pattern matching (relative to project root)"
        },
        "recursive": {
          "type": "boolean",
          "description": "Whether to search recursively in subdirectories",
          "default": false
        },
        "auto_register": {
          "type": "boolean",
          "description": "Whether to automatically register matching files as required",
          "default": true
        },
        "category": {
          "type": "string",
          "description": "Category for discovered files (e.g., 'validation_schema', 'engine_schema')"
        },
        "exclude_patterns": {
          "type": "array",
          "description": "Patterns to exclude from matching",
          "items": {"type": "string"},
          "default": ["**/backup/**", "**/test*/**", "**/.*/**"]
        }
      },
      "required": ["pattern", "directory"]
    },
    "validation_rule": {
      "type": "object",
      "description": "Validation rule for schema files",
      "properties": {
        "filename": {"type": "string"},
        "type": {
          "type": "string",
          "enum": ["json_schema", "python_module", "documentation"]
        },
        "required": {"type": "boolean"},
        "description": {"type": "string"},
        "schema_checks": {
          "type": "array",
          "description": "Validation checks to perform",
          "items": {
            "enum": ["syntax", "references", "definitions", "required_fields"]
          }
        }
      },
      "required": ["filename", "type", "required", "description"]
    },
    "dependency_entry": {
      "type": "object",
      "additionalProperties": false,
      "description": "Python module dependency",
      "properties": {
        "module": {"type": "string"},
        "members": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Required classes/functions from this module"
        },
        "optional": {
          "type": "boolean",
          "description": "Whether this dependency is optional",
          "default": false
        }
      },
      "required": ["module"]
    }
  },
  "properties": {
    "$schema": {"type": "string"},
    "$id": {"type": "string"},
    "title": {"type": "string"},
    "description": {"type": "string"},
    "version": {"type": "string"},
    "project_id": {
      "type": "string",
      "description": "Unique project identifier"
    },
    "extends_base": {
      "type": "boolean",
      "description": "Whether this setup extends the base DCC configuration",
      "default": false
    },
    "base_config": {
      "type": "string",
      "description": "Reference to base configuration file (for inheritance)",
      "default": "project_setup_base.json"
    }
  },
  "required": ["version"]
}
