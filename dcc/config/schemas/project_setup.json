{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DCC Project Setup Validation Schema",
  "description": "Schema for validating required folders and files for DCC project distribution and setup",
  "version": "1.0.0",
  "type": "object",
  "properties": {
    "folders": {
      "type": "array",
      "description": "All required and optional directories for the DCC project",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Relative path of the folder from project root"
          },
          "required": {
            "type": "boolean",
            "description": "Whether this folder is mandatory"
          },
          "purpose": {
            "type": "string",
            "description": "Description of the folder's purpose"
          },
          "auto_created": {
            "type": "boolean",
            "description": "Whether this folder is auto-created on first run"
          }
        },
        "required": ["name", "required", "purpose"]
      }
    },
    "root_files": {
      "type": "array",
      "description": "Files required at the project root level",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Filename at root level"
          },
          "required": {
            "type": "boolean",
            "description": "Whether this file is mandatory"
          },
          "purpose": {
            "type": "string",
            "description": "Description of the file's purpose"
          },
          "extension": {
            "type": "string",
            "enum": ["yml", "yaml", "md", "txt", "py", "json", "other"],
            "description": "File type extension"
          }
        },
        "required": ["name", "required", "purpose"]
      }
    },
    "schema_files": {
      "type": "array",
      "description": "Required JSON schema definition files (located in config/schemas)",
      "items": {
        "type": "object",
        "properties": {
          "filename": {
            "type": "string",
            "description": "Schema filename"
          },
          "required": {
            "type": "boolean",
            "description": "Whether this schema file is mandatory"
          },
          "description": {
            "type": "string",
            "description": "Purpose of this schema file"
          },
          "approximate_size": {
            "type": "string",
            "description": "Expected approximate file size"
          }
        },
        "required": ["filename", "required", "description"]
      }
    },
    "workflow_files": {
      "type": "array",
      "description": "Required workflow notebooks and Python modules (located in workflow)",
      "items": {
        "type": "object",
        "properties": {
          "filename": {
            "type": "string",
            "description": "Workflow filename"
          },
          "required": {
            "type": "boolean",
            "description": "Whether this workflow file is mandatory"
          },
          "type": {
            "type": "string",
            "enum": ["notebook", "python_module", "documentation"],
            "description": "Type of workflow file"
          },
          "description": {
            "type": "string",
            "description": "Purpose of this workflow file"
          },
          "approximate_size": {
            "type": "string",
            "description": "Expected approximate file size"
          }
        },
        "required": ["filename", "required", "type", "description"]
      }
    },
    "tool_files": {
      "type": "array",
      "description": "Required utility and setup script files (located in tools)",
      "items": {
        "type": "object",
        "properties": {
          "filename": {
            "type": "string",
            "description": "Tool filename"
          },
          "required": {
            "type": "boolean",
            "description": "Whether this tool file is mandatory"
          },
          "type": {
            "type": "string",
            "enum": ["python_script", "shell_script", "other"],
            "description": "Type of tool file"
          },
          "description": {
            "type": "string",
            "description": "Purpose of this tool file"
          },
          "main_functions": {
            "type": "array",
            "description": "Key functions provided by this tool",
            "items": {
              "type": "string"
            }
          }
        },
        "required": ["filename", "required", "type", "description"]
      }
    },
    "processor_engine": {
      "type": "array",
      "description": "Document processor engine modules (located in workflow/processor_engine)",
      "items": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "Relative path from workflow/processor_engine"
          },
          "type": {
            "type": "string",
            "enum": ["folder", "python_module", "documentation", "init_file", "test_file"],
            "description": "Type of processor engine item"
          },
          "required": {
            "type": "boolean",
            "description": "Whether this item is mandatory"
          },
          "description": {
            "type": "string",
            "description": "Purpose of this module/file"
          },
          "main_functions": {
            "type": "array",
            "description": "Key functions/classes provided (for modules)",
            "items": {
              "type": "string"
            }
          }
        },
        "required": ["path", "type", "required", "description"]
      }
    },
    "mapper_engine": {
      "type": "array",
      "description": "Column mapper engine modules (located in workflow/mapper_engine)",
      "items": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "Relative path from workflow/mapper_engine"
          },
          "type": {
            "type": "string",
            "enum": ["folder", "python_module", "documentation", "init_file"],
            "description": "Type of mapper engine item"
          },
          "required": {
            "type": "boolean",
            "description": "Whether this item is mandatory"
          },
          "description": {
            "type": "string",
            "description": "Purpose of this module/file"
          },
          "main_functions": {
            "type": "array",
            "description": "Key functions/classes provided (for modules)",
            "items": {
              "type": "string"
            }
          }
        },
        "required": ["path", "type", "required", "description"]
      }
    },
    "schema_validation": {
      "type": "array",
      "description": "Schema validation modules (located in workflow)",
      "items": {
        "type": "object",
        "properties": {
          "filename": {
            "type": "string",
            "description": "Schema validation filename"
          },
          "type": {
            "type": "string",
            "enum": ["python_module"],
            "description": "Type of schema validation item"
          },
          "required": {
            "type": "boolean",
            "description": "Whether this item is mandatory"
          },
          "description": {
            "type": "string",
            "description": "Purpose of this module"
          },
          "main_functions": {
            "type": "array",
            "description": "Key functions/classes provided",
            "items": {
              "type": "string"
            }
          }
        },
        "required": ["filename", "type", "required", "description"]
      }
    },
    "schema_engine": {
      "type": "array",
      "description": "Schema engine modules (located in workflow/schema_engine)",
      "items": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "Relative path from workflow/schema_engine"
          },
          "type": {
            "type": "string",
            "enum": ["folder", "python_module", "documentation", "init_file"],
            "description": "Type of schema engine item"
          },
          "required": {
            "type": "boolean",
            "description": "Whether this item is mandatory"
          },
          "description": {
            "type": "string",
            "description": "Purpose of this module/file"
          },
          "main_functions": {
            "type": "array",
            "description": "Key functions/classes provided (for modules)",
            "items": {
              "type": "string"
            }
          }
        },
        "required": ["path", "type", "required", "description"]
      }
    },
    "initiation_engine": {
      "type": "array",
      "description": "Initiation engine modules (located in workflow/initiation_engine)",
      "items": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "Relative path from workflow/initiation_engine"
          },
          "type": {
            "type": "string",
            "enum": ["folder", "python_module", "documentation", "init_file"],
            "description": "Type of initiation engine item"
          },
          "required": {
            "type": "boolean",
            "description": "Whether this item is mandatory"
          },
          "description": {
            "type": "string",
            "description": "Purpose of this module/file"
          },
          "main_functions": {
            "type": "array",
            "description": "Key functions/classes provided (for modules)",
            "items": {
              "type": "string"
            }
          }
        },
        "required": ["path", "type", "required", "description"]
      }
    },
    "environment": {
      "type": "array",
      "description": "Environment specifications for the project",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Environment spec name or identifier"
          },
          "required": {
            "type": "boolean",
            "description": "Whether this environment spec is mandatory"
          },
          "file": {
            "type": "string",
            "description": "Environment specification filename"
          },
          "location": {
            "type": "string",
            "description": "Location relative to project root"
          },
          "setup_commands": {
            "type": "array",
            "description": "Commands to set up the environment",
            "items": {
              "type": "string"
            }
          },
          "key_dependencies": {
            "type": "array",
            "description": "Key Python packages required",
            "items": {
              "type": "string"
            }
          }
        },
        "required": ["name", "required", "file"]
      }
    },
    "validation_rules": {
      "type": "array",
      "description": "Validation rule toggles for project setup checks",
      "items": {
        "type": "object",
        "properties": {
          "rule": {
            "type": "string",
            "description": "Name of the validation rule"
          },
          "enabled": {
            "type": "boolean",
            "description": "Whether this rule is active"
          },
          "description": {
            "type": "string",
            "description": "What this rule checks"
          }
        },
        "required": ["rule", "enabled"]
      }
    }
  },
  "required": [
    "folders",
    "root_files",
    "schema_files",
    "workflow_files",
    "tool_files",
    "processor_engine",
    "mapper_engine",
    "schema_validation",
    "schema_engine",
    "initiation_engine",
    "environment",
    "validation_rules"
  ],
  "project_setup": [
    {
      "folders": [
        {
          "name": "config/schemas",
          "required": true,
          "purpose": "Schema definitions"
        },
        {
          "name": "data",
          "required": false,
          "purpose": "Input data files"
        },
        {
          "name": "output",
          "required": false,
          "purpose": "Generated output",
          "auto_created": true
        },
        {
          "name": "reference",
          "required": false,
          "purpose": "Documentation and instructions"
        },
        {
          "name": "workflow",
          "required": true,
          "purpose": "Processing notebooks and modules"
        },
        {
          "name": "tools",
          "required": true,
          "purpose": "Setup and utility scripts"
        }
      ],
      "root_files": [
        {
          "name": "dcc.yml",
          "required": true,
          "purpose": "Conda environment specification",
          "extension": "yml"
        },
        {
          "name": "README.md",
          "required": false,
          "purpose": "Project overview",
          "extension": "md"
        }
      ],
      "schema_files": [
        {
          "filename": "dcc_register_enhanced.json",
          "required": true,
          "description": "Main schema with column definitions, aliases, null handling",
          "approximate_size": "~56KB"
        },
        {
          "filename": "department_schema.json",
          "required": true,
          "description": "Department validation rules",
          "approximate_size": "~454B"
        },
        {
          "filename": "discipline_schema.json",
          "required": true,
          "description": "Discipline validation rules",
          "approximate_size": "~379B"
        },
        {
          "filename": "document_type_schema.json",
          "required": true,
          "description": "Document type validation rules",
          "approximate_size": "~350B"
        },
        {
          "filename": "approval_code_schema.json",
          "required": true,
          "description": "Status code definition and mappings (APP, REJ, PEN, etc.)",
          "approximate_size": "~1316B"
        }
      ],
      "workflow_files": [
        {
          "filename": "dcc_register_processor_main.ipynb",
          "required": true,
          "type": "notebook",
          "description": "Main orchestration notebook - Step-by-step processing",
          "approximate_size": "~85KB"
        },
        {
          "filename": "dcc_register_processor_main.py",
          "required": true,
          "type": "python_module",
          "description": "Main Python pipeline for setup validation, schema validation, mapping, and processing",
          "approximate_size": "~12KB"
        },
        {
          "filename": "dcc_engine_pipeline.py",
          "required": true,
          "type": "python_module",
          "description": "Modular engine pipeline using four engine folders: initiation, schema, mapper, processor",
          "main_functions": [
            "run_engine_pipeline",
            "test_environment"
          ],
          "approximate_size": "~15KB"
        },
        {
          "filename": "universal_document_processor.py",
          "required": true,
          "type": "python_module",
          "description": "Schema-driven processing engine",
          "approximate_size": "~25KB"
        },
        {
          "filename": "universal_column_mapper.py",
          "required": true,
          "type": "python_module",
          "description": "Fuzzy column name mapping",
          "approximate_size": "~20KB"
        },
        {
          "filename": "schema_validation.py",
          "required": true,
          "type": "python_module",
          "description": "Standalone schema validation and schema dependency resolution",
          "approximate_size": "~10KB"
        }
      ],
      "tool_files": [
        {
          "filename": "project_setup_tools.py",
          "required": true,
          "type": "python_script",
          "description": "Main validation tool - Checks all required files and folders",
          "main_functions": [
            "validate_project_structure",
            "analyze_columns",
            "check_workflow_dependencies",
            "reorganize_schema_columns"
          ]
        }
      ],
      "processor_engine": [
        {
          "path": "engine",
          "type": "folder",
          "required": true,
          "description": "Main engine package"
        },
        {
          "path": "engine/__init__.py",
          "type": "init_file",
          "required": true,
          "description": "Engine package exports"
        },
        {
          "path": "engine/readme.md",
          "type": "documentation",
          "required": false,
          "description": "Engine module documentation"
        },
        {
          "path": "engine/core",
          "type": "folder",
          "required": true,
          "description": "Core engine components"
        },
        {
          "path": "engine/core/__init__.py",
          "type": "init_file",
          "required": true,
          "description": "Core module exports"
        },
        {
          "path": "engine/core/base.py",
          "type": "python_module",
          "required": true,
          "description": "BaseProcessor with shared utilities",
          "main_functions": ["BaseProcessor", "_resolve_schema_reference"]
        },
        {
          "path": "engine/core/engine.py",
          "type": "python_module",
          "required": true,
          "description": "CalculationEngine orchestrator",
          "main_functions": ["CalculationEngine", "apply_null_handling", "apply_calculations"]
        },
        {
          "path": "engine/core/registry.py",
          "type": "python_module",
          "required": true,
          "description": "Handler registries for calculations and null handling",
          "main_functions": ["get_null_handler", "get_calculation_handler", "register_calculation_handler"]
        },
        {
          "path": "engine/calculations",
          "type": "folder",
          "required": true,
          "description": "Calculation implementations"
        },
        {
          "path": "engine/calculations/__init__.py",
          "type": "init_file",
          "required": true,
          "description": "Calculations module exports"
        },
        {
          "path": "engine/calculations/aggregate.py",
          "type": "python_module",
          "required": true,
          "description": "Grouping/aggregation calculations",
          "main_functions": ["apply_aggregate_calculation", "apply_latest_by_date_calculation", "apply_latest_non_pending_status"]
        },
        {
          "path": "engine/calculations/composite.py",
          "type": "python_module",
          "required": true,
          "description": "Composite, row index, delay calculations",
          "main_functions": ["apply_composite_calculation", "apply_row_index", "apply_delay_of_resubmission", "apply_copy_calculation"]
        },
        {
          "path": "engine/calculations/conditional.py",
          "type": "python_module",
          "required": true,
          "description": "Conditional logic calculations",
          "main_functions": ["apply_update_resubmission_required", "apply_submission_closure_status", "apply_calculate_overdue_status"]
        },
        {
          "path": "engine/calculations/date.py",
          "type": "python_module",
          "required": true,
          "description": "Date arithmetic calculations",
          "main_functions": ["apply_date_calculation", "calculate_working_days", "apply_resubmission_plan_date"]
        },
        {
          "path": "engine/calculations/mapping.py",
          "type": "python_module",
          "required": true,
          "description": "Value mapping calculations",
          "main_functions": ["apply_mapping_calculation", "apply_status_to_code"]
        },
        {
          "path": "engine/calculations/null_handling.py",
          "type": "python_module",
          "required": true,
          "description": "Null handling strategies",
          "main_functions": ["apply_forward_fill", "apply_default_value", "apply_lookup_if_null"]
        },
        {
          "path": "engine/calculations/validation.py",
          "type": "python_module",
          "required": true,
          "description": "Data validation functions",
          "main_functions": ["collect_raw_pattern_errors", "apply_validation"]
        },
        {
          "path": "engine/schema",
          "type": "folder",
          "required": true,
          "description": "Schema utilities"
        },
        {
          "path": "engine/schema/__init__.py",
          "type": "init_file",
          "required": true,
          "description": "Schema module exports"
        },
        {
          "path": "engine/schema/dependency.py",
          "type": "python_module",
          "required": true,
          "description": "Dependency resolution and calculation ordering",
          "main_functions": ["resolve_calculation_order"]
        },
        {
          "path": "engine/schema/processor.py",
          "type": "python_module",
          "required": true,
          "description": "Schema processing utilities"
        },
        {
          "path": "engine/utils",
          "type": "folder",
          "required": true,
          "description": "Utility functions"
        },
        {
          "path": "engine/utils/__init__.py",
          "type": "init_file",
          "required": true,
          "description": "Utils module exports"
        },
        {
          "path": "engine/utils/dateframe.py",
          "type": "python_module",
          "required": true,
          "description": "DataFrame manipulation utilities",
          "main_functions": ["prepare_dataframe_for_processing", "flatten_columns", "move_column_to_front"]
        },
        {
          "path": "engine/utils/logging.py",
          "type": "python_module",
          "required": false,
          "description": "Logging utilities"
        },
        {
          "path": "test",
          "type": "folder",
          "required": false,
          "description": "Engine test files"
        },
        {
          "path": "test/test_calculations_date.py",
          "type": "test_file",
          "required": false,
          "description": "Date calculation tests"
        },
        {
          "path": "test/test_core_registry.py",
          "type": "test_file",
          "required": false,
          "description": "Registry tests"
        },
        {
          "path": "test/test_engine_integration.py",
          "type": "test_file",
          "required": false,
          "description": "Engine integration tests"
        },
        {
          "path": "test/test_schema_dependency.py",
          "type": "test_file",
          "required": false,
          "description": "Schema dependency tests"
        }
      ],
      "mapper_engine": [
        {
          "path": "engine",
          "type": "folder",
          "required": true,
          "description": "Main mapper engine package"
        },
        {
          "path": "engine/__init__.py",
