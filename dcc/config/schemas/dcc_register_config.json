{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dcc-pipeline.internal/schemas/dcc-register-config",
  "title": "DCC Register Configuration Data",
  "description": "Actual configuration items for DCC register column processing and parameters. References fragment schemas for categorical data.",
  "version": "1.0.0",
  "type": "object",
  "additionalProperties": false,
  "global_parameters": [
    {
      "fail_fast": false,
      "debug_dev_mode": false,
      "is_colab": false,
      "overwrite_existing_downloads": true,
      "duration_is_working_day": true,
      "pc_name": "CESL-22120",
      "start_col": "P",
      "end_col": "AP",
      "header_row_index": 4,
      "first_review_duration": 20,
      "second_review_duration": 14,
      "resubmission_duration": 14,
      "progress_stage": "not_start",
      "upload_sheet_name": "Prolog Submittals",
      "win_upload_file": "data/Submittal and RFI Tracker Lists.xlsx",
      "win_download_path": "output",
      "linux_upload_file": "data/Submittal and RFI Tracker Lists.xlsx",
      "linux_download_path": "output",
      "colab_upload_file": "/content/sample_data/Submittal and RFI Tracker Lists.xlsx",
      "colab_download_path": "/content/output",
      "upload_file_name": "data/Submittal and RFI Tracker Lists.xlsx",
      "download_file_path": "output",
      "pending_status": {
        "schema": "approval_code_schema",
        "code": "PEN",
        "field": "status",
        "description": "Resolved from approval_code_schema approval entry with code 'PEN'. Ensures single source of truth for pending status."
      },
      "dynamic_column_creation": {
        "enabled": true,
        "missing_column_action": "create_with_default",
        "default_value": "NA",
        "description": "Executed by _initialize_missing_columns. If a schema column is not found in the input data, it is created using the global or column-specific default value."
      }
    }
  ],
  "departments": {"$ref": "https://dcc-pipeline.internal/schemas/department#/departments"},
  "disciplines": {"$ref": "https://dcc-pipeline.internal/schemas/discipline#/disciplines"},
  "facilities": {"$ref": "https://dcc-pipeline.internal/schemas/facility#/facilities"},
  "document_types": {"$ref": "https://dcc-pipeline.internal/schemas/document-type#/document_types"},
  "projects": {"$ref": "https://dcc-pipeline.internal/schemas/project#/projects"},
  "column_types": [
    {
      "id_column": {
        "data_type": "string",
        "is_calculated": true,
        "create_if_missing": true
      },
      "code_column": {
        "data_type": "categorical",
        "is_calculated": false
      },
      "date_column": {
        "data_type": "date",
        "is_calculated": false
      },
      "sequence_column": {
        "data_type": "string",
        "is_calculated": false
      },
      "status_column": {
        "data_type": "categorical",
        "is_calculated": false
      }
    }
  ],
  "column_patterns": [
    {
      "pattern_validation": {
        "type": "pattern",
        "pattern": "^[A-Z0-9-]*$",
        "description": "Standard alphanumeric pattern with dashes"
      },
      "schema_validation": {
        "type": "schema_reference_check",
        "description": "Cross-reference with approved schemas"
      },
      "range_validation": {
        "type": "min_value",
        "min_value": 0,
        "description": "Non-negative value check"
      }
    }
  ],
  "column_strategies": [
    {
      "forward_fill_with_padding": {
        "strategy": "forward_fill",
        "formatting": {
          "zero_pad": 4
        }
      },
      "multi_level_forward_fill": {
        "strategy": "multi_level_forward_fill",
        "final_fill": "NA"
      }
    }
  ],
  "column_sequence": [
    "Row_Index",
    "Transmittal_Number",
    "Submission_Session",
    "Submission_Session_Revision",
    "Submission_Session_Subject",
    "Department",
    "Submitted_By",
    "Submission_Date",
    "Project_Code",
    "Facility_Code",
    "Document_Type",
    "Discipline",
    "Document_Sequence_Number",
    "Document_ID",
    "Document_ID_Affixes",
    "Document_Revision",
    "Document_Title",
    "Reviewer",
    "Review_Return_Actual_Date",
    "Review_Return_Plan_Date",
    "Review_Status",
    "Review_Status_Code",
    "Review_Comments",
    "Duration_of_Review",
    "Approval_Code",
    "First_Submission_Date",
    "Latest_Submission_Date",
    "Latest_Revision",
    "All_Submission_Sessions",
    "All_Submission_Dates",
    "All_Submission_Session_Revisions",
    "Count_of_Submissions",
    "Latest_Approval_Status",
    "Latest_Approval_Code",
    "All_Approval_Code",
    "Consolidated_Submission_Session_Subject",
    "Submission_Closed",
    "Resubmission_Required",
    "Resubmission_Plan_Date",
    "Resubmission_Forecast_Date",
    "Resubmission_Overdue_Status",
    "Delay_of_Resubmission",
    "Notes",
    "Submission_Reference_1",
    "Internal_Reference",
    "This_Submission_Approval_Code",
    "Validation_Errors"
  ],
  "column_groups": {
    "document_info": [
      "Project_Code",
      "Facility_Code",
      "Document_Type",
      "Discipline",
      "Document_Sequence_Number",
      "Document_ID",
      "Document_Revision",
      "Document_Title"
    ],
    "submission_info": [
      "Transmittal_Number",
      "Submission_Session",
      "Submission_Session_Revision",
      "Submission_Session_Subject",
      "Department",
      "Submitted_By",
      "Submission_Date"
    ],
    "review_info": [
      "Review_Status",
      "Approval_Code",
      "Review_Return_Actual_Date"
    ],
    "metadata": [
      "Department",
      "Discipline",
      "Project_Code",
      "Facility_Code"
    ]
  }
}
